<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
  <!-- v5 — forced cache bust -->
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="HeroQuest">
<meta name="theme-color" content="#1a0f00">
<link rel="manifest" href="./manifest.json">
<title>HeroQuest</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Pro:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
:root{--pa:#f2e8d0;--pad:#ddd0a8;--bl:#8b1a1a;--bld:#5c0f0f;--go:#c9962a;--god:#7a5a18;--gol:#f0c040;--st:#2a2420;--stl:#5a504a;--mb:#2a4a7f;--mg:#4a80d4;--gr:#5ab05a;--grd:#2a5a2a;--pu:#7a2a9a;--pul:#b060d4;--fs:15px;--fs-sm:12px;--fs-xs:11px}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overscroll-behavior:none}
body{font-family:'Crimson Pro',serif;background:var(--st);color:var(--pa);max-width:430px;margin:0 auto;padding-bottom:env(safe-area-inset-bottom);font-size:16px}
body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse at 20% 0%,rgba(201,150,42,.07) 0%,transparent 55%),radial-gradient(ellipse at 80% 100%,rgba(139,26,26,.09) 0%,transparent 55%);pointer-events:none;z-index:0}
header{position:sticky;top:0;z-index:100;background:linear-gradient(180deg,#0d0a07,var(--st));border-bottom:2px solid var(--god);padding:11px 16px 6px;text-align:center;box-shadow:0 4px 20px rgba(0,0,0,.8)}
header::after{content:'HEROQUEST';display:block;font-size:8px;color:var(--god);letter-spacing:8px;margin-top:1px}
.logo{font-family:'Cinzel',serif;font-size:22px;font-weight:700;color:var(--go);letter-spacing:3px}
.logo span{color:var(--bl)}
.sind{position:absolute;top:10px;right:12px;font-size:9px;color:var(--god);font-family:'Cinzel',serif;opacity:0;transition:opacity .5s}
.sind.v{opacity:1}
.tabs{display:flex;background:#12100d;border-bottom:1px solid var(--god);position:sticky;top:58px;z-index:99}
.tb{flex:1;padding:10px 2px 8px;background:none;border:none;color:var(--stl);font-family:'Cinzel',serif;font-size:11px;font-weight:600;cursor:pointer;border-bottom:2px solid transparent;display:flex;flex-direction:column;align-items:center;gap:2px;touch-action:manipulation;transition:color .2s}
.tb .ti{font-size:18px}
.tb.active{color:var(--go);border-bottom-color:var(--go);background:rgba(201,150,42,.06)}
.view{display:none;animation:fIn .25s ease;padding-bottom:24px}
.view.active{display:block}
@keyframes fIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.stit{font-family:'Cinzel',serif;font-size:12px;letter-spacing:3px;color:var(--god);text-align:center;padding:11px 0 3px;text-transform:uppercase}
.scard{margin:10px 14px 0;background:linear-gradient(135deg,#1e1810,#2a2218);border:1px solid rgba(201,150,42,.2);border-radius:4px;overflow:hidden}
.sct{font-family:'Cinzel',serif;font-size:11px;letter-spacing:2px;color:var(--god);padding:7px 13px;background:rgba(0,0,0,.3);border-bottom:1px solid rgba(201,150,42,.1);text-transform:uppercase;display:flex;align-items:center;justify-content:space-between}
.sctb{background:none;border:1px solid rgba(201,150,42,.3);color:var(--god);font-family:'Cinzel',serif;font-size:8px;padding:3px 7px;border-radius:2px;cursor:pointer;touch-action:manipulation}
.sctb:active{background:rgba(201,150,42,.1)}
/* hero cards */
.hgrid{padding:13px;display:flex;flex-direction:column;gap:11px}
.hcard{background:linear-gradient(135deg,#1e1810,#2a2218,#1a150e);border:1px solid var(--god);border-radius:4px;overflow:hidden;transition:transform .15s;touch-action:manipulation}
.hcard:active{transform:scale(.985)}
.hcard.dead{opacity:.5;filter:grayscale(.6)}
.hch{display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:1px solid rgba(201,150,42,.15)}
.hav{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;border:2px solid var(--god);flex-shrink:0}
.hnm{font-family:'Cinzel',serif;font-size:18px;font-weight:700;color:var(--go)}
.hcl{font-size:14px;color:var(--pad);font-style:italic}
.hlv{background:var(--bld);border:1px solid var(--bl);color:var(--pa);font-family:'Cinzel',serif;font-size:12px;padding:3px 7px;border-radius:2px;white-space:nowrap}
.hsts{display:grid;grid-template-columns:repeat(4,1fr)}
.sb{padding:6px 3px;text-align:center;border-right:1px solid rgba(201,150,42,.1)}
.sb:last-child{border-right:none}
.slb{font-family:'Cinzel',serif;font-size:10px;letter-spacing:1px;color:var(--stl);text-transform:uppercase;display:block;margin-bottom:1px}
.sv{font-family:'Cinzel',serif;font-size:23px;font-weight:700;line-height:1}
.hp{color:var(--bl)}.mp{color:var(--mg)}.atk{color:var(--go)}.def{color:var(--gr)}
.smx{font-size:11px;color:var(--stl);display:block}
.hbrs{padding:6px 12px 8px;display:flex;flex-direction:column;gap:4px}
.brow{display:flex;align-items:center;gap:6px}
.blb{font-size:11px;font-family:'Cinzel',serif;color:var(--stl);width:14px}
.btk{flex:1;height:6px;background:rgba(0,0,0,.5);border-radius:1px;overflow:hidden}
.bf{height:100%;border-radius:1px;transition:width .4s ease}
.hpb{background:linear-gradient(90deg,var(--bld),var(--bl))}
.mpb{background:linear-gradient(90deg,var(--mb),var(--mg))}
.btx{font-size:13px;color:var(--pad);min-width:30px;text-align:right}
.cact{display:grid;grid-template-columns:repeat(4,1fr);border-top:1px solid rgba(201,150,42,.1)}
.cab{padding:12px 2px;background:none;border:none;border-right:1px solid rgba(201,150,42,.1);font-size:21px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center;color:var(--pa)}
.cab:last-child{border-right:none;font-family:'Cinzel',serif;font-size:9px;color:var(--god)}
.cab:active{background:rgba(255,255,255,.05)}
/* detail panel */
.dpanel{position:fixed;inset:0;background:var(--st);z-index:1500;overflow-y:auto;max-width:430px;margin:0 auto;animation:slR .25s ease;padding-bottom:50px}
@keyframes slR{from{transform:translateX(28px);opacity:0}to{transform:translateX(0);opacity:1}}
.dtb{position:sticky;top:0;z-index:10;background:linear-gradient(180deg,#0d0a07,var(--st));padding:10px 13px;border-bottom:1px solid var(--god);display:flex;align-items:center;gap:10px}
.bbtn{background:none;border:none;color:var(--go);font-size:22px;cursor:pointer;padding:2px;touch-action:manipulation}
.dttl{font-family:'Cinzel',serif;font-size:11px;color:var(--god);letter-spacing:2px;flex:1}
.dhdr{background:linear-gradient(180deg,#0d0a07,#1a150e);padding:16px 13px;border-bottom:1px solid var(--god);display:flex;align-items:center;gap:13px}
.dav{width:82px;height:82px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:44px;border:3px solid var(--go);box-shadow:0 0 16px rgba(201,150,42,.3)}
.dname{font-family:'Cinzel',serif;font-size:24px;font-weight:700;color:var(--go)}
.dsubt{font-size:14px;color:var(--pad);font-style:italic}
.dgold{font-family:'Cinzel',serif;font-size:12px;color:var(--gol);margin-top:3px}
.sadj{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.04)}
.sadj:last-child{border-bottom:none}
.alb{font-size:16px;color:var(--pad);flex:1}
.alb small{display:block;font-size:10px;color:var(--stl)}
.acls{display:flex;align-items:center}
.abtn{width:42px;height:42px;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);color:var(--go);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;border-radius:2px;touch-action:manipulation}
.abtn:active{background:rgba(201,150,42,.2);transform:scale(.9)}
.aval{min-width:56px;text-align:center;font-family:'Cinzel',serif;font-size:24px;font-weight:700;color:var(--pa)}
.esl{display:flex;align-items:center;gap:12px;padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.04);cursor:pointer;transition:background .15s}
.esl:last-child{border-bottom:none}
.esl:active{background:rgba(201,150,42,.07)}
.spsl{display:flex;align-items:center;gap:12px;padding:11px 14px;border-bottom:1px solid rgba(255,255,255,.04)}
.spsl:last-child{border-bottom:none}
.sprm{background:none;border:none;color:var(--stl);font-size:15px;cursor:pointer;touch-action:manipulation}
.sprm:active{color:var(--bl)}
.ivit{display:flex;align-items:center;gap:9px;padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.04)}
.ivit:last-child{border-bottom:none}
.nfld{width:100%;min-height:90px;background:rgba(0,0,0,.3);border:1px solid rgba(201,150,42,.2);color:var(--pa);font-family:'Crimson Pro',serif;font-size:14px;line-height:1.5;padding:10px;resize:vertical;outline:none}
.nfld:focus{border-color:var(--god)}
.nfld::placeholder{color:var(--stl);font-style:italic}
/* rarity */
.rc{color:#aaa}.ru{color:var(--gr)}.rr{color:var(--mg)}.rl{color:var(--go)}.rm{color:var(--pul)}
/* SKIRMISH */
.skv{padding:13px;padding-bottom:80px}
.skbd{background:linear-gradient(135deg,#1a1208,#221a0e);border:2px solid var(--god);border-radius:6px;overflow:hidden;margin-bottom:11px}
.bdhd{padding:12px;border-bottom:1px solid rgba(201,150,42,.2);display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.bdtl{font-family:'Cinzel',serif;font-size:14px;color:var(--go)}
.bdst{font-size:10px;color:var(--stl);font-style:italic;margin-top:2px}
.bphs{font-family:'Cinzel',serif;font-size:9px;letter-spacing:1px;padding:4px 8px;border-radius:2px;border:1px solid;white-space:nowrap;flex-shrink:0}
.ph-ex{color:var(--go);border-color:var(--god);background:rgba(201,150,42,.1)}
.ph-cm{color:var(--bl);border-color:var(--bld);background:rgba(139,26,26,.1)}
.ph-ev{color:var(--mg);border-color:var(--mb);background:rgba(42,74,127,.15)}
.ph-rw{color:var(--gr);border-color:var(--grd);background:rgba(42,90,42,.15)}
/* ── SESSION SCREEN ── */
#session-screen{
  position:fixed;inset:0;z-index:1000;
  background:linear-gradient(180deg,#0d0a07 0%,#1a1208 50%,#0d0a07 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:30px 24px;max-width:430px;margin:0 auto;
  animation:fIn .4s ease;
}
.ss-logo{font-family:'Cinzel',serif;font-size:32px;font-weight:700;color:var(--go);
  text-shadow:0 0 30px rgba(201,150,42,.5),0 2px 6px rgba(0,0,0,.9);
  letter-spacing:4px;margin-bottom:4px;text-align:center}
.ss-logo span{color:var(--bl)}
.ss-sub{font-family:'Cinzel',serif;font-size:9px;letter-spacing:8px;color:var(--god);
  text-align:center;margin-bottom:40px}
.ss-emblem{font-size:64px;margin-bottom:8px;
  filter:drop-shadow(0 0 16px rgba(201,150,42,.4));
  animation:emblemPulse 3s ease-in-out infinite}
@keyframes emblemPulse{0%,100%{filter:drop-shadow(0 0 10px rgba(201,150,42,.3))}
  50%{filter:drop-shadow(0 0 24px rgba(201,150,42,.7))}}
.ss-divider{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--god),transparent);margin:0 auto 28px}
/* Save slot preview */
.ss-save-preview{
  width:100%;background:rgba(0,0,0,.5);
  border:1px solid rgba(201,150,42,.3);border-radius:6px;
  padding:12px 14px;margin-bottom:20px;position:relative;overflow:hidden
}
.ss-save-preview::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--go),transparent)}
.ss-save-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;
  color:var(--god);text-transform:uppercase;margin-bottom:8px}
.ss-save-heroes{display:flex;gap:8px;margin-bottom:8px;flex-wrap:wrap}
.ss-hero-chip{display:flex;align-items:center;gap:5px;
  background:rgba(42,30,18,.8);border:1px solid rgba(201,150,42,.25);
  border-radius:20px;padding:4px 9px 4px 4px}
.ss-hero-avatar{width:24px;height:24px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;border:1px solid var(--god);overflow:hidden;flex-shrink:0}
.ss-hero-name{font-family:'Cinzel',serif;font-size:10px;color:var(--pa);letter-spacing:.5px}
.ss-save-meta{font-size:10px;color:var(--stl);font-style:italic}
.ss-no-save{font-size:12px;color:var(--stl);font-style:italic;
  text-align:center;padding:8px 0}
/* Buttons */
.ss-btn{
  width:100%;padding:15px;border-radius:5px;border:none;
  font-family:'Cinzel',serif;font-size:13px;font-weight:600;
  letter-spacing:2px;cursor:pointer;touch-action:manipulation;
  transition:all .18s;margin-bottom:10px;display:flex;
  align-items:center;justify-content:center;gap:10px
}
.ss-btn:active{transform:scale(.97)}
.ss-btn-continue{
  background:linear-gradient(135deg,#3a2810,#2a1e08);
  border:2px solid var(--go);color:var(--go);
  box-shadow:0 0 20px rgba(201,150,42,.2)
}
.ss-btn-continue:active{box-shadow:0 0 30px rgba(201,150,42,.4)}
.ss-btn-new{
  background:linear-gradient(135deg,var(--bl),var(--bld));
  border:1px solid var(--bl);color:var(--pa)
}
.ss-btn-delete{
  background:none;border:1px solid rgba(255,255,255,.1);
  color:var(--stl);font-size:10px;padding:10px;margin-bottom:0
}
.ss-version{font-size:9px;color:rgba(90,80,74,.6);
  font-family:'Cinzel',serif;letter-spacing:1px;
  position:absolute;bottom:16px;text-align:center}
/* ── ORACLE / SKIRMISH ── */
.skv{padding:14px;padding-bottom:80px}
/* Lore card */
.lore-card{background:linear-gradient(160deg,#1a1005,#120c04);border:1px solid var(--god);border-radius:6px;overflow:hidden;margin-bottom:12px;position:relative}
.lore-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,var(--go),transparent)}
.lore-header{padding:12px 14px 8px;display:flex;align-items:center;gap:10px;border-bottom:1px solid rgba(201,150,42,.15)}
.lore-badge{font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;padding:4px 9px;border-radius:2px;border:1px solid;text-transform:uppercase}
.lore-title{font-family:'Cinzel',serif;font-size:21px;font-weight:700;color:var(--go);margin-bottom:2px}
.lore-obj{font-size:11px;color:var(--god);font-family:'Cinzel',serif;letter-spacing:.5px}
.lore-body{padding:14px 16px;font-size:15px;color:var(--pad);line-height:1.7;font-style:italic;border-bottom:1px solid rgba(201,150,42,.1)}
.lore-footer{padding:8px 14px;display:flex;gap:8px;flex-wrap:wrap}
.lore-tag{font-size:12px;font-family:'Cinzel',serif;padding:6px 12px;border-radius:4px;background:rgba(0,0,0,.5);border:1px solid;cursor:pointer;touch-action:manipulation;transition:all .18s;display:inline-flex;align-items:center;gap:5px}
.lore-tag:active{transform:scale(.95);filter:brightness(1.3)}
/* Condition popup */
.cond-overlay{position:fixed;inset:0;z-index:3000;background:rgba(0,0,0,.85);display:flex;align-items:center;justify-content:center;padding:20px;animation:fIn .2s ease}
.cond-popup{background:linear-gradient(160deg,#1e1810,#100c06);border-radius:10px;width:100%;max-width:400px;overflow:hidden;box-shadow:0 0 50px rgba(0,0,0,.95);animation:popIn .25s cubic-bezier(.34,1.4,.64,1)}
.cond-header{padding:16px 18px 12px;border-bottom:1px solid rgba(255,255,255,.08)}
.cond-name{font-family:'Cinzel',serif;font-size:20px;font-weight:700;margin-bottom:4px}
.cond-type{font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;color:var(--god)}
.cond-body{padding:16px 18px}
.cond-effect{font-size:15px;color:var(--pad);line-height:1.7;font-style:italic;margin-bottom:14px}
.cond-rules{display:flex;flex-direction:column;gap:8px}
.cond-rule{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;background:rgba(0,0,0,.35);border-radius:5px;border:1px solid rgba(255,255,255,.07)}
.cond-rule-ico{font-size:20px;flex-shrink:0;margin-top:1px}
.cond-rule-txt{font-size:13px;color:var(--pa);line-height:1.5}
.cond-close{width:100%;margin:14px 18px 0;padding:12px;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);border-radius:5px;color:var(--god);font-family:'Cinzel',serif;font-size:12px;letter-spacing:1px;cursor:pointer;touch-action:manipulation}
/* Oracle question categories */
.oracle-section{margin-bottom:14px}
.oracle-cat-title{font-family:'Cinzel',serif;font-size:10px;letter-spacing:3px;color:var(--god);text-transform:uppercase;padding:10px 14px 6px;display:flex;align-items:center;gap:8px}
.oracle-cat-title::before,.oracle-cat-title::after{content:'';flex:1;height:1px;background:rgba(201,150,42,.2)}
.oracle-questions{display:flex;flex-direction:column;gap:6px;padding:0 14px}
/* Question button */
.oq-btn{background:linear-gradient(135deg,#1e1810,#2a2218);border:1px solid rgba(201,150,42,.25);border-radius:5px;padding:0;overflow:hidden;cursor:pointer;touch-action:manipulation;transition:all .18s;text-align:left;width:100%}
.oq-btn:active{transform:scale(.98);border-color:var(--god)}
.oq-inner{display:flex;align-items:center;gap:10px;padding:10px 12px}
.oq-ico{font-size:20px;flex-shrink:0;width:28px;text-align:center}
.oq-text{flex:1}
.oq-label{font-family:'Cinzel',serif;font-size:15px;color:var(--pa);letter-spacing:.5px;display:block;margin-bottom:1px}
.oq-hint{font-size:13px;color:var(--stl);font-style:italic}
.oq-arrow{color:var(--god);font-size:14px;flex-shrink:0}
.oq-btn.used{border-color:rgba(201,150,42,.1);opacity:.6}
.oq-btn.used .oq-label{color:var(--stl)}
/* Answer panel */
.oracle-answer{margin:0 14px 14px;background:linear-gradient(135deg,#0d0a07,#1a1208);border:2px solid var(--god);border-radius:5px;overflow:hidden;animation:answerIn .3s ease}
@keyframes answerIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.oa-header{padding:9px 12px;background:rgba(0,0,0,.4);border-bottom:1px solid rgba(201,150,42,.2);display:flex;align-items:center;gap:8px}
.oa-question{font-family:'Cinzel',serif;font-size:10px;color:var(--god);letter-spacing:1px;flex:1}
.oa-dice{font-family:'Cinzel',serif;font-size:10px;color:var(--stl)}
.oa-body{padding:12px 14px}
.oa-result{font-family:'Cinzel',serif;font-size:19px;font-weight:700;margin-bottom:6px}
.oa-detail{font-size:16px;color:var(--pad);line-height:1.6;font-style:italic}
.oa-effect{display:flex;align-items:center;gap:8px;margin-top:10px;padding:8px 10px;background:rgba(0,0,0,.3);border-radius:3px;border:1px solid rgba(201,150,42,.15)}
.oa-effect-ico{font-size:18px}
.oa-effect-txt{font-size:11px;color:var(--pa);font-family:'Cinzel',serif;letter-spacing:.5px}
.oa-actions{padding:8px 12px;border-top:1px solid rgba(201,150,42,.1);display:flex;gap:6px;flex-wrap:wrap}
.oa-act-btn{background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);border-radius:3px;color:var(--god);font-family:'Cinzel',serif;font-size:9px;letter-spacing:1px;padding:7px 10px;cursor:pointer;touch-action:manipulation;transition:all .15s}
.oa-act-btn:active{background:rgba(201,150,42,.15);color:var(--go)}
.oa-act-btn.pri{background:linear-gradient(135deg,var(--bl),var(--bld));border-color:var(--bl);color:var(--pa)}
.oa-act-btn.gre{background:linear-gradient(135deg,var(--grd),#1a3010);border-color:var(--grd);color:var(--gr)}
/* Log */
.sk-log{margin:0 14px;padding:9px 12px;background:rgba(0,0,0,.3);border:1px solid rgba(201,150,42,.1);border-radius:4px;max-height:130px;overflow-y:auto}
.sk-log-title{font-family:'Cinzel',serif;font-size:8px;letter-spacing:2px;color:var(--stl);margin-bottom:5px;text-transform:uppercase}
.sk-log-item{font-size:13px;color:var(--pad);padding:3px 0;border-bottom:1px solid rgba(255,255,255,.03);line-height:1.4}
.sk-log-item:last-child{border-bottom:none}
/* New adventure button */
.new-adv-btn{display:block;width:calc(100% - 28px);margin:14px auto 0;background:linear-gradient(135deg,var(--bl),var(--bld));border:1px solid var(--bl);border-radius:5px;color:var(--pa);font-family:'Cinzel',serif;font-size:12px;font-weight:600;letter-spacing:2px;padding:13px;cursor:pointer;touch-action:manipulation;text-align:center}
.new-adv-btn:active{transform:scale(.98);opacity:.9}
/* ── END ORACLE ── */
/* toast */
.toast{position:fixed;top:72px;left:50%;transform:translateX(-50%) translateY(-16px);background:rgba(20,12,0,.97);border:1px solid var(--god);color:var(--pa);font-family:'Cinzel',serif;font-size:10px;letter-spacing:1px;padding:8px 16px;border-radius:4px;opacity:0;pointer-events:none;transition:all .3s;z-index:700;white-space:nowrap;max-width:90%;text-align:center}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
@keyframes popIn{from{transform:scale(.85);opacity:0}to{transform:scale(1);opacity:1}}
.fab{
  position:fixed;bottom:calc(24px + env(safe-area-inset-bottom));right:20px;
  width:62px;height:62px;
  background:linear-gradient(145deg,#a02020,#6a1010);
  border:2px solid #c03030;border-radius:50%;
  color:#f2e8d0;font-size:32px;font-weight:700;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  box-shadow:0 4px 24px rgba(139,26,26,.7),0 0 0 4px rgba(139,26,26,.15);
  z-index:200;transition:transform .15s,box-shadow .15s;
}
.fab:active{transform:scale(.88);box-shadow:0 2px 10px rgba(139,26,26,.5)}
.fab.hidden{display:none}
.mazo-view{padding:14px;padding-bottom:80px}
.mazo-card{background:linear-gradient(135deg,#1e1810,#2a2218);border:1px solid rgba(201,150,42,.2);border-radius:6px;overflow:hidden;margin-bottom:14px}
.mazo-card-header{padding:12px 14px;background:rgba(0,0,0,.3);border-bottom:1px solid rgba(201,150,42,.15);display:flex;align-items:center;justify-content:space-between}
.mazo-card-title{font-family:'Cinzel',serif;font-size:14px;color:var(--go);letter-spacing:.5px}
.mazo-card-sub{font-size:11px;color:var(--stl);font-style:italic;margin-top:2px}
.d20-table{width:100%;border-collapse:collapse}
.d20-table th{font-family:'Cinzel',serif;font-size:9px;letter-spacing:1px;color:var(--god);text-transform:uppercase;padding:8px 10px;background:rgba(0,0,0,.3);text-align:left;border-bottom:1px solid rgba(201,150,42,.1)}
.d20-table td{padding:8px 10px;border-bottom:1px solid rgba(255,255,255,.04);font-size:13px;color:var(--pad);vertical-align:top;line-height:1.4}
.d20-table td:first-child{font-family:'Cinzel',serif;font-size:12px;color:var(--go);font-weight:700;width:52px;text-align:center}
.d20-table tr:last-child td{border-bottom:none}
.d20-table tr:hover td{background:rgba(201,150,42,.04)}
.d20-roll-btn{background:linear-gradient(135deg,#2a1e0a,#1a1208);border:2px solid var(--god);border-radius:6px;color:var(--go);font-family:'Cinzel',serif;font-size:13px;letter-spacing:1px;padding:10px 16px;cursor:pointer;touch-action:manipulation;transition:all .15s;display:flex;align-items:center;gap:8px}
.d20-roll-btn:active{transform:scale(.94);border-color:var(--go)}
.d20-result{font-family:'Cinzel',serif;font-size:28px;font-weight:700;color:var(--go);text-shadow:0 0 16px rgba(201,150,42,.4);transition:all .3s}
.d20-result.rolling{animation:diceRollAnim .4s ease}
@keyframes diceRollAnim{0%{transform:scale(1.5) rotate(-10deg);opacity:0}60%{transform:scale(.9) rotate(5deg)}100%{transform:scale(1) rotate(0);opacity:1}}
.empty{padding:52px 26px;text-align:center}
.eico{font-size:48px;margin-bottom:12px;opacity:.4}
.etxt{font-family:'Cinzel',serif;font-size:13px;color:var(--stl);letter-spacing:1px;line-height:1.8}

/* ── MODAL OVERLAY ── */
.movl{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:2000;display:none;align-items:flex-end;justify-content:center;will-change:display;-webkit-backface-visibility:hidden;backface-visibility:hidden}
.movl.open{display:flex}
.modal{
  background:linear-gradient(180deg,#1e1810 0%,#140f08 100%);
  border:1px solid var(--god);border-top:2px solid var(--go);
  border-bottom:none;border-radius:10px 10px 0 0;
  width:100%;max-width:430px;
  padding:20px 18px calc(18px + env(safe-area-inset-bottom));
  animation:slUp .22s ease-out;
  max-height:90vh;overflow-y:auto;
  box-shadow:0 -8px 40px rgba(0,0,0,.8);
  will-change:transform;transform:translateZ(0);
}
@keyframes slUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.mtit{
  font-family:'Cinzel',serif;font-size:16px;font-weight:700;
  color:var(--go);letter-spacing:1px;
  margin-bottom:16px;
  display:flex;justify-content:space-between;align-items:center;
  padding-bottom:12px;
  border-bottom:1px solid rgba(201,150,42,.2);
}
.mcls{
  background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);
  border-radius:50%;width:28px;height:28px;
  color:var(--stl);font-size:14px;
  cursor:pointer;touch-action:manipulation;
  display:flex;align-items:center;justify-content:center;
  transition:all .15s;
}
.mcls:active{background:rgba(201,150,42,.15);color:var(--go)}

/* ── FORM FIELDS ── */
.ilb{
  font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;
  color:var(--god);text-transform:uppercase;
  display:block;margin-bottom:5px;
}
.ifl{
  width:100%;
  background:rgba(0,0,0,.5);
  border:1px solid rgba(201,150,42,.3);
  border-bottom:2px solid var(--god);
  border-radius:4px;
  color:var(--pa);
  font-family:'Crimson Pro',serif;font-size:16px;
  padding:10px 12px;
  margin-bottom:14px;
  outline:none;
  transition:border-color .2s;
}
.ifl:focus{border-color:var(--go);border-bottom-color:var(--go);background:rgba(0,0,0,.6)}
.ifl::placeholder{color:var(--stl);font-style:italic}
.slf{
  width:100%;background:rgba(0,0,0,.5);
  border:1px solid rgba(201,150,42,.3);border-radius:4px;
  color:var(--pa);font-size:14px;padding:9px 11px;
  margin-bottom:11px;outline:none;appearance:none;
}

/* ── PRIMARY BUTTON ── */
.bpri{
  width:100%;
  background:linear-gradient(135deg,var(--bl) 0%,var(--bld) 100%);
  border:1px solid rgba(139,26,26,.6);
  border-top:1px solid rgba(180,50,50,.4);
  border-radius:5px;
  color:var(--pa);
  font-family:'Cinzel',serif;font-size:12px;font-weight:700;
  letter-spacing:2px;padding:13px;
  cursor:pointer;margin-top:8px;
  touch-action:manipulation;
  transition:all .15s;
  box-shadow:0 2px 12px rgba(139,26,26,.3),inset 0 1px 0 rgba(255,100,100,.1);
}
.bpri:active{transform:scale(.98);box-shadow:none}
.bsec{
  width:100%;background:rgba(0,0,0,.4);
  border:1px solid rgba(201,150,42,.25);border-radius:4px;
  color:var(--god);font-family:'Cinzel',serif;font-size:11px;
  letter-spacing:1px;padding:10px;
  cursor:pointer;touch-action:manipulation;
  transition:all .15s;margin-top:6px;
}
.bsec:active{background:rgba(201,150,42,.1);color:var(--go)}
.bdng{background:rgba(70,10,10,.5);border-color:rgba(139,26,26,.5);font-size:10px;padding:11px}

/* ── RARITY BUTTONS ── */
.rgrd{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:10px}
.rbt{
  background:rgba(0,0,0,.4);border:1px solid rgba(255,255,255,.1);
  border-radius:3px;color:#888;
  font-family:'Cinzel',serif;font-size:8px;
  padding:7px 2px;cursor:pointer;text-align:center;touch-action:manipulation;
  transition:all .15s;
}
.rbt.sel{color:var(--go);border-color:var(--god);background:rgba(201,150,42,.12)}
.rbt[data-r=common].sel{color:#bbb;border-color:#666;background:rgba(100,100,100,.1)}
.rbt[data-r=uncommon].sel{color:var(--gr);border-color:var(--grd);background:rgba(42,90,42,.12)}
.rbt[data-r=rare].sel{color:var(--mg);border-color:var(--mb);background:rgba(42,74,127,.12)}
.rbt[data-r=legendary].sel{color:var(--go);border-color:var(--god);background:rgba(201,150,42,.12)}

/* ── HERO CLASS BUTTONS ── */
.htbt{
  background:linear-gradient(160deg,#1e1810,#2a2010);
  border:1px solid rgba(201,150,42,.25);
  border-radius:6px;
  color:var(--pad);
  cursor:pointer;touch-action:manipulation;
  transition:all .18s;
  position:relative;overflow:hidden;
}
.htbt::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(201,150,42,.04),transparent);
  opacity:0;transition:opacity .2s;
}
.htbt.sel{
  border-color:var(--go);border-width:2px;
  background:linear-gradient(160deg,#2a1e0a,#3a2a10);
  box-shadow:0 0 14px rgba(201,150,42,.25),inset 0 1px 0 rgba(201,150,42,.15);
}
.htbt.sel::before{opacity:1}
.htbt:active{transform:scale(.96)}
.hti{font-size:30px;line-height:1;display:block;margin-bottom:4px}
.htn{
  font-family:'Cinzel',serif;font-size:10px;font-weight:600;
  letter-spacing:.5px;display:block;margin-bottom:3px;
  color:var(--pa);
}
.htbt.sel .htn{color:var(--go)}
.hts{font-size:8px;color:var(--stl);display:block;line-height:1.4}
.htbt.sel .hts{color:var(--god)}

/* ── CLASS CATEGORY HEADER ── */
.cls-cat-hdr{
  font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;
  color:var(--god);text-transform:uppercase;
  padding:10px 0 6px;
  display:flex;align-items:center;gap:8px;
}
.cls-cat-hdr::before,.cls-cat-hdr::after{
  content:'';flex:1;height:1px;
  background:linear-gradient(90deg,transparent,rgba(201,150,42,.3),transparent);
}

/* ── SELECTED CLASS PREVIEW STRIP ── */
.cls-preview{
  background:linear-gradient(135deg,rgba(201,150,42,.08),rgba(0,0,0,.3));
  border:1px solid rgba(201,150,42,.2);border-radius:5px;
  padding:10px 12px;margin-bottom:14px;
  display:flex;align-items:center;gap:12px;
  min-height:60px;
}
.cls-preview-ico{font-size:34px;line-height:1;flex-shrink:0}
.cls-preview-info{flex:1}
.cls-preview-name{font-family:'Cinzel',serif;font-size:14px;color:var(--go);font-weight:700;margin-bottom:2px}
.cls-preview-cat{font-size:10px;color:var(--god);font-family:'Cinzel',serif;letter-spacing:1px;margin-bottom:4px}
.cls-preview-stats{display:flex;gap:8px;flex-wrap:wrap}
.cls-stat-pill{
  font-family:'Cinzel',serif;font-size:9px;
  padding:2px 7px;border-radius:10px;border:1px solid;
}
.cls-preview-skills{font-size:10px;color:var(--stl);font-style:italic;margin-top:4px;line-height:1.4}

</style>
</head>
<body>
<header>
  <div class="logo">HERO<span>QUEST</span></div>
  <span class="sind" id="sind">GUARDADO</span>
</header>
<nav class="tabs">
  <button class="tb active" onclick="showTab('heroes',this)"><span class="ti">&#9876;&#65039;</span>HEROES</button>
  <button class="tb" onclick="showTab('skirmish',this)"><span class="ti">&#128506;&#65039;</span>ESCARAMUZA</button>
  <button class="tb" onclick="showTab('mazo',this)"><span class="ti">&#127922;</span>MAZO</button>
  <button class="tb" onclick="showTab('notes',this)"><span class="ti">&#128214;</span>NOTAS</button>
</nav>
<div class="view active" id="view-heroes">
  <div class="hgrid" id="hcon">
    <div class="empty" id="ehero">
      <div class="eico">&#127984;</div>
      <div class="etxt">No hay heroes en la mazmorra.<br><br>Pulsa + para anadir<br>un aventurero.</div>
    </div>
  </div>
</div>
<div class="view" id="view-skirmish">
  <div class="skv" id="skcon"></div>
</div>
</div>
<div class="view" id="view-mazo">
  <div class="mazo-view" id="mazocon">
    <div style="padding:40px 20px;text-align:center">
      <div style="font-size:64px;margin-bottom:16px;opacity:.4">&#127922;</div>
      <div style="font-family:'Cinzel',serif;font-size:15px;color:var(--god);letter-spacing:2px;margin-bottom:10px">SIN MISION ACTIVA</div>
      <div style="font-size:14px;color:var(--stl);font-style:italic;line-height:1.8">Inicia una nueva escaramuza para<br>generar las tablas D20 de la mision.</div>
    </div>
  </div>
</div>
<div class="view" id="view-notes">
  <div class="nv">
    <p class="stit">DIARIO DE CAMPANA</p>
    <textarea class="nfld" id="cnotes" placeholder="Anota eventos, pistas, mapas..." rows="5"></textarea>
    <p class="stit" style="margin-top:13px">TESORO DEL GRUPO</p>
    <div id="tlist"></div>
    <p class="stit" style="margin-top:13px">INVENTARIO DEL GRUPO</p>
    <div id="ginv"></div>
    <button class="bsec" style="margin-top:7px" onclick="openM('m-ginv')">+ Anadir objeto al grupo</button>
  </div>
</div>
<button id="fab" onclick="openHeroModal()" style="
  position:fixed;bottom:calc(26px + env(safe-area-inset-bottom));right:20px;
  width:66px;height:66px;z-index:200;
  background:linear-gradient(145deg,#b02020,#6a1010);
  border:3px solid #d04040;border-radius:50%;
  color:#f2e8d0;font-size:36px;font-weight:900;line-height:1;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;touch-action:manipulation;
  box-shadow:0 6px 28px rgba(139,26,26,.8),0 0 0 5px rgba(139,26,26,.18),inset 0 1px 0 rgba(255,150,150,.2);
  transition:transform .15s,box-shadow .15s;
">+</button>
<!-- new hero modal -->
<div id="m-nh" style="display:none;position:fixed;inset:0;z-index:2500;background:rgba(0,0,0,.88);align-items:flex-end;justify-content:center" onclick="if(event.target===this)closeHeroModal()">
  <div style="background:linear-gradient(180deg,#1e1810,#140f08);border:1px solid #7a5a18;border-top:2px solid #c9962a;border-radius:10px 10px 0 0;width:100%;max-width:430px;padding:20px 18px 32px;max-height:90vh;overflow-y:auto;will-change:transform;transform:translateZ(0)">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;padding-bottom:12px;border-bottom:1px solid rgba(201,150,42,.2)">
      <span style="font-family:'Cinzel',serif;font-size:16px;color:#c9962a;letter-spacing:1px">&#9876;&#65039; Nuevo Heroe</span>
      <button onclick="closeHeroModal()" style="background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);border-radius:50%;width:30px;height:30px;color:#5a504a;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center">&#10005;</button>
    </div>

    <!-- Step 1: Class selection -->
    <div id="nh-step1">
      <div style="font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;color:#7a5a18;margin-bottom:8px">ELIGE TU CLASE</div>
      <div id="class-grid" style="max-height:52vh;overflow-y:auto;margin-bottom:14px"></div>
      <button onclick="nhNextStep()" style="width:100%;background:linear-gradient(135deg,#2a1e0a,#1a1208);border:2px solid #c9962a;border-radius:5px;color:#c9962a;font-family:'Cinzel',serif;font-size:12px;font-weight:700;letter-spacing:2px;padding:13px;cursor:pointer">
        SIGUIENTE &#8250;
      </button>
    </div>

    <!-- Step 2: Name entry (shown after class chosen) -->
    <div id="nh-step2" style="display:none">
      <!-- Selected class preview -->
      <div id="nh-class-preview" style="display:flex;align-items:center;gap:12px;padding:12px 14px;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.25);border-radius:6px;margin-bottom:16px">
        <span id="nh-prev-ico" style="font-size:36px"></span>
        <div>
          <div id="nh-prev-name" style="font-family:'Cinzel',serif;font-size:15px;color:#c9962a;font-weight:700"></div>
          <div id="nh-prev-stats" style="font-size:12px;color:#5a504a;margin-top:2px"></div>
          <div id="nh-prev-skills" style="font-size:11px;color:#4a80d4;margin-top:3px"></div>
        </div>
        <button onclick="nhBackStep()" style="margin-left:auto;background:none;border:1px solid rgba(201,150,42,.3);border-radius:3px;color:#7a5a18;font-family:'Cinzel',serif;font-size:9px;letter-spacing:1px;padding:4px 8px;cursor:pointer">&#8249; CAMBIAR</button>
      </div>

      <div style="font-family:'Cinzel',serif;font-size:9px;letter-spacing:2px;color:#7a5a18;margin-bottom:6px">NOMBRE DEL HEROE</div>
      <input id="hinp" type="text" placeholder="Como se llama tu heroe..." maxlength="22" autocomplete="off"
        style="width:100%;background:rgba(0,0,0,.5);border:1px solid rgba(201,150,42,.3);border-bottom:2px solid #7a5a18;border-radius:4px;color:#f2e8d0;font-size:17px;padding:11px 13px;margin-bottom:16px;outline:none;font-family:'Crimson Pro',serif"
        onkeydown="if(event.key==='Enter')createH()">

      <button onclick="createH()" style="width:100%;background:linear-gradient(135deg,#8b1a1a,#5c0f0f);border:1px solid #a03030;border-radius:5px;color:#f2e8d0;font-family:'Cinzel',serif;font-size:13px;font-weight:700;letter-spacing:2px;padding:14px;cursor:pointer;box-shadow:0 2px 12px rgba(139,26,26,.4)">
        &#9876;&#65039; UNIRSE A LA AVENTURA &#9876;&#65039;
      </button>
    </div>

  </div>
</div>

<!-- equip picker -->

