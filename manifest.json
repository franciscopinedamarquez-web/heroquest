    {nm:'Ampliar HP',       ico:'&#10084;',         desc:'+1 HP maximo permanente a 1 heroe.',            price:100,stat:'maxHp',val:1},
    {nm:'Ampliar Mana',     ico:'&#10024;',          desc:'+1 MP maximo permanente a 1 heroe.',            price:120,stat:'maxMp',val:1},
    {nm:'Estandarte Heroico',ico:'&#127937;',        desc:'+1 nivel al heroe seleccionado.',               price:200,stat:'level',val:1},
