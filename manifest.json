const ORACLE_CATS = [...new Set(ORACLE_QUESTIONS.map(q=>q.cat))];

let currentAdventure = null;
let oracleLog = [];
let usedQuestions = new Set();

function startSk(){
  const lore = rnd(LORE_POOL);
  const extraIntro = rnd(LORE_INTROS_EXTRA);
  currentAdventure = {lore, extraIntro, started:Date.now(), phase:'explore'};
  oracleLog=[];usedQuestions=new Set();
  if(!sk)sk={};
  sk.adventure=currentAdventure;sk.oracleLog=oracleLog;
  saveS();renderSk();
}

let _openCat = null;

function renderSk(){
  const c=document.getElementById('skcon');
  if(!currentAdventure){
    c.innerHTML=`
      <div style="padding:40px 20px;text-align:center">
        <div style="font-size:68px;margin-bottom:20px;opacity:.4">&#128302;</div>
        <div style="font-family:'Cinzel',serif;font-size:17px;color:var(--god);letter-spacing:2px;margin-bottom:12px">EL ORACULO ESPERA</div>
        <div style="font-size:15px;color:var(--stl);font-style:italic;line-height:1.9;margin-bottom:32px">
          Cada pregunta genera una respuesta<br>con contexto narrativo y efectos.<br>Usalo durante tu turno de HeroQuest.
        </div>
      </div>
      <button class="new-adv-btn" onclick="startSk()">&#128302; NUEVA AVENTURA &#9876;&#65039;</button>`;
    return;
  }
  const adv=currentAdventure, lore=adv.lore;
  const tagsHtml=(lore.tags||[]).map((t,i)=>{
    const col=lore.tagcols?lore.tagcols[i]:'var(--pad)';
    const cond=CONDITIONS[t];
    const ico=cond?cond.ico:'&#127919;';
    return`<button class="lore-tag" onclick="showCondition('${t}')"
      style="color:${col};border-color:${col}66;background:rgba(0,0,0,.5)">
      ${ico} ${t}
    </button>`;
  }).join('');

  const catDef=[
    {id:'Exploracion',lbl:'EXPLORAR',ico:'&#128270;',col:'var(--go)'},
    {id:'Combate',    lbl:'COMBATE', ico:'&#9876;&#65039;',col:'var(--bl)'},
    {id:'Tesoro',     lbl:'TESORO',  ico:'&#128176;',col:'var(--gol)'},
    {id:'Magia',      lbl:'MAGIA',   ico:'&#10024;', col:'var(--mg)'},
    {id:'Narrativa',  lbl:'NARRATIVA',ico:'&#128172;',col:'var(--pul)'},
  ];

  const questionsHtml=catDef.map(({id:cat,lbl,ico,col})=>{
    const qs=ORACLE_QUESTIONS.filter(q=>q.cat===cat);
    if(!qs.length) return '';
    const qBtns=qs.map((q,qi)=>{
      const qKey=cat+'_'+qi, isUsed=usedQuestions.has(qKey);
      return`<button onclick="askOracle(${ORACLE_QUESTIONS.indexOf(q)},'${qKey}')"
        style="width:100%;background:${isUsed?'rgba(0,0,0,.25)':'rgba(0,0,0,.4)'};
          border:1px solid rgba(201,150,42,.2);border-radius:4px;
          padding:12px 14px;display:flex;align-items:center;gap:12px;
          cursor:pointer;touch-action:manipulation;opacity:${isUsed?.7:1};
          text-align:left;transition:all .15s">
        <span style="font-size:22px;flex-shrink:0">${q.ico}</span>
        <div style="flex:1">
          <div style="font-family:'Cinzel',serif;font-size:14px;color:${isUsed?'var(--stl)':'var(--pa)'};letter-spacing:.3px">${q.lbl}</div>
          <div style="font-size:12px;color:var(--stl);font-style:italic;margin-top:2px">${q.hint}</div>
        </div>
        <span style="color:var(--god);font-size:20px">&#8250;</span>
      </button>`;
    }).join('');

    return`<div style="margin:0 14px">
      <button onclick="toggleCat('${cat}')"
        style="width:100%;background:rgba(0,0,0,.35);
          border:1px solid rgba(201,150,42,.25);border-radius:6px;
          padding:14px 16px;display:flex;align-items:center;gap:12px;
          cursor:pointer;touch-action:manipulation;margin-bottom:6px">
        <span style="font-size:24px">${ico}</span>
        <span style="font-family:'Cinzel',serif;font-size:15px;color:${col};letter-spacing:1px;flex:1;text-align:left">${lbl}</span>
        <span id="ocat-arrow-${cat}" style="color:var(--god);font-size:22px;transition:transform .2s">&#8250;</span>
      </button>
      <div id="ocat-body-${cat}" style="display:none;flex-direction:column;gap:7px;padding-bottom:8px">
        ${qBtns}
      </div>
    </div>`;
  }).join('<div style="height:6px"></div>');

  const logHtml=oracleLog.length?`
    <div class="sk-log" style="margin:16px 14px 0">
      <div class="sk-log-title">&#128220; REGISTRO DE SESION</div>
      ${oracleLog.slice(0,8).map(l=>`<div class="sk-log-item">${l}</div>`).join('')}
    </div>`:'';

  c.innerHTML=`
    <div class="lore-card">
      <div class="lore-header">
        <div style="flex:1">
          <div class="lore-title">${lore.tl}</div>
          <div class="lore-obj" style="font-size:13px">&#127919; ${lore.ob}</div>
        </div>
        <span class="lore-badge" style="color:${lore.bcol||'var(--go)'};border-color:${lore.bcol||'var(--god)'}66;background:${lore.bcol||'#2a1a08'}22;font-size:11px">${lore.badge}</span>
      </div>
      <div class="lore-body">
        <div style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:2px;color:var(--god);margin-bottom:8px">&#128304; LORE</div>
        ${lore.in}
        <div style="margin-top:10px;padding-top:10px;border-top:1px solid rgba(201,150,42,.1);font-size:13px;color:var(--stl);font-style:italic">&#128293; ${adv.extraIntro}</div>
      </div>
      <div class="lore-footer">${tagsHtml}</div>
    </div>

    <div style="font-family:'Cinzel',serif;font-size:11px;letter-spacing:3px;color:var(--god);text-align:center;padding:16px 0 10px">&#9876; CONSULTAR EL ORACULO &#9876;</div>

    <div style="display:flex;flex-direction:column;gap:8px">${questionsHtml}</div>

    ${logHtml}

    <div style="padding:20px 14px 0">
      <button onclick="if(confirm('Iniciar nueva aventura?')){currentAdventure=null;sk=null;usedQuestions=new Set();oracleLog=[];saveS();renderSk();}"
        style="width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.3);border-radius:5px;
          color:var(--god);font-family:'Cinzel',serif;font-size:13px;letter-spacing:2px;padding:14px;cursor:pointer">
        &#9876;&#65039; NUEVA AVENTURA
      </button>
    </div>`;
}


function showCondition(tagName){
  const cond = CONDITIONS[tagName];
  if(!cond) return;
  const old = document.getElementById('cond-overlay');
  if(old) old.remove();

  const rulesHtml = (cond.rules||[]).map(r=>
    '<div class="cond-rule">'
    + '<span class="cond-rule-ico">'+r.ico+'</span>'
    + '<span class="cond-rule-txt">'+r.txt+'</span>'
    + '</div>'
  ).join('');

  const typeColor = cond.type==='BONIFICACION' ? 'var(--gr)' : 'var(--bl)';
  const typeBg    = cond.type==='BONIFICACION' ? 'rgba(42,90,42,.3)' : 'rgba(139,26,26,.3)';

  const el = document.createElement('div');
  el.id = 'cond-overlay';
  el.className = 'cond-overlay';
  el.innerHTML =
    '<div class="cond-popup">'
      + '<div class="cond-header" style="border-bottom:2px solid '+cond.col+'">'
        + '<div style="display:flex;align-items:center;gap:10px">'
          + '<span style="font-size:34px">'+cond.ico+'</span>'
          + '<div>'
            + '<div class="cond-name" style="color:'+cond.col+'">'+tagName+'</div>'
            + '<div class="cond-type" style="color:'+typeColor+';background:'+typeBg+';padding:2px 8px;border-radius:3px;display:inline-block;margin-top:2px">'+cond.type+'</div>'
          + '</div>'
        + '</div>'
      + '</div>'
      + '<div class="cond-body">'
        + '<div class="cond-effect">'+cond.effect+'</div>'
        + '<div class="cond-rules">'+rulesHtml+'</div>'
        + '<button class="cond-close" onclick="document.getElementById(\'cond-overlay\').remove()">&#10003; Entendido</button>'
      + '</div>'
    + '</div>';

  el.addEventListener('click', function(e){ if(e.target===el) el.remove(); });
  document.documentElement.appendChild(el);
}


function toggleCat(cat){
  const body  = document.getElementById('ocat-body-'+cat);
  const arrow = document.getElementById('ocat-arrow-'+cat);
  if(!body) return;
  const isOpen = body.style.display === 'flex';

  // Close all
  document.querySelectorAll('[id^="ocat-body-"]').forEach(el => el.style.display = 'none');
  document.querySelectorAll('[id^="ocat-arrow-"]').forEach(el => el.style.transform = '');

  if(!isOpen){
    // Open this one
    body.style.cssText = 'display:flex;flex-direction:column;gap:7px;padding-bottom:8px';
    if(arrow) arrow.style.transform = 'rotate(90deg)';
    _openCat = cat;
    setTimeout(() => body.scrollIntoView({behavior:'smooth', block:'nearest'}), 80);
  } else {
    _openCat = null;
  }
}



function askOracle(qIdx,qKey){
  const q=ORACLE_QUESTIONS[qIdx]; if(!q) return;
  const roll=ri(1,6);
  let result=q.rolls[q.rolls.length-1];
  for(const r of q.rolls){ if(roll>=r.range[0]&&roll<=r.range[1]){result=r;break;} }
  usedQuestions.add(qKey);

  const col = roll<=2?'var(--bl)': roll<=4?'var(--pad)': roll===5?'var(--go)': 'var(--gol)';
  const lbls= ['','ADVERSO','ADVERSO','NEUTRO','NEUTRO','FAVORABLE','&#11088; CRITICO'];
  const rollLabel = lbls[roll]||'';

  const fxHtml = result.fx ? `
    <div style="display:flex;align-items:center;gap:12px;margin-top:14px;padding:12px 14px;
      background:rgba(0,0,0,.4);border-radius:5px;border:1px solid rgba(201,150,42,.2)">
      <span style="font-size:26px">${result.fx.ico}</span>
      <span style="font-family:'Cinzel',serif;font-size:13px;color:var(--pa);letter-spacing:.5px;line-height:1.4">${result.fx.txt}</span>
    </div>` : '';

  // Remove old popup
  const old=document.getElementById('oracle-popup'); if(old) old.remove();

  const popup=document.createElement('div');
  popup.id='oracle-popup';
  popup.style.cssText='position:fixed;inset:0;z-index:900;background:rgba(0,0,0,.88);display:flex;align-items:center;justify-content:center;padding:20px;animation:fIn .2s ease';
  popup.innerHTML=`
    <div style="background:linear-gradient(160deg,#1e1810,#100c06);
      border:2px solid ${col};border-radius:10px;
      width:100%;max-width:400px;overflow:hidden;
      box-shadow:0 0 50px rgba(0,0,0,.95),0 0 24px ${col}44;
      animation:popIn .28s cubic-bezier(.34,1.4,.64,1)">

      <!-- Header -->
      <div style="background:rgba(0,0,0,.5);padding:13px 16px;
        display:flex;align-items:center;justify-content:space-between;
        border-bottom:1px solid ${col}44">
        <div style="display:flex;align-items:center;gap:10px">
          <span style="font-size:22px">${q.ico}</span>
          <span style="font-family:'Cinzel',serif;font-size:12px;color:var(--god);letter-spacing:1px">${q.lbl}</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <span style="font-family:'Cinzel',serif;font-size:15px;color:${col};font-weight:700">&#127922; ${roll}</span>
          <button onclick="document.getElementById('oracle-popup').remove()"
            style="background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;
            width:30px;height:30px;color:var(--stl);font-size:16px;cursor:pointer;
            display:flex;align-items:center;justify-content:center;touch-action:manipulation">&#10005;</button>
        </div>
      </div>

      <!-- Roll level badge -->
      <div style="text-align:center;padding:16px 16px 8px">
        <div style="font-family:'Cinzel',serif;font-size:12px;letter-spacing:4px;color:${col};margin-bottom:10px">${rollLabel}</div>
        <div style="font-family:'Cinzel',serif;font-size:22px;font-weight:700;
          color:${col};text-shadow:0 0 24px ${col}66;line-height:1.25;margin-bottom:10px">
          ${result.res}
        </div>
      </div>

      <!-- Narrative detail -->
      <div style="padding:0 18px 14px">
        <div style="font-size:15px;color:var(--pad);line-height:1.75;font-style:italic;
          border-top:1px solid rgba(255,255,255,.07);padding-top:14px">
          ${result.det}
        </div>
        ${fxHtml}
      </div>

      <!-- Buttons -->
      <div style="padding:12px 16px 16px;display:grid;grid-template-columns:1fr 1fr;gap:10px;
        border-top:1px solid rgba(255,255,255,.07)">
        <button onclick="askOracle(${qIdx},'${qKey}')"
          style="background:rgba(0,0,0,.5);border:1px solid rgba(201,150,42,.35);border-radius:5px;
          color:var(--god);font-family:'Cinzel',serif;font-size:12px;letter-spacing:1px;
          padding:12px;cursor:pointer;touch-action:manipulation">
          &#127922; Tirar de nuevo
        </button>
        <button onclick="document.getElementById('oracle-popup').remove()"
          style="background:linear-gradient(135deg,var(--grd),#1a3010);border:1px solid var(--grd);
          border-radius:5px;color:var(--gr);font-family:'Cinzel',serif;font-size:12px;
          letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">
          &#10003; Anotado
        </button>
      </div>
    </div>`;

  popup.addEventListener('click', e=>{ if(e.target===popup) popup.remove(); });
  document.documentElement.appendChild(popup);

  // Log
  oracleLog.unshift(`${q.ico} <strong style="color:${col}">${result.res}</strong> — ${q.lbl} (&#127922;${roll})`);
  if(oracleLog.length>20) oracleLog.pop();
  if(sk) sk.oracleLog=oracleLog;
  saveS();

  // Re-render questions (marks used), restore open category, then re-attach popup
  renderSk();
  if(_openCat){ setTimeout(()=>{ const b=document.getElementById('ocat-body-'+_openCat); if(b){b.style.cssText='display:flex;flex-direction:column;gap:7px;padding-bottom:8px'; const a=document.getElementById('ocat-arrow-'+_openCat); if(a)a.style.transform='rotate(90deg)';} }, 10); }
  document.body.appendChild(popup);
}


