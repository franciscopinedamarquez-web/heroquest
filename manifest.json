  <div class="ss-version">v5.0 &bull; PWA &bull; 2026</div>
</div>
<script>
const HT={
// ── HEROQUEST ORIGINAL ──────────────────────────────────────────────────────
barbaro:{ico:'&#129427;',col:'#8b1a1a',cls:'Barbaro',cat:'Original',
  hp:8,maxHp:8,mp:2,maxMp:2,atk:3,def:2,mov:3,
  eq:[{sl:'Arma',ico:'&#129427;',nm:'Hacha de Batalla',r:'uncommon',a:1,d:0},{sl:'Armadura',ico:'&#128737;&#65039;',nm:'Armadura de Cuero',r:'common',a:0,d:1},{sl:'Accesorio',ico:'&#128141;',nm:'--',r:'common',a:0,d:0}],
  sp:[],inv:[],
  sk:[
