function closeHeroModal(){
  const m = document.getElementById('m-nh');
  if(m) m.style.display='none';
}

function selT(btn){
  document.querySelectorAll('#class-grid button').forEach(b=>{
    b.style.borderColor='rgba(201,150,42,.2)';
    b.style.background='linear-gradient(160deg,#1e1810,#2a2010)';
    b.style.color='#ddd0a8';
  });
  btn.style.borderColor='#c9962a';
  btn.style.background='linear-gradient(160deg,#2a1e0a,#3a2a10)';
  btn.style.color='#c9962a';
  sT = btn.dataset.type;
}

function renderClassGrid(){
  const grid = document.getElementById('class-grid');
  if(!grid) return;
  const cats = {};
  Object.entries(HT).forEach(([key,cls])=>{
    const cat = cls.cat||'Original';
    if(!cats[cat]) cats[cat]=[];
    cats[cat].push({key,cls});
  });
  let out='';
  Object.entries(cats).forEach(([cat,list])=>{
    out+=`<div style="font-family:'Cinzel',serif;font-size:8px;letter-spacing:3px;color:#7a5a18;text-transform:uppercase;padding:10px 2px 6px;border-bottom:1px solid rgba(201,150,42,.15);margin-bottom:6px">${cat}</div>`;
    out+=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:4px">`;
    list.forEach(({key,cls})=>{
      const isSel = key===sT;
      out+=`<button data-type="${key}" onclick="selT(this)"
        style="display:flex;flex-direction:column;align-items:center;gap:4px;padding:12px 6px;
               background:${isSel?'linear-gradient(160deg,#2a1e0a,#3a2a10)':'linear-gradient(160deg,#1e1810,#2a2010)'};
               border:1px solid ${isSel?'#c9962a':'rgba(201,150,42,.2)'};
               border-radius:6px;cursor:pointer;touch-action:manipulation;
               color:${isSel?'#c9962a':'#ddd0a8'};transition:all .15s">
        <span style="font-size:28px;line-height:1">${cls.ico}</span>
        <span style="font-family:'Cinzel',serif;font-size:10px;font-weight:600;letter-spacing:.5px">${cls.cls}</span>
        <span style="font-size:8px;color:#5a504a;line-height:1.4">HP${cls.hp} &bull; MP${cls.mp} &bull; ATK${cls.atk} &bull; DEF${cls.def}</span>
      </button>`;
    });
    if(list.length%2!==0) out+=`<div></div>`;
    out+=`</div>`;
  });
  grid.innerHTML=out;
}


