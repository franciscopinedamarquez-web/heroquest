function loadS(){try{const r=localStorage.getItem(LSK);if(r)return JSON.parse(r)}catch(e){}return null}
function dpUpdatePhoto(id,input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    const h=heroes.find(x=>x.id===id);
    if(!h)return;
    h.photo=e.target.result;
    // Update visible avatar in detail panel
    const dav=document.querySelector('.dpanel .dav');
    if(dav){
      let img=dav.querySelector('img');
      if(!img){img=document.createElement('img');img.style.cssText='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%';dav.appendChild(img);}
      img.src=h.photo;
      const ico=dav.querySelector('span');if(ico)ico.style.display='none';
    }
    rH();saveS();toast('&#128247; Foto actualizada');
  };
  reader.readAsDataURL(file);
}

