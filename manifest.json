function triggerRoomEvent(roomIdx){
  if(!dg) return;
  const ev = DUNGEON_ROOM_EVENTS[roomIdx % DUNGEON_ROOM_EVENTS.length];
  activeRoomEvent = {ev, roomIdx};
  // Show as popup
  const old = document.getElementById('room-event-popup');
  if(old) old.remove();
  const popup = document.createElement('div');
  popup.id = 'room-event-popup';
  popup.style.cssText = 'position:fixed;inset:0;z-index:3000;background:rgba(0,0,0,.88);display:flex;align-items:center;justify-content:center;padding:20px;animation:fIn .2s ease';
  popup.innerHTML = '<div style="background:linear-gradient(160deg,#1e1810,#100c06);border:2px solid var(--mg);border-radius:10px;width:100%;max-width:400px;overflow:hidden;box-shadow:0 0 40px rgba(74,128,212,.3)">'
    +'<div style="background:rgba(0,0,0,.5);padding:13px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(74,128,212,.3)">'
    +'<div style="display:flex;align-items:center;gap:10px"><span style="font-size:24px">'+ev.ico+'</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--mg)">'+ev.title+'</span></div>'
    +'<button onclick="document.getElementById(\'room-event-popup\').remove()" style="background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:28px;height:28px;color:var(--stl);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center">&#10005;</button>'
    +'</div>'
    +'<div style="padding:16px 18px">'
    +'<div style="font-size:14px;color:var(--pad);font-style:italic;line-height:1.7;margin-bottom:14px">'+ev.desc+'</div>'
    +'<div style="display:flex;flex-direction:column;gap:8px">'
    +ev.choices.map(ch=>'<button onclick="resolveRoomEvent(\''+ch.res+'\')" style="width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.25);border-radius:4px;padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;touch-action:manipulation;text-align:left">'
      +'<span style="font-size:20px">'+ch.ico+'</span>'
      +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa)">'+ch.txt+'</span>'
      +'<span style="color:var(--god);font-size:18px;margin-left:auto">&#8250;</span></button>'
    ).join('')
    +'</div>'
    +'<div id="room-event-result" style="margin-top:10px"></div>'
    +'</div></div>';
  popup.addEventListener('click',e=>{if(e.target===popup)popup.remove();});
  document.documentElement.appendChild(popup);
}

function resolveRoomEvent(resKey){
  const outcome = DUNGEON_EVENT_OUTCOMES[resKey];
  if(!outcome) return;

  let roll=null, effectText=outcome.effect, goldChange=0;
  if(outcome.roll){
    roll=Math.floor(Math.random()*6)+1;
    const good=roll>=(outcome.rollGood?.min||4);
    effectText=good?outcome.rollGood?.effect:outcome.rollBad?.effect;
    if(good&&outcome.rollGood?.gold) goldChange=outcome.rollGood.gold;
    if(!good&&outcome.rollBad?.damage&&heroes.length>0){
      const dmg=Math.floor(Math.random()*4)+1;
      heroes.forEach(h=>{h.hp=Math.max(0,h.hp-dmg);});
      rH();saveS();
    }
  }
  if(goldChange>0&&heroes.length>0){
    const share=Math.floor(goldChange/heroes.length);
    heroes.forEach(h=>{h.gold=(h.gold||0)+share;});
    rH();saveS();
  }

  const typeCol=outcome.type==='good'?'var(--gr)':outcome.type==='bad'?'var(--bl)':'var(--go)';
  const el=document.getElementById('room-event-result');
  if(el){
    el.innerHTML='<div class="event-result">'
      +'<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">'
      +(roll?'<span style="font-family:Cinzel,serif;font-size:14px;color:var(--go)">&#127922; '+roll+'</span>':'')
      +'<span style="font-size:13px;color:'+typeCol+'">'+outcome.txt+'</span></div>'
      +(effectText?'<div style="font-size:12px;color:var(--pad);font-style:italic;padding:8px;background:rgba(0,0,0,.3);border-radius:3px">'+effectText+'</div>':'')
      +'</div>';
    document.querySelectorAll('#room-event-popup button:not(#room-event-popup button[onclick*="remove"])').forEach(b=>{if(!b.id)b.remove();});
  }
}


