        +'<span style="font-size:10px;color:var(--stl)">&#10084; '+(h.hp||0)+'/'+(h.maxHp||0)+' &nbsp; &#10024; '+(h.mp||0)+'/'+(h.maxMp||0)+'</span>'
        +statPreview(h)
        +'</div>'
        +'</div>'
        +'<span style="color:var(--go);font-size:22px">&#8250;</span>'
        +'</button>';
    }).join('')
    +'</div></div>';

  el.addEventListener('click',e=>{if(e.target===el)el.remove();});
  document.documentElement.appendChild(el);
}

function confirmHeroPickerBuy(shopId, itemIdx, heroId){
  const shopMap={armeria:ARMERIA_ITEMS,taberna:TABERNA_ITEMS,templo:TEMPLO_ITEMS,gremio:GREMIO_ITEMS,biblioteca:BIBLIOTECA_ITEMS};
  const item=shopMap[shopId]?.[itemIdx];
  const h=heroes.find(x=>x.id===heroId);
  if(!item||!h) return;

  const totalGold=heroes.reduce((s,hh)=>s+(hh.gold||0),0);
  if(totalGold<item.price){ toast('Sin oros suficientes'); return; }

  _deductGold(item.price);
  _applyItemEffect(item, h);

  const popup=document.getElementById('hero-picker-popup');
  if(popup) popup.remove();

  rH(); saveS(); renderCiudad();
}


function applyUpgrade(shopId, upgradeIdx){
  const upgrades = [
    {nm:'Afilar Armas',stat:'atk',val:1,price:80},
    {nm:'Reforzar Armadura',stat:'def',val:1,price:80},
    {nm:'Ampliar HP',stat:'maxHp',val:1,price:100},
    {nm:'Ampliar Mana',stat:'maxMp',val:1,price:120},
    {nm:'Estandarte Heroico',stat:'level',val:1,price:200},
  ];
  const upg = upgrades[upgradeIdx];
  if(!upg) return;

  const sel = document.getElementById('herrero-hero-select');
  const heroId = sel ? parseInt(sel.value) : (heroes[0]?.id);
  const h = heroes.find(x=>x.id===heroId);
  if(!h){ toast('Selecciona un heroe'); return; }

  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
  if(totalGold < upg.price){ toast('Sin oros suficientes'); return; }

  // Deduct
  let remaining = upg.price;
  for(const hh of heroes){
    const pay = Math.min(remaining, hh.gold||0);
    hh.gold = (hh.gold||0) - pay;
    remaining -= pay;
    if(remaining<=0) break;
  }

  // Apply
  if(upg.stat==='atk')   h.atk=(h.atk||1)+upg.val;
  else if(upg.stat==='def') h.def=(h.def||1)+upg.val;
  else if(upg.stat==='maxHp'){h.maxHp=(h.maxHp||4)+upg.val;h.hp=Math.min(h.hp+upg.val,h.maxHp);}
  else if(upg.stat==='maxMp'){h.maxMp=(h.maxMp||2)+upg.val;h.mp=Math.min(h.mp+upg.val,h.maxMp);}
  else if(upg.stat==='level'){
    h.level=(h.level||1)+upg.val;
    const skills2=pickTwoSkills(h);
    if(skills2.length>=2){ setTimeout(()=>showSkillChoicePopup(h,skills2,null),400); }
  }

  toast('&#9874;&#65039; '+h.name+': '+upg.nm+' completado!');
  rH(); saveS(); renderCiudad();
}

