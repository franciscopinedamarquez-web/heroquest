}


function initSessionScreen(){
  const raw=localStorage.getItem(LSK);
  let saveData=null;
  if(raw){try{saveData=JSON.parse(raw);}catch(e){}}
  const slotEl=document.getElementById('ss-save-slot');
  const btnsEl=document.getElementById('ss-buttons');
  const hasSave=saveData&&(saveData.heroes?.length>0||saveData.cn||saveData.gi?.length);
  if(hasSave){
    const heroChips=(saveData.heroes||[]).map(h=>{
      const av=h.photo?`<img src="${h.photo}" style="width:100%;height:100%;object-fit:cover;border-radius:50%">`:`<span style="font-size:14px">${h.ico||'&#129497;'}</span>`;
      return`<div class="ss-hero-chip"><div class="ss-hero-avatar">${av}</div><span class="ss-hero-name">${h.name||'?'}</span></div>`;
    }).join('');
    const heroCount=saveData.heroes?.length||0;
    const advName=saveData.sk?.adventure?.lore?.tl||null;
    const gold=saveData.gt?.gold||0;
    slotEl.innerHTML=`<div class="ss-save-preview">
      <div class="ss-save-label">&#128190; Partida guardada</div>
      ${heroCount?`<div class="ss-save-heroes">${heroChips}</div>`:''}
      <div class="ss-save-meta">${heroCount} heroe${heroCount!==1?'s':''} &bull; ${gold} oros${advName?` &bull; ${advName}`:''}</div>
    </div>`;
    btnsEl.innerHTML=`
      <button class="ss-btn ss-btn-continue" onclick="continueSession()">&#128190; CONTINUAR PARTIDA</button>
      <button class="ss-btn ss-btn-new" onclick="confirmNewSession()">&#9876;&#65039; NUEVA SESION</button>
      <button class="ss-btn ss-btn-delete" onclick="confirmDeleteSave()">&#128465;&#65039; Borrar datos guardados</button>`;
  } else {
    slotEl.innerHTML=`<div class="ss-save-preview"><div class="ss-no-save">&#128302; No hay partida guardada.<br>Crea tus heroes y comienza la aventura.</div></div>`;
    btnsEl.innerHTML=`<button class="ss-btn ss-btn-new" onclick="continueSession()">&#9876;&#65039; NUEVA PARTIDA</button>`;
  }
}
function continueSession(){
  const raw=localStorage.getItem(LSK);
  if(raw){try{const d=JSON.parse(raw);heroes=d.heroes??[];gt=d.gt??{gold:0,potions:0,scrolls:0,keys:0};gi=d.gi??[];cn=d.cn??'';dh=d.dh??[];sk=d.sk??null;if(sk?.adventure){currentAdventure=sk.adventure;} if(sk?.oracleLog)oracleLog=sk.oracleLog; if(sk?.dg){dg=sk.dg;skDifficulty=dg.difficulty||'medio';restoreZoneStates();} if(d.esquirlas!==undefined)esquirlas=d.esquirlas; if(d.esquirlasPozo!==undefined)esquirlasPozo=d.esquirlasPozo; if(d.guaridaMejoras)guaridaMejoras=d.guaridaMejoras; if(d.esquirlasLog)esquirlasLog=d.esquirlasLog; if(d.guaridaRestLog)guaridaRestLog=d.guaridaRestLog;}catch(e){}}
  dismissSessionScreen();
}
function confirmNewSession(){
  document.getElementById('ss-buttons').innerHTML=`
    <div style="background:rgba(139,26,26,.15);border:1px solid var(--bld);border-radius:5px;padding:14px;margin-bottom:14px;text-align:center">
      <div style="font-family:'Cinzel',serif;font-size:13px;color:var(--bl);margin-bottom:6px">&#9888;&#65039; NUEVA SESION</div>
      <div style="font-size:12px;color:var(--pad);line-height:1.6">Se creara una nueva partida.<br>Los datos actuales quedan guardados.</div>
    </div>
    <button class="ss-btn ss-btn-new" onclick="startNewSession()">&#9876;&#65039; CONFIRMAR</button>
    <button class="ss-btn ss-btn-delete" onclick="initSessionScreen()">&#8249; Cancelar</button>`;
}
function startNewSession(){
  heroes=[];gt={gold:0,potions:0,scrolls:0,keys:0};gi=[];cn='';dh=[];sk=null;
  currentAdventure=null;oracleLog=[];usedQuestions=new Set();
  saveS();dismissSessionScreen();
}
function confirmDeleteSave(){
  document.getElementById('ss-buttons').innerHTML=`
    <div style="background:rgba(139,26,26,.2);border:1px solid var(--bl);border-radius:5px;padding:14px;margin-bottom:14px;text-align:center">
      <div style="font-family:'Cinzel',serif;font-size:14px;color:var(--bl);margin-bottom:6px">&#128128; BORRAR TODO</div>
      <div style="font-size:12px;color:var(--pad);line-height:1.6">Esta accion es irreversible.<br>Se perderan heroes, inventario y notas.</div>
    </div>
    <button class="ss-btn" style="background:linear-gradient(135deg,var(--bl),var(--bld));border:1px solid var(--bl);color:var(--pa)" onclick="deleteSaveAndStart()">&#128128; BORRAR Y EMPEZAR</button>
    <button class="ss-btn ss-btn-delete" onclick="initSessionScreen()">&#8249; Cancelar</button>`;
}
function deleteSaveAndStart(){
  localStorage.removeItem(LSK);
  heroes=[];gt={gold:0,potions:0,scrolls:0,keys:0};gi=[];cn='';dh=[];sk=null;
  currentAdventure=null;oracleLog=[];usedQuestions=new Set();
  dismissSessionScreen();
}
function dismissSessionScreen(){
  const el=document.getElementById('session-screen');
  if(!el)return;
  el.style.transition='opacity .4s ease,transform .4s ease';
  el.style.opacity='0';el.style.transform='scale(1.04)';
  setTimeout(()=>{el.remove();bootApp();},380);
}
function bootApp(){
  rH();renderDH();renderN();renderSk();
  if(!localStorage.getItem('hq_pwa_hint')){
    setTimeout(()=>{if(!window.matchMedia('(display-mode: standalone)').matches){toast('&#128247; Instala: Menu → Anadir a pantalla de inicio');localStorage.setItem('hq_pwa_hint','1');}},2000);
  }
}

// INIT
initSessionScreen();

</script>


