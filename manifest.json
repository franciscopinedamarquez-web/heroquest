function selectSkillChoice(heroId, skillIdx, isReplace){
  const popup = document.getElementById('levelup-popup');
  const skills = popup ? JSON.parse(popup.dataset.skills||'[]') : [];
  const chosen = skills[skillIdx];
  if(!chosen) return;

  const h = heroes.find(x=>x.id===heroId);
  if(!h) return;

  if(!h.sk) h.sk=[];

  if(h.sk.length >= 3){
    // Need to replace — show replace popup
    if(popup) popup.remove();
    showSkillChoicePopup(h, skills, chosen);
    return;
  }

  // Add the skill
  h.sk.push({...chosen});
  rH(); saveS();

  if(popup) popup.remove();
  toast('&#11088; '+h.name+' aprende: '+chosen.n);
}

function replaceSkillChoice(heroId, replaceIdx){
  // The new skill is stored in the popup's replace section
  // We need to find it — it's the skill shown in the "nueva habilidad" div
  // Best approach: store pending skill in the popup dataset
  const popup = document.getElementById('levelup-popup');
  const skills = popup ? JSON.parse(popup.dataset.skills||'[]') : [];

  // Find which skill was the chosen one — we stored it in data-chosen
  const chosenSkill = popup ? JSON.parse(popup.dataset.chosen||'null') : null;
  if(!chosenSkill) return;

  const h = heroes.find(x=>x.id===heroId);
  if(!h||!h.sk) return;

  const oldSkill = h.sk[replaceIdx];
  h.sk[replaceIdx] = {...chosenSkill};
  rH(); saveS();

  if(popup) popup.remove();
  toast('&#11088; '+h.name+': '+oldSkill.n+' sustituida por '+chosenSkill.n);
}

