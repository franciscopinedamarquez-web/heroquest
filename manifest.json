    costGold: 500,
    statBonus: {herreroDiscount: 20},
  },
  {
    id:'biblioteca_arcana',
    ico:'&#128218;', nm:'Biblioteca Arcana',
    desc:'Estantes llenos de tomos y pergaminos recuperados de mazmorras. El Mago puede estudiar entre misiones.',
    lore:'Los libros que sobrevivieron a las llamas de la Forja del Caos.',
