// Map class types to skill pools
function getSkillPool(classKey){
  const cls = HT[classKey]||{};
  const cat = (classKey||'').toLowerCase();
  if(['barbaro','enano','caballero','berserker','guardia','cazaogros'].some(k=>cat.includes(k))) return SKILL_POOLS.guerrero;
  if(['mago','hechicera','alquimista','elementalista','piromante'].some(k=>cat.includes(k))) return SKILL_POOLS.mago;
  if(['elfo','explorador','cazador','ladrón','ladron','bardo'].some(k=>cat.includes(k))) return SKILL_POOLS.explorador;
  if(['sacerdote','paladin','monje','chamana','nigromante'].some(k=>cat.includes(k))) return SKILL_POOLS.clerigo;
  return SKILL_POOLS.general;
}

function pickTwoSkills(hero){
  const pool = getSkillPool(hero.type||'');
  // Exclude already-known skills
  const known = (hero.sk||[]).map(s=>s.n);
  const available = pool.filter(s=>!known.includes(s.n));
  if(available.length < 2){
    // Fall back to general pool
    const fallback = SKILL_POOLS.general.filter(s=>!known.includes(s.n));
    available.push(...fallback);
  }
  if(available.length < 2) return available.slice(0,2);
  // Pick 2 random distinct
  const shuffled = available.sort(()=>Math.random()-.5);
  return [shuffled[0], shuffled[1]];
}

