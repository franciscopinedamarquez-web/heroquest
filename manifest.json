<!-- group inv create -->

<div class="toast" id="toast"></div>

<!-- SESSION SCREEN (shown on first load) -->
<div id="session-screen">
  <div class="ss-emblem">&#9876;&#65039;</div>
  <div class="ss-logo">HERO<span>QUEST</span></div>
  <div class="ss-sub">GESTOR DE HEROES</div>
  <div class="ss-divider"></div>

  <!-- Save preview filled by JS -->
  <div id="ss-save-slot" style="width:100%"></div>

  <!-- Buttons filled by JS -->
  <div id="ss-buttons" style="width:100%"></div>

  <div class="ss-version">v14.0 &bull; Crawlers &bull; 2026</div>
</div>
<script>
const HT={
// ── HEROQUEST ORIGINAL ──────────────────────────────────────────────────────
