    desc:'Una sala con camas, hierbas y instrumental médico. La curación en la guarida es más eficiente.',
    lore:'Equipada con material salvado de un templo derruido.',
    effect:'Al descansar en la guarida, los héroes recuperan +1 HP adicional por noche.',
    costGold: 350,
    statBonus: {healBonus: 1},
  },
  {
    id:'sala_entrenamiento',
    ico:'&#127947;&#65039;', nm:'Sala de Entrenamiento',
    desc:'Un espacio para practicar combate y tácticas. Los héroes mejoran más rápido.',
    lore:'Construida con madera del bosque que rodea la guarida.',
    effect:'+25 XP extra al completar cada mazmorra para héroes activos.',
    costGold: 450,
    statBonus: {xpBonus: 25},
  },
  {
    id:'almacen',
    ico:'&#128189;', nm:'Almacén Reforzado',
    desc:'Un almacén seguro para guardar el botín entre mazmorras. Protección contra robos y deterioro.',
    lore:'Las paredes tienen 60 cm de piedra sólida. Nadie entra sin permiso.',
    effect:'El inventario del grupo no tiene límite. Protección total del botín.',
    costGold: 300,
