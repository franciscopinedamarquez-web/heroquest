let ciudadOpenCard = null;
let ciudadEventUsed = new Set();
let activeRoomEvent = null;

// ── RENDER CIUDAD ─────────────────────────────────────────────────────────────
function renderCiudad(){
  const c = document.getElementById('ciudadcon');
  if(!c) return;

  // Total gold across heroes
  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
  const heroCount = heroes.length;

  // Gold bar
  const goldBar = '<div class="ciudad-gold-bar">'
    +'<span style="font-size:26px">&#128176;</span>'
    +'<div style="flex:1">'
    +'<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--god);margin-bottom:2px">ORO DEL GRUPO</div>'
    +'<div style="font-family:Cinzel,serif;font-size:22px;color:var(--go);font-weight:700">'+totalGold+' oros</div>'
    +(heroCount===0?'<div style="font-size:11px;color:var(--stl);font-style:italic">Crea heroes para usar la ciudad</div>':'')
    +'</div>'
    +'<div style="text-align:right">'
    +'<div style="font-family:Cinzel,serif;font-size:10px;color:var(--stl)">'+heroCount+' heroe'+(heroCount!==1?'s':'')+'</div>'
    +'<div style="font-size:11px;color:var(--stl);margin-top:2px">Entre escaramuzas</div>'
    +'</div>'
    +'</div>';

  // Random event (if any, show at top)
  let eventHtml = '';
  const unusedEvents = CIUDAD_EVENTS.filter(e=>!ciudadEventUsed.has(e.id));
  if(unusedEvents.length > 0 && Math.random() < 0.7){
    const ev = unusedEvents[Math.floor(Math.random()*unusedEvents.length)];
    eventHtml = renderCiudadEvent(ev);
  }

  // Shops
  const shops = [
    {id:'armeria',  ico:'&#9876;&#65039;', title:'Armeria',      sub:'Armas, armaduras y equipo de combate',      items:ARMERIA_ITEMS},
    {id:'taberna',  ico:'&#127867;',        title:'La Taberna del Dragon', sub:'Pociones, descanso y mejoras',     items:TABERNA_ITEMS},
    {id:'templo',   ico:'&#128267;',        title:'Templo de la Luz', sub:'Bendiciones, curaciones y purificacion', items:TEMPLO_ITEMS},
    {id:'gremio',   ico:'&#128272;',        title:'Gremio de Aventureros', sub:'Contratos, informacion y entrenamiento', items:GREMIO_ITEMS},
    {id:'biblioteca',ico:'&#128218;',       title:'Biblioteca Arcana', sub:'Pergaminos, tomos y conocimiento magico', items:BIBLIOTECA_ITEMS},
  ];

  const shopsHtml = shops.map(shop=>renderShop(shop, totalGold, heroCount)).join('');

  // Extra section: Herrero (upgrade existing gear)
  const herreroHtml = renderHerrero(totalGold, heroCount);

  c.innerHTML = '<div class="ciudad-view">'
    + '<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:3px;color:var(--god);text-align:center;padding:10px 0 14px">&#127968; CIUDAD — ENTRE ESCARAMUZAS</div>'
    + goldBar
    + eventHtml
    + shopsHtml
    + herreroHtml
    + '</div>';
}

function renderCiudadEvent(ev){
  return '<div class="event-card">'
    +'<div style="display:flex;align-items:center;gap:12px;margin-bottom:10px">'
    +'<span style="font-size:36px">'+ev.ico+'</span>'
    +'<div>'
    +'<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--mg);margin-bottom:3px">EVENTO ALEATORIO</div>'
    +'<div style="font-family:Cinzel,serif;font-size:15px;color:var(--pa);font-weight:700">'+ev.title+'</div>'
    +'</div>'
    +'</div>'
    +'<div style="font-size:13px;color:var(--pad);font-style:italic;line-height:1.7;margin-bottom:12px">'+ev.desc+'</div>'
    +'<div style="display:flex;flex-direction:column;gap:7px">'
    +ev.choices.map(ch=>'<button class="event-choice" onclick="resolveCiudadEvent(\''+ev.id+'\',\''+ch.fn+'\')">'
      +'<span style="font-size:22px">'+ch.ico+'</span>'
      +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa)">'+ch.txt+'</span>'
      +'<span style="color:var(--god);font-size:18px;margin-left:auto">&#8250;</span>'
      +'</button>'
    ).join('')
    +'</div>'
    +'<div id="ciudad-event-result"></div>'
    +'</div>';
}

function resolveCiudadEvent(evId, fn){
  const outcome = EVENT_OUTCOMES[fn];
  if(!outcome) return;
  ciudadEventUsed.add(evId);

  let roll = null;
  let resultText = outcome.txt;
  let effectText = outcome.effect;
  let goldChange = outcome.gold || 0;
  let appliedFn  = outcome.apply || null;

  // Handle roll-based outcomes
  if(outcome.roll){
    roll = Math.floor(Math.random()*6)+1;
    const good = roll >= (outcome.rollGood?.min || 4);
    const branch = good ? outcome.rollGood : outcome.rollBad;
    effectText = branch?.effect || null;
    appliedFn  = branch?.apply || null;
    if(good && branch?.gold) goldChange += branch.gold;
    if(!good && branch?.damage){
      const dmg = Math.floor(Math.random()*4)+1;
      heroes.filter(h=>!h.dead&&!h.enGuarida).forEach(h=>{ h.hp=Math.max(0,(h.hp||0)-dmg); });
    }
  }

  // Apply gold change evenly
  if(goldChange !== 0 && heroes.length > 0){
    const share = Math.floor(Math.abs(goldChange) / Math.max(1, heroes.filter(h=>!h.dead).length));
    heroes.filter(h=>!h.dead).forEach(h=>{
      h.gold = Math.max(0, (h.gold||0) + (goldChange > 0 ? share : -share));
    });
  }

  // Apply real effect
  if(appliedFn) appliedFn();

  rH(); saveS();

  // Build result UI
  const typeCol = outcome.type==='good'?'var(--gr)':outcome.type==='bad'?'var(--bl)':outcome.type==='risk'?'var(--go)':'var(--stl)';
  const typeIco = outcome.type==='good'?'&#11088;':outcome.type==='bad'?'&#128128;':outcome.type==='risk'?'&#127922;':'&#9679;';

  // Build applied effects summary
  let appliedHtml = '';
  if(goldChange !== 0){
    appliedHtml += '<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.05)">'
      +'<span style="font-size:16px">&#128176;</span>'
      +'<span style="font-size:12px;color:var(--pad);flex:1">Oro</span>'
      +'<span style="font-family:Cinzel,serif;font-size:13px;color:'+(goldChange>0?'var(--go)':'var(--bl)')+'">'+(goldChange>0?'+':'')+goldChange+' oros</span>'
      +'</div>';
  }
  if(effectText){
    appliedHtml += '<div style="display:flex;align-items:flex-start;gap:8px;padding:6px 0">'
      +'<span style="font-size:16px">'+(appliedFn?'&#10003;':'&#128302;')+'</span>'
      +'<span style="font-size:12px;color:'+(appliedFn?'var(--gr)':'var(--pad)')+';flex:1;line-height:1.5">'+effectText+'</span>'
      +'</div>';
  }

  const resultEl = document.getElementById('ciudad-event-result');
  if(resultEl){
    resultEl.innerHTML = '<div class="event-result">'
      +'<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">'
      +'<span style="font-size:24px">'+typeIco+'</span>'
      +(roll?'<span style="font-family:Cinzel,serif;font-size:18px;color:var(--go);font-weight:700">&#127922; '+roll+'</span>':'')
      +'<span style="font-family:Cinzel,serif;font-size:13px;color:'+typeCol+';flex:1;line-height:1.5">'+resultText+'</span>'
      +'</div>'
      +(appliedHtml
        ?'<div style="background:rgba(0,0,0,.3);border-radius:4px;padding:8px 12px;border:1px solid rgba(201,150,42,.15)">'
        +'<div style="font-family:Cinzel,serif;font-size:9px;letter-spacing:2px;color:var(--god);margin-bottom:6px">EFECTOS APLICADOS</div>'
        +appliedHtml+'</div>'
        :'')
      +'</div>';
  }

  document.querySelectorAll('.event-choice').forEach(b=>b.remove());
  renderCiudad();
}


function renderShop(shop, totalGold, heroCount){
  const isOpen = ciudadOpenCard === shop.id;
  const itemsHtml = shop.items.map((item,idx)=>{
    const canAfford = totalGold >= item.price;
    return '<div class="shop-item">'
      +'<span class="shop-item-ico">'+item.ico+'</span>'
      +'<div class="shop-item-info">'
      +'<div class="shop-item-name">'+item.nm+'</div>'
      +'<div class="shop-item-desc">'+item.desc+'</div>'
      +'</div>'
      +'<span class="shop-item-price">'+item.price+'&#128176;</span>'
      +'<button class="shop-btn" '+(heroCount===0||!canAfford?'disabled':'onclick="buyItem(\''+shop.id+'\','+idx+')"')
      +(item.heroTarget?' style="border-color:rgba(74,128,212,.6);color:var(--mg)"':'')+'>'
      +(canAfford&&heroCount>0?(item.heroTarget?'ELEGIR &#8250;':'COMPRAR'):'SIN OROS')
      +'</button>'
      +'</div>';
  }).join('');

  return '<div class="ciudad-card">'
    +'<div class="ciudad-card-hdr" onclick="toggleShop(\''+shop.id+'\')">'
    +'<span class="ciudad-card-ico">'+shop.ico+'</span>'
    +'<div style="flex:1">'
    +'<div class="ciudad-card-title">'+shop.title+'</div>'
    +'<div class="ciudad-card-sub">'+shop.sub+'</div>'
    +'</div>'
    +'<span style="color:var(--god);font-size:22px;transition:transform .2s'+(isOpen?';transform:rotate(90deg)':'')+'">&#8250;</span>'
    +'</div>'
    +'<div class="ciudad-card-body'+(isOpen?' open':'')+'">'+itemsHtml+'</div>'
    +'</div>';
}

