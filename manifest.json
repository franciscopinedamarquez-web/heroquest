  <div class="ss-logo">HERO<span>QUEST</span></div>
  <div class="ss-sub">GESTOR DE HEROES</div>
  <div class="ss-divider"></div>

  <!-- Save preview filled by JS -->
  <div id="ss-save-slot" style="width:100%"></div>

  <!-- Buttons filled by JS -->
