    .room-d20-body.open{display:block}
    .room-d20-roll-row{padding:10px 13px;display:flex;align-items:center;gap:12px;border-bottom:1px solid rgba(201,150,42,.1)}
    .d20-result-inline{font-family:'Cinzel',serif;font-size:26px;font-weight:700;color:var(--go);min-width:36px;text-align:center;transition:all .25s}
    .d20-result-inline.rolling{animation:diceRollAnim .35s ease}
    .d20-row-highlight{background:rgba(201,150,42,.14)!important;color:var(--go)!important}
  `;
  document.head.appendChild(s);
})();

const RARITY_COLS = {common:'#5a504a',uncommon:'#4a80d4',rare:'#8a2a8a',legendary:'#c9962a'};
const RARITY_LABELS = {common:'COMÚN',uncommon:'POCO COMÚN',rare:'RARO',legendary:'LEGENDARIO'};

// Inventory: gi is the global array, items have {nm,ico,ds,r,qty,src,heroId?}
function addToInventory(item, source){
  if(!gi) gi=[];
  const existing = gi.find(x=>x.nm===item.nm&&x.r===item.r);
  if(existing && item.stackable){ existing.qty=(existing.qty||1)+1; }
  else { gi.push({...item, qty:item.qty||1, src:source||'Desconocido', added:Date.now()}); }
  saveS();
  toast(item.ico+' '+item.nm+' añadido al inventario');
}

function renderInventario(){
  const c=document.getElementById('invcon');
  if(!c) return;

  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
  const items = gi||[];

  // Split by rarity for display
  const byRarity = {legendary:[],rare:[],uncommon:[],common:[]};
  items.forEach(it=>{
    const r=it.r||'common';
    if(byRarity[r]) byRarity[r].push(it);
    else byRarity.common.push(it);
  });

  let html='<div class="inv-view">'
    +'<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:3px;color:var(--god);text-align:center;padding:8px 0 12px">&#127919; INVENTARIO DEL GRUPO</div>'

    // Summary bar
    +'<div style="display:flex;gap:8px;margin-bottom:14px">'
    +[
      {ico:'&#128176;',val:totalGold+' oros',col:'var(--go)'},
      {ico:'&#127919;',val:items.length+' objetos',col:'var(--pa)'},
      {ico:'&#129514;',val:(items.filter(x=>x.nm&&x.nm.toLowerCase().includes('pocion')).length)+' pociones',col:'var(--gr)'},
    ].map(s=>'<div style="flex:1;background:rgba(0,0,0,.3);border:1px solid rgba(201,150,42,.15);border-radius:5px;padding:8px 10px;text-align:center">'
      +'<div style="font-size:18px">'+s.ico+'</div>'
      +'<div style="font-family:Cinzel,serif;font-size:11px;color:'+s.col+';margin-top:3px">'+s.val+'</div>'
      +'</div>'
    ).join('')
    +'</div>';

  if(items.length===0){
    html+='<div class="inv-empty">El inventario está vacío.<br>Los objetos conseguidos en mazmorras<br>y comprados en la ciudad aparecerán aquí.</div>';
  } else {
    ['legendary','rare','uncommon','common'].forEach(r=>{
      const group=byRarity[r];
      if(!group.length) return;
      html+='<div class="inv-section-title">'
        +'<span style="color:'+RARITY_COLS[r]+'">'+RARITY_LABELS[r]+'</span>'
        +'<span style="font-size:11px;color:var(--stl)">'+group.length+' objeto'+(group.length!==1?'s':'')+'</span>'
        +'</div>';
      group.forEach((it,idx)=>{
        const globalIdx = gi.indexOf(it);
        const rarCol = RARITY_COLS[r]||'var(--stl)';
        html+='<div class="inv-item">'
          +'<span class="inv-item-ico">'+it.ico+'</span>'
          +'<div class="inv-item-body">'
          +'<div class="inv-item-name">'+it.nm+(it.qty>1?' ×'+it.qty:'')+'</div>'
          +'<div class="inv-item-desc">'+(it.ds||it.desc||'Sin descripción')+'</div>'
          +(it.src?'<div class="inv-item-src">&#128205; '+it.src+'</div>':'')
          +'</div>'
          +'<span class="inv-rarity" style="color:'+rarCol+';border-color:'+rarCol+'44">'+RARITY_LABELS[r]+'</span>'
          +(isUsableItem(it)?'<button class="inv-use-btn" onclick="useInventoryItem('+globalIdx+')">USAR</button>':'')
          +'<button onclick="removeInvItem('+globalIdx+')" style="background:none;border:none;color:rgba(139,26,26,.5);font-size:18px;cursor:pointer;padding:4px;touch-action:manipulation">&#10005;</button>'
          +'</div>';
      });
    });
  }

  // Hero gold breakdown
  if(heroes.length>0){
    html+='<div class="inv-section-title"><span>ORO POR HÉROE</span></div>'
      +'<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:12px">';
    heroes.filter(h=>!h.dead).forEach(h=>{
      html+='<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(0,0,0,.25);border:1px solid rgba(201,150,42,.12);border-radius:5px">'
        +'<span style="font-size:20px">'+h.ico+'</span>'
        +'<span style="font-family:Cinzel,serif;font-size:12px;color:var(--pa);flex:1">'+h.name+'</span>'
        +'<span style="font-family:Cinzel,serif;font-size:14px;color:var(--go)">'+( h.gold||0)+' &#128176;</span>'
        +'</div>';
    });
    html+='</div>';
  }

  html+='</div>';
  c.innerHTML=html;
}

function isUsableItem(it){
  const nm=(it.nm||'').toLowerCase();
  return nm.includes('pocion')||nm.includes('pergamino')||nm.includes('elixir')||nm.includes('antidoto');
}

function useInventoryItem(idx){
  const it=gi[idx];
  if(!it) return;
  const nm=(it.nm||'').toLowerCase();
  if(nm.includes('pocion')||nm.includes('elixir')){
    // Heal most injured active hero
    const active=heroes.filter(h=>!h.enGuarida&&!h.dead);
    const target=active.sort((a,b)=>((a.hp/a.maxHp)-(b.hp/b.maxHp)))[0];
    if(target){ const heal=Math.floor(Math.random()*4)+3; target.hp=Math.min(target.maxHp,(target.hp||0)+heal); toast(it.ico+' '+it.nm+' usado en '+target.name+': +'+heal+' HP'); }
  } else if(nm.includes('antidoto')){
    toast(it.ico+' Antídoto usado — veneno curado');
  } else {
    toast(it.ico+' '+it.nm+' activado');
  }
  if(it.qty>1){ it.qty--; } else { gi.splice(idx,1); }
  rH(); saveS(); renderInventario();
}

function removeInvItem(idx){
  if(!gi||!gi[idx]) return;
  if(!confirm('¿Eliminar '+gi[idx].nm+' del inventario?')) return;
  gi.splice(idx,1);
  saveS(); renderInventario();
}

// ══════════════════════════════════════════════════════════════════════════════
// D20 TABLE INLINE IN ROOMS
// ══════════════════════════════════════════════════════════════════════════════
let openD20Rooms = new Set(); // track which rooms have D20 open

function renderInlineD20(room){
  const table = room.content.d20Table;
  if(!table||!table.length) return '';
  const rt = room.roomType||{label:'Sala',ico:'&#127968;'};
  const isOpen = openD20Rooms.has(room.idx);
  const resultId = 'id20res-'+room.idx;

  let rows = table.map(row=>
    '<tr id="id20row-'+room.idx+'-'+row[0]+'" style="border-bottom:1px solid rgba(255,255,255,.04)">'
    +'<td style="padding:7px 10px;font-family:Cinzel,serif;font-size:12px;color:var(--go);font-weight:700;width:44px;text-align:center">'+row[0]+'</td>'
    +'<td style="padding:7px 10px;font-size:12px;color:var(--pad);line-height:1.45">'+row[1]+'</td>'
    +'</tr>'
  ).join('');

  return '<div class="room-d20-section">'
    +'<div class="room-d20-header" onclick="toggleRoomD20('+room.idx+')">'
    +'<div style="display:flex;align-items:center;gap:8px">'
    +'<span style="font-size:16px">&#127922;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:11px;color:var(--god);letter-spacing:1px">TABLA D20 — '+rt.label.toUpperCase()+'</span>'
    +'</div>'
    +'<div style="display:flex;align-items:center;gap:10px">'
    +'<span class="d20-result-inline" id="'+resultId+'">—</span>'
    +'<button onclick="event.stopPropagation();rollInlineD20('+room.idx+')" style="background:linear-gradient(135deg,#2a1e0a,#1a1208);border:2px solid var(--god);border-radius:4px;color:var(--go);font-family:Cinzel,serif;font-size:11px;letter-spacing:1px;padding:7px 12px;cursor:pointer;touch-action:manipulation">&#127922; D20</button>'
    +'<span style="color:var(--god);font-size:18px;transition:transform .2s'+(isOpen?';transform:rotate(90deg)':'')+'">&#8250;</span>'
    +'</div>'
    +'</div>'
    +'<div class="room-d20-body'+(isOpen?' open':'')+'" id="id20body-'+room.idx+'">'
    +'<div class="room-d20-roll-row">'
    +'<span style="font-size:13px;color:var(--stl);font-style:italic">Tira el dado y compara con la tabla</span>'
    +'</div>'
    +'<table style="width:100%;border-collapse:collapse"><tbody>'+rows+'</tbody></table>'
    +'</div>'
    +'</div>';
}

function toggleRoomD20(roomIdx){
  if(openD20Rooms.has(roomIdx)) openD20Rooms.delete(roomIdx);
  else openD20Rooms.add(roomIdx);
  renderSk();
  // Scroll to keep position
  const el=document.getElementById('id20body-'+roomIdx);
  if(el&&openD20Rooms.has(roomIdx)) setTimeout(()=>el.scrollIntoView({behavior:'smooth',block:'nearest'}),100);
}

function rollInlineD20(roomIdx){
  const roll=Math.floor(Math.random()*20)+1;
  const resEl=document.getElementById('id20res-'+roomIdx);
  if(resEl){ resEl.classList.remove('rolling'); void resEl.offsetWidth; resEl.textContent=roll; resEl.classList.add('rolling'); }
  // Clear all highlights for this room
  if(!dg) return;
  const room=dg.rooms[roomIdx];
  const table=room?.content?.d20Table||[];
  table.forEach(row=>{
    const rowEl=document.getElementById('id20row-'+roomIdx+'-'+row[0]);
    if(rowEl){ rowEl.style.background=''; rowEl.querySelectorAll('td').forEach(td=>td.style.color=''); }
  });
  // Highlight the result
  const target=document.getElementById('id20row-'+roomIdx+'-'+roll);
  if(target){
    target.classList.add('d20-row-highlight');
    target.querySelectorAll('td').forEach(td=>td.classList.add('d20-row-highlight'));
    // Auto-open if closed
    openD20Rooms.add(roomIdx);
    const body=document.getElementById('id20body-'+roomIdx);
    if(body){ body.classList.add('open'); }
    setTimeout(()=>target.scrollIntoView({behavior:'smooth',block:'nearest'}),150);
  }
}

