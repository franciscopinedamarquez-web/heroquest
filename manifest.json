// ── GENERATORS ────────────────────────────────────────────────────────────────
function rnd(arr){ return arr[Math.floor(Math.random()*arr.length)]; }
function ri(a,b){ return a+Math.floor(Math.random()*(b-a+1)); }
function rollDice(sides){ return Math.floor(Math.random()*sides)+1; }

function pickRoomSize(roomIdx){
  if(roomIdx===9) return {w:6,h:6,label:'6x6'};
  if(roomIdx===0) return {w:3,h:3,label:'3x3'};
  const pool=[];
  ROOM_SIZES.forEach(s=>{ for(let i=0;i<s.freq;i++) pool.push(s); });
  return rnd(pool);
}

function weightedRandom(pool){
  const total=pool.reduce((a,b)=>a+b.weight,0);
  let r=Math.random()*total;
  for(const item of pool){ r-=item.weight; if(r<=0) return item; }
  return pool[pool.length-1];
}

function pickRoomType(roomIdx, difficulty, isNarrative){
  if(isNarrative) return {type:'narrative',label:'Sala de Historia',ico:'&#128212;',weight:0};
  if(roomIdx===9) return {type:'combat',label:'Sala del Jefe',ico:'&#128128;',weight:0};
  // Filter pool by difficulty
  const d=DIFFICULTY[difficulty]||DIFFICULTY.medio;
  let pool=[...ROOM_TYPE_POOL];
  if(difficulty==='facil') pool=pool.filter(t=>t.type!=='ambush');
  if(difficulty==='dificil'){
    pool=pool.map(t=>({...t, weight: t.type==='combat'||t.type==='ambush'?t.weight+2:t.weight}));
  }
  return weightedRandom(pool);
}

function generateFurniture(loreType, size, difficulty){
  const pool = FURNITURE_POOLS[loreType]||FURNITURE_POOLS.Mazmorra;
  const count = ri(1, Math.min(4, Math.floor(size.w*size.h/4)));
  const placed=[];
  for(let i=0;i<count;i++){
    let x,y,tries=0;
    do{x=ri(0,size.w-1);y=ri(0,size.h-1);tries++;}
    while(tries<20&&placed.some(p=>p.x===x&&p.y===y));
    placed.push({...rnd(pool),x,y,id:'f'+i});
  }
  return placed;
}

function generateRoomContents(roomIdx, loreType, difficulty, roomType, isNarrative, lore){
  const d=DIFFICULTY[difficulty]||DIFFICULTY.medio;
  const isBoss=roomIdx===9;
  const enemies=ENEMY_POOLS[loreType]||ENEMY_POOLS.Mazmorra;
  const boss=BOSS_POOL[loreType]||BOSS_POOL.Mazmorra;
  const size=pickRoomSize(roomIdx);

  // Place enemies based on room type and difficulty
  const roomEnemies=[];
  let enemyCount=0;
  if(isBoss){
    const bossEnemy={...boss,id:'boss',curHp:Math.round(boss.hp*d.hpMult)};
    bossEnemy.hp=bossEnemy.curHp;
    roomEnemies.push({...bossEnemy,x:Math.floor(size.w/2),y:Math.floor(size.h/2)});
  } else if(roomType.type==='combat'||roomType.type==='ambush'){
    enemyCount=ri(d.enemyMin, Math.min(d.enemyMax, size.w*size.h-2));
  } else if(roomType.type==='trap'||roomType.type==='puzzle'){
    if(Math.random()<0.4) enemyCount=ri(1,d.enemyMin);
  } else if(roomType.type==='narrative'||roomType.type==='shrine'){
    enemyCount=0;
  } else {
    if(Math.random()<0.3) enemyCount=ri(1,d.enemyMin);
  }
  for(let i=0;i<enemyCount;i++){
    const e={...rnd(enemies),id:'e'+roomIdx+'_'+i};
    e.hp=Math.max(1,Math.round(e.hp*d.hpMult));
    e.curHp=e.hp;
    let x,y,tries=0;
    do{x=ri(0,size.w-1);y=ri(0,size.h-1);tries++;}
    while(tries<20&&roomEnemies.some(r=>r.x===x&&r.y===y));
    roomEnemies.push({...e,x,y});
  }

  // Traps
  const traps=[];
  if(roomType.type!=='shrine'&&roomType.type!=='merchant'){
    const trapCount=roomIdx<2?0:Math.floor(ri(0,Math.min(3,Math.floor(roomIdx/3)))*d.trapMult);
    for(let i=0;i<trapCount;i++){
      let x,y,tries=0;
      do{x=ri(0,size.w-1);y=ri(0,size.h-1);tries++;}
      while(tries<20&&(roomEnemies.some(r=>r.x===x&&r.y===y)||traps.some(t=>t.x===x&&t.y===y)));
      traps.push({...rnd(TRAP_TYPES),x,y,id:'t'+i});
    }
  }

  // Loot
  const loots=[];
  const wantsLoot=roomType.type==='treasure'||isBoss||(Math.random()>(difficulty==='facil'?0.2:difficulty==='dificil'?0.5:0.35));
  if(wantsLoot){
    const lootCount=roomType.type==='treasure'?ri(1,2):1;
    for(let i=0;i<lootCount;i++){
      let x,y,tries=0;
      do{x=ri(0,size.w-1);y=ri(0,size.h-1);tries++;}
      while(tries<20&&(roomEnemies.some(r=>r.x===x&&r.y===y)||traps.some(t=>t.x===x&&t.y===y)||loots.some(l=>l.x===x&&l.y===y)));
      loots.push({...rnd(isBoss?LOOT_TYPES:LOOT_TYPES),x,y,id:'l'+i});
    }
  }

  // PNJ
  let pnjData=null;
  if(roomType.type==='pnj'||roomType.type==='merchant'){
    pnjData=roomType.type==='merchant'
      ? {nm:'Mercader',ico:'&#128717;',desc:'Tiene mercancias. Consulta la tabla D20 para ver su stock.',type:'mercader',stock:MERCHANT_STOCK.sort(()=>Math.random()-.5).slice(0,ri(3,5))}
      : rnd(PNJ_POOL);
  }

  // Furniture
  const furniture=generateFurniture(loreType,size,difficulty);

  // Narrative events
  let narrativeEvent=null;
  if(roomType.type==='narrative'){
    const narratives=[
      {ico:'&#128212;',txt:'El grupo descubre evidencia del objetivo principal de la mision.'},
      {ico:'&#128212;',txt:'Un testigo revela informacion crucial sobre el jefe de la mazmorra.'},
      {ico:'&#128212;',txt:'Los heroes encuentran el lugar exacto donde ocurrio el evento de la mision.'},
      {ico:'&#128212;',txt:'Una vision magica muestra el objetivo completado — queda poco camino.'},
    ];
    narrativeEvent=rnd(narratives);
  }

  // D20 table for this room
  const d20Table=generateRoomD20Table(roomType.type, loreType, difficulty, roomIdx);

  return {size,enemies:roomEnemies,traps,loots,furniture,isBoss,pnjData,narrativeEvent,d20Table,roomType};
}

function generateCorridorContent(corridorIdx,loreType,difficulty){
  const d=DIFFICULTY[difficulty]||DIFFICULTY.medio;
  const widths=[1,1,2,2,2,3];
  const w=widths[Math.floor(Math.random()*widths.length)];
  const h=ri(3,8);
  const enemies=ENEMY_POOLS[loreType]||ENEMY_POOLS.Mazmorra;
  const corridorEnemies=[];
  const hasEnemy=corridorIdx>0&&Math.random()<(d.corridorEnemy+corridorIdx*0.04);
  if(hasEnemy){
    const count=ri(1,Math.ceil(d.enemyMin/2));
    for(let i=0;i<count;i++){
      const e={...rnd(enemies),id:'ce'+corridorIdx+'_'+i};
      e.hp=Math.max(1,Math.round(e.hp*d.hpMult)); e.curHp=e.hp;
      let x,y,tries=0;
      do{x=ri(0,w-1);y=ri(1,h-2);tries++;}
      while(tries<20&&corridorEnemies.some(r=>r.x===x&&r.y===y));
      corridorEnemies.push({...e,x,y});
    }
  }
  const traps=[];
  if(corridorIdx>1&&Math.random()<0.25*d.trapMult){
    let x,y,tries=0;
    do{x=ri(0,w-1);y=ri(1,h-2);tries++;}
    while(tries<20&&corridorEnemies.some(r=>r.x===x&&r.y===y));
    traps.push({...rnd(TRAP_TYPES),x,y,id:'ct0'});
  }
  const maxQueries=ri(1,3);
  return{w,h,enemies:corridorEnemies,traps,maxQueries,usedQueries:0};
}

function generateCorridorDesc(roomIdx,lore){
  const descs=[
    'Un corredor estrecho de piedra humeda. Antorchas apagadas en las paredes.',
    'El pasillo se curva suavemente. El suelo cruje bajo los pies.',
    'Niebla baja cubre el suelo. El aire huele a moho y sangre seca.',
    'Las paredes tienen marcas de garras. Algo paso aqui a toda prisa.',
    'Un corredor mas ancho. Se escucha agua corriendo detras de las paredes.',
    'La piedra esta ennegrecida por el fuego. Restos de una batalla reciente.',
    'El techo baja peligrosamente. Hay que agacharse para avanzar.',
    'Estatuas de guerreros flanquean el paso. Sus ojos parecen seguirte.',
    'Un corredor largo y recto. La luz de la antorcha apenas llega al final.',
    'Las puertas al jefe se ven al fondo. El suelo vibra levemente.',
  ];
  return descs[roomIdx%descs.length];
}

function generateDungeon(lore,difficulty){
  const loreType=lore.ty||'Mazmorra';
  // Decide which 2 rooms (excluding 0 and 9) are narrative
  const narrativeIdxs=[];
  while(narrativeIdxs.length<2){
    const idx=ri(1,8);
    if(!narrativeIdxs.includes(idx)) narrativeIdxs.push(idx);
  }
  const rooms=[];
  for(let i=0;i<10;i++){
    const isNarrative=narrativeIdxs.includes(i);
    const roomType=pickRoomType(i,difficulty,isNarrative);
    const maxRoomQueries=ri(2,4);
    rooms.push({
      idx:i,state:'hidden',
      content:generateRoomContents(i,loreType,difficulty,roomType,isNarrative,lore),
      corridorContent:generateCorridorContent(i,loreType,difficulty),
      corridorDesc:generateCorridorDesc(i,lore),
      usedRoomQueries:0,maxRoomQueries,
      roomType,isNarrative,
    });
  }
  rooms[0].state='corridor';
  return{lore,loreType,difficulty,rooms,currentPos:-1,currentZone:'corridor',phase:'explore'};
}


function startSk(){
  if(!skDifficulty){ renderDifficultyPicker(); return; }
  const lore=rnd(LORE_POOL);
  dg=generateDungeon(lore,skDifficulty);
  currentAdventure={lore,started:Date.now(),difficulty:skDifficulty};
  oracleLog=[];
  if(!sk)sk={};
  sk.adventure=currentAdventure; sk.dg=dg; sk.oracleLog=oracleLog;
  saveS(); renderSk();
}

function renderDifficultyPicker(){
  const c=document.getElementById('skcon');
  c.innerHTML=
    '<div style="padding:30px 20px;text-align:center">'
    +'<div style="font-size:56px;margin-bottom:14px;opacity:.5">&#9876;&#65039;</div>'
    +'<div style="font-family:Cinzel,serif;font-size:17px;color:var(--god);letter-spacing:2px;margin-bottom:6px">NUEVA ESCARAMUZA</div>'
    +'<div style="font-size:13px;color:var(--stl);font-style:italic;margin-bottom:28px">Elige la dificultad antes de comenzar</div>'
    +'</div>'
    +Object.entries(DIFFICULTY).map(([key,d])=>{
      const tips={
        facil:'1-2 enemigos por sala. Pocas trampas. Mas botin. Sin emboscadas.',
        medio:'2-3 enemigos. Trampas moderadas. Botin estandar. Alguna emboscada.',
        dificil:'3-5 enemigos. Muchas trampas. Poco botin. Enemigos mas duros y frecuentes.',
      };
      return '<button onclick="setDifficulty(\''+key+'\')" style="'
        +'display:flex;align-items:center;gap:14px;'
        +'width:calc(100% - 28px);margin:0 14px 10px;'
        +'background:linear-gradient(135deg,rgba(0,0,0,.5),rgba(0,0,0,.3));'
        +'border:2px solid '+d.col+';border-radius:6px;'
        +'padding:16px 18px;cursor:pointer;touch-action:manipulation;text-align:left">'
        +'<span style="font-size:36px">'+d.ico+'</span>'
        +'<div>'
        +'<div style="font-family:Cinzel,serif;font-size:15px;color:'+d.col+';font-weight:700;letter-spacing:1px;margin-bottom:4px">'+d.label+'</div>'
        +'<div style="font-size:12px;color:var(--stl);line-height:1.5">'+tips[key]+'</div>'
        +'</div>'
        +'</button>';
    }).join('');
}

function setDifficulty(diff){
  skDifficulty=diff;
  startSk();
}


function renderSk(){
  const c = document.getElementById('skcon');
  if(!dg){
    renderDifficultyPicker();
    return;
  }

  const lore = dg.lore;
  const pos  = dg.currentPos;      // -1..9 (room index)
  const zone = dg.currentZone;     // 'corridor' | 'room'
  const room = pos >= 0 ? dg.rooms[pos] : null;

  // ── Progress bar ──
  const prog = Math.max(0, pos+1);
  const pct  = Math.round(prog/10*100);
  const progressHtml =
    '<div style="margin-bottom:14px">'
    + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px">'
    + '<span style="font-family:\'Cinzel\',serif;font-size:10px;letter-spacing:2px;color:var(--god)">PROGRESO EN LA MAZMORRA</span>'
    + '<span style="font-family:\'Cinzel\',serif;font-size:12px;color:var(--go)">'
    + (pos<0?'Entrada':pos===9?'JEFE':'Sala '+(pos+1)+'/10') + '</span>'
    + '</div>'
    + '<div style="height:8px;background:rgba(0,0,0,.4);border-radius:4px;overflow:hidden;border:1px solid rgba(201,150,42,.2)">'
    + '<div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,var(--grd),var(--go));transition:width .5s ease;border-radius:4px"></div>'
    + '</div>'
    + '<div style="display:flex;margin-top:5px;gap:2px">'
    + Array.from({length:10},(_,i)=>{
        const st = dg.rooms[i].state;
        const isCurrent = i===pos;
        const isBoss = i===9;
        const col = isCurrent ? 'var(--go)' : st==='cleared' ? 'var(--gr)' : st==='revealed' ? 'var(--mg)' : 'rgba(201,150,42,.15)';
        return '<div style="flex:1;height:14px;border-radius:2px;background:'+col+';border:1px solid rgba(201,150,42,.2);display:flex;align-items:center;justify-content:center;font-size:8px">'
          + (isBoss?'&#128128;':isCurrent?'&#9678;':'')
          + '</div>';
      }).join('')
    + '</div>'
    + '</div>';

  // ── Lore card (collapsed, just title + tags) ──
  const tagsHtml = (lore.tags||[]).map((t,i)=>{
    const col   = lore.tagcols?lore.tagcols[i]:'var(--pad)';
    const cond  = CONDITIONS[t];
    const ico   = cond?cond.ico:'&#127919;';
    return '<button class="lore-tag" onclick="showCondition(\''+t+'\')" style="color:'+col+';border-color:'+col+'66;background:rgba(0,0,0,.5)">'+ico+' '+t+'</button>';
  }).join('');

  const loreHtml =
    '<div class="lore-card" style="margin-bottom:12px">'
    + '<div class="lore-header">'
    + '<div style="flex:1"><div class="lore-title" style="font-size:16px">'+lore.tl+'</div>'
    + '<div class="lore-obj" style="font-size:12px">&#127919; '+lore.ob+'</div></div>'
    + '<span class="lore-badge" style="color:'+(lore.bcol||'var(--go)')+';border-color:'+(lore.bcol||'var(--god)')+'66;background:'+(lore.bcol||'#2a1a08')+'22;font-size:10px">'+lore.badge+'</span>'
    + '</div>'
    + '<div class="lore-footer" style="padding:8px 14px">'+tagsHtml+'</div>'
    + '</div>';

  // ── Zone content ──
  let zoneHtml = '';
  if(zone==='corridor'){
    zoneHtml = renderCorridorView(pos, dg);
  } else if(zone==='room' && room){
    zoneHtml = renderRoomView(room, dg);
  }

  // ── Navigation buttons ──
  let navHtml = renderNavButtons(pos, zone, dg);

  // ── Oracle log ──
  const logHtml = oracleLog.length ?
    '<div class="sk-log" style="margin-top:12px">'
    + '<div class="sk-log-title">&#128220; REGISTRO</div>'
    + oracleLog.slice(0,5).map(l=>'<div class="sk-log-item">'+l+'</div>').join('')
    + '</div>' : '';

  c.innerHTML = progressHtml + loreHtml + zoneHtml + navHtml + logHtml
    + '<div style="padding:14px 0 0">'
    + '<button onclick="if(confirm(\'Abandonar esta escaramuza?\'))resetDungeon()" style="width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.2);border-radius:4px;color:var(--stl);font-family:\'Cinzel\',serif;font-size:11px;letter-spacing:1px;padding:11px;cursor:pointer">&#9876;&#65039; NUEVA ESCARAMUZA</button>'
    + '</div>';
}

function renderCorridorGrid(cc){
  if(!cc) return '';
  const CELL = 34;
  const {w,h,enemies,traps} = cc;
  const grid = Array.from({length:h},()=>Array(w).fill(null));
  enemies.forEach(e=>{ if(e.y<h&&e.x<w) grid[e.y][e.x]={type:'enemy',data:e}; });
  traps.forEach(t=>{   if(t.y<h&&t.x<w) grid[t.y][t.x]={type:'trap', data:t}; });
  const midCol = Math.floor(w/2);
  let tbl = '<div style="overflow-x:auto;margin-bottom:8px"><table style="border-collapse:collapse;margin:0 auto">';
  for(let r=0;r<h;r++){
    tbl += '<tr>';
    for(let c=0;c<w;c++){
      const cell = grid[r][c];
      let bg='rgba(14,10,6,.9)',border='1px solid rgba(201,150,42,.1)',inner='';
      if(r===0&&c===midCol)   inner='<span style="font-size:11px;color:rgba(201,150,42,.5)">&#9650;</span>';
      if(r===h-1&&c===midCol) inner='<span style="font-size:11px;color:rgba(201,150,42,.5)">&#9660;</span>';
      if(cell){
        if(cell.type==='enemy'){bg='rgba(70,15,15,.8)';border='1px solid rgba(139,26,26,.5)';inner='<span style="font-size:17px">'+cell.data.ico+'</span>';}
        if(cell.type==='trap') {bg='rgba(40,30,10,.8)';border='1px solid rgba(201,150,42,.35)';inner='<span style="font-size:14px">&#9888;&#65039;</span>';}
      }
      tbl += '<td style="width:'+CELL+'px;height:'+CELL+'px;background:'+bg+';border:'+border+';text-align:center;vertical-align:middle">'+inner+'</td>';
    }
    tbl += '</tr>';
  }
  return tbl+'</table></div><div style="font-family:Cinzel,serif;font-size:9px;letter-spacing:2px;color:var(--stl);text-align:center;margin-bottom:10px">PASILLO '+w+'x'+h+' CASILLAS</div>';
}

function statCell(ico,lbl,val,col){
  return '<div style="padding:7px 4px;text-align:center;border-right:1px solid rgba(201,150,42,.08)">'
    +'<div style="font-size:16px;margin-bottom:2px">'+ico+'</div>'
    +'<div style="font-family:Cinzel,serif;font-size:15px;color:'+col+';font-weight:700">'+val+'</div>'
    +'<div style="font-size:9px;color:var(--stl);letter-spacing:1px">'+lbl+'</div></div>';
}

function renderEnemyCards(enemies,zoneKey){
  if(!enemies||!enemies.length) return '';
  const isBoss = enemies.some(e=>e.id==='boss');
  let h2='<div style="margin-bottom:12px">'
    +'<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:'+(isBoss?'var(--bl)':'var(--god)')+';margin-bottom:8px">'+(isBoss?'&#128128; JEFE':'&#128121; ENEMIGOS')+'</div>';
  enemies.forEach(e=>{
    const maxHp=e.hp, curHp=(e.curHp!=null?e.curHp:maxHp);
    const pct=Math.max(0,curHp/maxHp*100);
    const hcol=pct>60?'var(--gr)':pct>30?'var(--go)':'var(--bl)';
    h2+='<div style="background:linear-gradient(135deg,#1e1208,#140c04);border:1px solid rgba('+(isBoss?'139,26,26':'201,150,42')+','+(isBoss?.35:.2)+');border-radius:6px;overflow:hidden;margin-bottom:8px">'
      +'<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:rgba(0,0,0,.35);border-bottom:1px solid rgba(201,150,42,.1)">'
      +'<span style="font-size:28px;flex-shrink:0">'+e.ico+'</span>'
      +'<div style="flex:1">'
      +'<div style="font-family:Cinzel,serif;font-size:14px;color:'+(isBoss?'var(--bl)':'var(--pa)')+';font-weight:700">'+e.nm+'</div>'
      +'<div style="font-size:11px;color:var(--stl)">'+e.type+(e.magic?' · magico':'')+(e.poison?' · venenoso':'')+(e.regen?' · regenera':'')+'</div>'
      +'</div>'
      +(isBoss?'<div style="font-family:Cinzel,serif;font-size:11px;color:var(--bl);border:1px solid var(--bl);border-radius:3px;padding:2px 7px">JEFE</div>':'')
      +'</div>'
      +'<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid rgba(201,150,42,.08)">'
      +statCell('&#10084;','Vida',curHp+'/'+maxHp,hcol)
      +statCell('&#9876;&#65039;','Ataque',e.atk,'var(--bl)')
      +statCell('&#128737;&#65039;','Defensa',e.def,'var(--go)')
      +statCell('&#128694;','Mov.',e.mv,'var(--mg)')
      +'</div>'
      +'<div style="padding:8px 12px">'
      +'<div style="height:6px;background:rgba(0,0,0,.5);border-radius:3px;overflow:hidden;margin-bottom:8px">'
      +'<div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,'+hcol+','+hcol+'88);border-radius:3px;transition:width .3s"></div></div>'
      +(e.desc?'<div style="font-size:11px;color:var(--stl);font-style:italic;margin-bottom:8px;line-height:1.5">'+e.desc+'</div>':'')
      +'<div style="display:flex;align-items:center;justify-content:center;gap:10px">'
      +'<button onclick="adjEnemyHp(\''+zoneKey+'_'+e.id+'\',\''+e.id+'\',-1)" style="background:rgba(0,0,0,.5);border:1px solid var(--bl);border-radius:50%;width:34px;height:34px;color:var(--bl);font-size:22px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center">−</button>'
      +'<span style="font-family:Cinzel,serif;font-size:20px;color:'+hcol+';min-width:44px;text-align:center">'+curHp+'</span>'
      +'<button onclick="adjEnemyHp(\''+zoneKey+'_'+e.id+'\',\''+e.id+'\',1)" style="background:rgba(0,0,0,.5);border:1px solid var(--gr);border-radius:50%;width:34px;height:34px;color:var(--gr);font-size:22px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center">+</button>'
      +'</div></div></div>';
  });
  return h2+'</div>';
}

function adjEnemyHp(zoneKey,enemyId,delta){
  if(!dg) return;
  const pos=dg.currentPos, zone=dg.currentZone;
  let enemies;
  if(zone==='corridor'){
    const ci=Math.max(0,pos);
    enemies=dg.rooms[Math.min(ci,9)]?.corridorContent?.enemies;
  } else {
    enemies=pos>=0?dg.rooms[pos]?.content?.enemies:null;
  }
  if(!enemies) return;
  const e=enemies.find(x=>x.id===enemyId);
  if(!e) return;
  e.curHp=Math.max(0,Math.min(e.hp,(e.curHp!=null?e.curHp:e.hp)+delta));
  if(sk) sk.dg=dg;
  saveS(); renderSk();
}

function qLimitBar(used,max){
  return '<div style="display:flex;align-items:center;gap:6px;margin-bottom:10px;padding:7px 10px;background:rgba(0,0,0,.3);border-radius:4px;border:1px solid rgba(201,150,42,.15)">'
    +'<span style="font-size:14px">&#128302;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:11px;color:var(--god);flex:1">Consultas disponibles</span>'
    +Array.from({length:max},(_,i)=>'<span style="font-size:16px;opacity:'+(i<used?.25:1)+'">'+(i<used?'&#9711;':'&#9673;')+'</span>').join('')
    +'</div>';
}

function renderCorridorView(pos,dg){
  const ci=Math.max(0,pos);
  const isEntry=pos<0;
  const roomData=dg.rooms[Math.min(ci,9)];
  const cc=roomData?roomData.corridorContent:null;
  const desc=isEntry?dg.lore.atmosphere:(roomData?roomData.corridorDesc:'');
  const heading=isEntry?'&#128304; ENTRADA — PASILLO 1':'&#9135;&#65039; PASILLO '+(ci+1)+' / 10';
  const maxQ=cc?cc.maxQueries:2;
  const usedQ=cc?Math.min(cc.usedQueries||0,maxQ):0;
  const remaining=Math.max(0,maxQ-usedQ);

  return '<div style="background:linear-gradient(135deg,#1a1208,#0d0a07);border:1px solid rgba(201,150,42,.25);border-radius:6px;overflow:hidden;margin-bottom:12px">'
    +'<div style="padding:11px 14px;background:rgba(0,0,0,.4);border-bottom:1px solid rgba(201,150,42,.15);display:flex;align-items:center;gap:8px">'
    +'<span style="font-size:20px">&#9135;&#65039;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:12px;color:var(--god);letter-spacing:1px">'+heading+'</span>'
    +'</div>'
    +'<div style="padding:12px 14px">'
    +(cc?renderCorridorGrid(cc):'')
    +'<div style="font-size:14px;color:var(--pad);font-style:italic;line-height:1.8;margin-bottom:12px">'+desc+'</div>'
    +(cc&&cc.enemies.length?renderEnemyCards(cc.enemies,'cor'+ci):'')
    +qLimitBar(usedQ,maxQ)
    +(remaining>0?renderCorridorOracle(pos,dg):'<div style="font-family:Cinzel,serif;font-size:12px;color:var(--stl);text-align:center;padding:10px;font-style:italic">Sin mas consultas en este pasillo.</div>')
    +'</div></div>';
}

// Corridor-specific oracle questions

// ══════════════════════════════════════════════════════════════════════════════
// ORÁCULO COHERENTE — Estado de zona persiste entre preguntas
// ══════════════════════════════════════════════════════════════════════════════

// ZoneState tracks what the oracle already "knows" about the current zone.
// Keys: hasEnemies, hasTrap, hasSecret, hasLoot, hasPNJ, isSafe, isAmbush
// These are set by previous oracle answers and constrain future ones.
// Stored per zone key (e.g. "cor_3", "rm_7")

let zoneStates = {};  // key -> { hasEnemies, hasTrap, hasSecret, ... }

function getZoneState(key){
  if(!zoneStates[key]) zoneStates[key] = {};
  return zoneStates[key];
}

function setZoneState(key, updates){
  const z = getZoneState(key);
  Object.assign(z, updates);
  // Save with dg
  if(dg){ dg._zoneStates = zoneStates; if(sk) sk.dg = dg; }
}

// Restore zone states when loading saved game
function restoreZoneStates(){
  if(dg && dg._zoneStates) zoneStates = dg._zoneStates;
  else zoneStates = {};
}

// ── CORRIDOR QUESTIONS (3 questions, coherence-aware) ─────────────────────────
const CORRIDOR_Qs = [
  {
    id:'explorar', ico:'&#128270;', lbl:'Exploro el pasillo', hint:'Buscar peligros o secretos',
    // Rules: if zone already has enemies from "escuchar", we must show them; if safe, no trap
    resolve: function(zk){
      const z = getZoneState(zk);
      // If we already know there are enemies (from listen), show them nearby
      if(z.hasEnemies){
        return {res:'Rastros recientes de enemigos', det:'El suelo muestra huellas frescas. Los mismos que oíste antes patrullan este tramo.', casillas:'A 2-4 casillas adelante', fx:{ico:'&#9876;&#65039;',txt:'Enemigos confirmados — 2-4 casillas'}, _sets:{hasTrap:false}};
      }
      if(z.isAmbush){
        return {res:'Marcas de emboscada preparada', det:'Cuerdas tensadas, piedras alineadas. Alguien preparó esto con cuidado. Si avanzas sin precaución, actúan.', casillas:'En los 3 casillas siguientes', fx:{ico:'&#128128;',txt:'Emboscada activa — 3 casillas'}, _sets:{}};
      }
      if(z.isSafe){
        return {res:'Pasillo completamente despejado', det:'Lo confirmas con tus propios ojos. No hay nada más que piedra y silencio. El sonido tampoco mentía.', casillas:'Libre hasta la puerta', fx:null, _sets:{hasTrap:false, hasSecret: Math.random()>0.7}};
      }
      // Default random
      const roll = rollDice(6);
      if(roll<=2) return {res:'Pasillo despejado',        det:'El corredor está limpio. Suelo firme, sin trampas visibles.', casillas:'Libre hasta la puerta', fx:null, _sets:{isSafe:true, hasTrap:false}};
      if(roll<=3) return {res:'Trampa de hilo detectada', det:'Un hilo casi invisible cruza el pasillo. El Enano puede desactivarla (4+ en 1D6).', casillas:'A 2 casillas adelante', fx:{ico:'&#9888;&#65039;',txt:'Trampa — desactivar o rodear'}, _sets:{hasTrap:true}};
      if(roll<=4) return {res:'Panel secreto en la pared',det:'El Enano nota un panel movible. Detrás hay un objeto o atajo.', casillas:'A 1 casilla, pared derecha', fx:{ico:'&#128285;',txt:'Panel secreto — 1 casilla'}, _sets:{hasSecret:true}};
      if(roll<=5) return {res:'Rastro de sangre',         det:'Gotas de sangre llevan hacia la puerta. Alguien pasó herido hace poco.', casillas:'Desde aquí hasta la puerta', fx:{ico:'&#128167;',txt:'Rastro — indica combate reciente'}, _sets:{hasEnemies:true}};
      return           {res:'Emboscada preparada',        det:'Sombras inmóviles en los recodos del pasillo. Están esperando que entres.', casillas:'A 3-4 casillas', fx:{ico:'&#9876;&#65039;',txt:'COMBATE — emboscada activa'}, _sets:{isAmbush:true, hasEnemies:true}};
    }
  },
  {
    id:'escuchar', ico:'&#128483;', lbl:'Escucho antes de avanzar', hint:'Detectar actividad en la zona',
    resolve: function(zk){
      const z = getZoneState(zk);
      // If we already explored and found nothing dangerous, this confirms it
      if(z.isSafe){
        return {res:'Silencio absoluto, confirmado', det:'Tus oídos confirman lo que tus ojos vieron: no hay nadie. Puedes avanzar con total seguridad.', casillas:null, fx:null, _sets:{}};
      }
      if(z.isAmbush){
        return {res:'Respiran conteniendo el aliento', det:'Escuchas la respiración tensa de al menos dos figuras. Están justo al otro lado del recodo, esperando.', casillas:'A 1-2 casillas del recodo', fx:{ico:'&#128128;',txt:'EMBOSCADA — respiran a 1-2 casillas'}, _sets:{}};
      }
      if(z.hasTrap){
        return {res:'Solo el chasquido del mecanismo', det:'Un leve chasquido metálico periódico. Es la trampa que encontraste — el mecanismo está activo.', casillas:null, fx:{ico:'&#9888;&#65039;',txt:'Trampa activa — confirma lo encontrado'}, _sets:{}};
      }
      if(z.hasEnemies){
        return {res:'Pasos confirmados', det:'Los mismos pasos que intuías. Se mueven despacio, en patrulla. Probablemente no os han oído todavía.', casillas:'3-5 casillas adelante', fx:{ico:'&#128121;',txt:'Enemigos — patrulla lenta, 3-5 casillas'}, _sets:{}};
      }
      // No prior context — independent roll
      const roll = rollDice(6);
      if(roll<=2) return {res:'Silencio total',       det:'Nada al otro lado. El pasillo parece muerto.', casillas:null, fx:null, _sets:{isSafe:true}};
      if(roll<=3) return {res:'Ruidos lejanos',        det:'Pasos distantes, quizá de la sala siguiente. No en el pasillo mismo.', casillas:null, fx:{ico:'&#9888;&#65039;',txt:'Actividad — en sala siguiente, no aquí'}, _sets:{}};
      if(roll<=4) return {res:'Pasos en el pasillo',   det:'Alguien patrulla este corredor. Se acerca desde el otro extremo.', casillas:'Avanzando desde el fondo', fx:{ico:'&#128121;',txt:'Patrulla — viene hacia ti'}, _sets:{hasEnemies:true}};
      if(roll<=5) return {res:'Voces en voz baja',     det:'Dos o tres voces. Están apostados esperando. Han oído algo y están alerta.', casillas:'A 4-5 casillas, quietos', fx:{ico:'&#128121;',txt:'Guardias alertas — 4-5 casillas'}, _sets:{hasEnemies:true}};
      return           {res:'Silencio siniestro',      det:'Demasiado silencio. Ni pasos ni respiración. Una emboscada bien entrenada no hace ruido.', casillas:null, fx:{ico:'&#128128;',txt:'EMBOSCADA preparada — máxima alerta'}, _sets:{isAmbush:true}};
    }
  },
  {
    id:'puerta', ico:'&#128682;', lbl:'Examino la puerta de la sala', hint:'Antes de abrir la puerta',
    resolve: function(zk){
      const z = getZoneState(zk);
      // If we know there's an ambush, the door might be trapped or reinforced
      if(z.isAmbush){
        return {res:'Puerta con truco al abrirla', det:'Al tocarla notas resistencia extraña. Está conectada a un mecanismo — abrirla alerta a todos los que esperan dentro.', casillas:'Tu casilla actual', fx:{ico:'&#9888;&#65039;',txt:'Abrir = alerta inmediata al interior'}, _sets:{hasTrap:true}};
      }
      if(z.isSafe){
        return {res:'Puerta normal, sin peligro', det:'Simple madera reforzada. Sin cerradura ni trampa. Puedes abrirla sin hacer ruido.', casillas:'Tu casilla actual', fx:null, _sets:{}};
      }
      if(z.hasEnemies){
        return {res:'Oyes movimiento al otro lado', det:'La puerta vibra levemente. Hay alguien muy cerca del otro lado. Te oirán al abrirla.', casillas:'Tu casilla actual', fx:{ico:'&#128121;',txt:'Enemigo adyacente al otro lado de la puerta'}, _sets:{}};
      }
      // Default
      const roll = rollDice(6);
      if(roll<=2) return {res:'Puerta normal',                  det:'Madera reforzada. Sin trampa ni cerradura especial.', casillas:'Tu casilla actual', fx:null, _sets:{}};
      if(roll<=3) return {res:'Puerta cerrada con llave',       det:'Cerradura de hierro. Necesitas llave o fuerza (4+ en 1D6, hace ruido).', casillas:'Tu casilla actual', fx:{ico:'&#128285;',txt:'Llave o fuerza (4+) para abrir'}, _sets:{}};
      if(roll<=4) return {res:'Trampa en la puerta',            det:'Mecanismo trucado. Al abrir sin cuidado: 1D4 daño al abridor.', casillas:'Tu casilla actual', fx:{ico:'&#9888;&#65039;',txt:'Trampa — 1D4 daño si no se detecta'}, _sets:{hasTrap:true}};
      if(roll<=5) return {res:'Puerta entreabierta',            det:'Ya está abierta una rendija. Puedes ver el borde de la sala sin activar nada.', casillas:'Tu casilla actual', fx:{ico:'&#128064;',txt:'+1 consulta oráculo en sala — puerta entreabierta'}, _sets:{hasSecret:true}};
      return           {res:'Puerta reforzada mágicamente',    det:'Runas de bloqueo en los bordes. Solo el Mago puede abrirla (1 MP, 1 acción).', casillas:'Tu casilla actual', fx:{ico:'&#128302;',txt:'Magia requerida — Mago 1 MP'}, _sets:{}};
    }
  },
];

// ── ROOM QUESTIONS (4 questions, coherence-aware) ─────────────────────────────
const ROOM_Qs = [
  {
    id:'inspeccionar', ico:'&#128064;', lbl:'Inspecciono la sala', hint:'Al entrar — visión general',
    resolve: function(zk, room){
      const z = getZoneState(zk);
      const hasEnemies = room && room.content.enemies.length > 0;
      const hasTraps   = room && room.content.traps.length > 0;
      const hasLoot    = room && room.content.loots.length > 0;

      // Set base state from actual room contents (always first question)
      setZoneState(zk, {
        hasEnemies: hasEnemies,
        hasTrap:    hasTraps,
        hasLoot:    hasLoot,
        inspected:  true,
      });

      if(hasEnemies && hasTraps){
        return {res:'Sala peligrosa', det:'A primera vista: presencias enemigas en el interior Y el suelo parece irregular en una zona. Doble amenaza.', casillas:'Enemigos visibles. Trampa en zona central.', fx:{ico:'&#9760;&#65039;',txt:'Enemigos + trampa — actúa con cuidado'}, _sets:{}};
      }
      if(hasEnemies){
        const count = room.content.enemies.length;
        return {res: count>2 ? 'Sala con múltiples amenazas' : 'Presencias enemigas', det: count>2 ? 'Más de dos figuras se mueven en la sala. Se coordinan — llevan tiempo aquí.' : 'Una o dos figuras se mueven en la penumbra. Aún no os han visto.', casillas:'Distribuidos por la sala', fx:{ico:'&#128121;',txt:count+' enemigo'+(count!==1?'s':'')+' — '+( count>2?'sala vigilada':'ventaja de sorpresa posible')}, _sets:{}};
      }
      if(hasTraps){
        return {res:'Algo no cuadra en el suelo', det:'El pavimento brilla distinto en una zona. Podría ser una trampa de presión. Avanza con cautela.', casillas:'Zona central de la sala', fx:{ico:'&#9888;&#65039;',txt:'Posible trampa — no pises el centro'}, _sets:{}};
      }
      if(hasLoot){
        return {res:'Sala aparentemente vacía', det:'Sin enemigos visibles. Pero en una esquina hay algo que sobresale bajo una tela. Quizá vale la pena explorar.', casillas:'Esquina opuesta', fx:{ico:'&#128176;',txt:'Objeto visible — sala segura'}, _sets:{isSafe:true}};
      }
      return {res:'Sala sin nada aparente', det:'Polvo, silencio y piedra. Lo que ves es lo que hay.', casillas:'Toda la sala', fx:null, _sets:{isSafe:true}};
    }
  },
  {
    id:'buscar', ico:'&#128270;', lbl:'Busco objetos ocultos', hint:'Búsqueda activa — 1 acción',
    resolve: function(zk, room){
      const z = getZoneState(zk);
      // If we already know enemies are here, warn
      if(z.hasEnemies && !z.inspected){
        return {res:'Imposible buscar — hay enemigos', det:'No puedes registrar la sala con amenazas activas. Primero ocúpate de los enemigos.', casillas:null, fx:{ico:'&#9876;&#65039;',txt:'Derrota a los enemigos antes de buscar'}, _sets:{}};
      }
      // If we already found loot from inspection, confirm it
      if(z.hasLoot){
        const roll = rollDice(6);
        if(roll>=4) return {res:'Objeto confirmado', det:'La tela en la esquina cubre exactamente lo que esperabas: un cofre o bolsa con contenido real.', casillas:'Esquina opuesta, 3-4 casillas', fx:{ico:'&#128176;',txt:'Botín — '+(roll>=5?'más de lo esperado':'tal como parecía')}, _sets:{}};
        return {res:'El objeto resultó ser basura', det:'Bajo la tela: trapos rotos y una vasija vacía. La promesa era mayor que la realidad.', casillas:null, fx:null, _sets:{hasLoot:false}};
      }
      if(z.isSafe){
        const roll = rollDice(6);
        if(roll<=3) return {res:'Nada oculto', det:'Registráis cada rincón a fondo. Paredes sólidas, suelo firme.', casillas:null, fx:null, _sets:{}};
        if(roll<=4) return {res:'Monedas en el suelo', det:'Unas pocas monedas dispersas, olvidadas por alguien que pasó aquí antes.', casillas:'Zona norte, 2-3 casillas', fx:{ico:'&#128176;',txt:'+1D6x5 oros — suelo zona norte'}, _sets:{hasLoot:true}};
        if(roll<=5) return {res:'Panel suelto en la pared', det:'Una piedra se mueve al presionarla. Detrás: una cavidad con algo dentro.', casillas:'Pared norte, en tu alcance', fx:{ico:'&#128285;',txt:'Compartimento oculto — pared norte'}, _sets:{hasSecret:true}};
        return {res:'Altar oculto tras un tapiz', det:'Un altar antiguo con una ofrenda intacta. Emana energía mágica residual.', casillas:'Pared sur, 4-5 casillas', fx:{ico:'&#128302;',txt:'+1 MP al activarlo — pared sur'}, _sets:{hasLoot:true}};
      }
      return {res:'Demasiado peligroso para buscar ahora', det:'Con la situación actual en la sala, una búsqueda cuidadosa no es posible. Primero asegura el perímetro.', casillas:null, fx:null, _sets:{}};
    }
  },
  {
    id:'magia', ico:'&#10024;', lbl:'Siento magia en la sala', hint:'Solo Mago o Elfo',
    resolve: function(zk, room){
      const z = getZoneState(zk);
      // Coherence with room type
      const rt = room && room.roomType ? room.roomType.type : 'combat';

      if(rt==='shrine'){
        return {res:'Energía sagrada intensa', det:'Este lugar fue un santuario. La energía es pura y antigua. El Mago recupera 2 MP al acercarse al altar.', casillas:'Todo el radio de la sala', fx:{ico:'&#10024;',txt:'+2 MP al Mago/Elfo — sala sagrada'}, _sets:{hasMagic:true}};
      }
      if(z.hasEnemies && rt==='combat'){
        return {res:'Energía hostil detectada', det:'Los enemigos de esta sala no son ordinarios. Alguno porta un objeto encantado o tiene origen mágico.', casillas:'En los enemigos visibles', fx:{ico:'&#9889;',txt:'Enemigo con objeto o habilidad mágica'}, _sets:{hasMagic:true}};
      }
      if(z.hasTrap){
        return {res:'Trampa mágica confirmada', det:'La anomalía que detectaste antes tiene origen arcano. No es mecánica — es una runa activada.', casillas:'Centro de la sala, 2-3 casillas', fx:{ico:'&#9889;',txt:'Trampa runa — solo magia puede desactivarla'}, _sets:{hasMagic:true}};
      }
      if(z.isSafe){
        const roll = rollDice(6);
        if(roll<=3) return {res:'Sin magia detectable', det:'La sala está muerta mágicamente. Los hechizos costarán +1 MP mientras estéis aquí.', casillas:'Toda la sala', fx:{ico:'&#128683;',txt:'Zona árida — hechizos +1 MP'}, _sets:{hasMagic:false}};
        return {res:'Nexo de energía arcana', det:'Un punto de concentración de poder en el centro. Mago y Elfo recuperan 2 MP al estar en radio de 2 casillas.', casillas:'Radio 2 casillas del centro', fx:{ico:'&#10024;',txt:'+2 MP Mago/Elfo — radio 2 casillas del nexo'}, _sets:{hasMagic:true}};
      }
      return {res:'Residuos mágicos recientes', det:'Alguien usó magia potente aquí hace poco. Los rastros se disipan pero son rastreables.', casillas:'Zona central', fx:{ico:'&#128302;',txt:'Rastro mágico — útil para identificar origen'}, _sets:{hasMagic:true}};
    }
  },
  {
    id:'alguien', ico:'&#128172;', lbl:'¿Hay alguien vivo aquí?', hint:'Al explorar zona con presencia',
    resolve: function(zk, room){
      const z = getZoneState(zk);
      const hasPNJ = room && room.content.pnjData;

      // Coherence: if we know enemies are here, can't also have a neutral PNJ free
      if(z.hasEnemies && !hasPNJ){
        return {res:'Solo enemigos — ningún aliado', det:'Lo que hay en esta sala no son amigos. Los que encontraste antes lo confirman.', casillas:null, fx:null, _sets:{}};
      }
      if(hasPNJ){
        const pnj = room.content.pnjData;
        return {res:'Alguien vivo: '+pnj.nm, det:pnj.desc, casillas:'En la sala — busca el icono en el grid', fx:{ico:pnj.ico,txt:pnj.nm+' — '+pnj.reward}, _sets:{hasPNJ:true}};
      }
      if(z.isSafe){
        return {res:'Completamente vacía', det:'No hay nadie. Esta sala lleva tiempo abandonada. Ni siquiera hay rastros recientes.', casillas:null, fx:null, _sets:{}};
      }
      // Random
      const roll = rollDice(6);
      if(roll<=2) return {res:'Solo amenazas — nadie más', det:'Quien hay aquí no tiene buenas intenciones. No hay inocentes.', casillas:null, fx:null, _sets:{}};
      if(roll<=3) return {res:'Prisionero encadenado', det:'En la pared norte, alguien encadenado. Vivo pero en shock. Puede dar información si se le ayuda.', casillas:'Pared norte, 4-5 casillas', fx:{ico:'&#128532;',txt:'Prisionero — información a cambio de ayuda'}, _sets:{hasPNJ:true}};
      if(roll<=4) return {res:'Mercenario herido', det:'En una esquina. Herido pero combativo. Podría ayudar por curación o dinero.', casillas:'Esquina SO, 5-6 casillas', fx:{ico:'&#129454;',txt:'Mercenario — aliado por 30 oros o 1 poción'}, _sets:{hasPNJ:true}};
      if(roll<=5) return {res:'Comerciante perdido', det:'Un buhonero con su bolsa de cuero. Asustado pero con mercancía útil.', casillas:'Centro de la sala, 3-4 casillas', fx:{ico:'&#128717;',txt:'Mercader — pociones y objetos disponibles'}, _sets:{hasPNJ:true}};
      return {res:'Aliado con información valiosa', det:'Un aventurero que lleva días aquí. Conoce el camino al jefe y la distribución de las salas restantes.', casillas:'Centro-sur, 4 casillas', fx:{ico:'&#128302;',txt:'Aliado con mapa del dungeon completo'}, _sets:{hasPNJ:true}};
    }
  },
];

function renderCorridorOracle(pos, dg){
  const zk = 'cor_'+(pos<0?0:pos);
  let html = '<div style="display:flex;flex-direction:column;gap:7px">';
  CORRIDOR_Qs.forEach((q,qi)=>{
    const key  = zk+'_q'+qi;
    const used = (oracleLog||[]).some(l=>l.includes('['+key+']'));
    html += '<button onclick="askDgOracle('+qi+',\'corridor\',\''+key+'\',\''+zk+'\')" style="'
      + 'width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.2);'
      + 'border-radius:4px;padding:11px 13px;display:flex;align-items:center;gap:10px;'
      + 'cursor:pointer;touch-action:manipulation;text-align:left;opacity:'+(used?.65:1)+'">'
      + '<span style="font-size:20px">'+q.ico+'</span>'
      + '<div style="flex:1">'
      + '<div style="font-family:\'Cinzel\',serif;font-size:13px;color:var(--pa)">'+q.lbl+'</div>'
      + '<div style="font-size:11px;color:var(--stl);font-style:italic;margin-top:2px">'+q.hint+'</div>'
      + '</div>'
      + (used ? '<span style="font-size:10px;color:var(--god);font-family:Cinzel,serif;border:1px solid rgba(201,150,42,.2);border-radius:2px;padding:1px 5px">YA CONSULTADO</span>' : '<span style="color:var(--god);font-size:18px">&#8250;</span>')
      + '</button>';
  });
  html += '</div>';
  return html;
}

function askDgOracle(qIdx, zone, key, zk){
  const qs = zone==='corridor' ? CORRIDOR_Qs : ROOM_Qs;
  const q  = qs[qIdx];
  if(!q) return;

  // Get current room for room questions
  const pos  = dg ? dg.currentPos : -1;
  const room = (zone==='room' && pos>=0) ? dg.rooms[pos] : null;

  // Resolve with coherence
  const result = zone==='corridor'
    ? q.resolve(zk)
    : q.resolve(zk, room);

  // Apply zone state updates from result
  if(result._sets && Object.keys(result._sets).length){
    setZoneState(zk, result._sets);
  }

  const roll = rollDice(6); // for display only (result is already determined)
  const col  = result.fx ? 'var(--go)' : (result._sets && Object.keys(result._sets).some(k=>zoneStates[zk]&&zoneStates[zk][k]&&['hasEnemies','isAmbush','hasTrap'].includes(k))) ? 'var(--bl)' : 'var(--pad)';

  const casillasHtml = result.casillas
    ? '<div style="font-family:Cinzel,serif;font-size:11px;font-weight:700;color:var(--go);padding:4px 10px;background:rgba(201,150,42,.12);border:1px solid rgba(201,150,42,.3);border-radius:3px;margin-top:8px;display:inline-block">&#128205; '+result.casillas+'</div>'
    : '';

  const fxHtml = result.fx
    ? '<div style="display:flex;align-items:center;gap:12px;margin-top:12px;padding:11px 13px;background:rgba(0,0,0,.4);border-radius:4px;border:1px solid rgba(201,150,42,.2)">'
      + '<span style="font-size:24px">'+result.fx.ico+'</span>'
      + '<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa)">'+result.fx.txt+'</span>'
      + '</div>'
    : '';

  // Zone state summary (what oracle now knows)
  const z = getZoneState(zk);
  const knownItems = [];
  if(z.hasEnemies) knownItems.push('&#128121; Enemigos confirmados');
  if(z.isAmbush)   knownItems.push('&#128128; Emboscada activa');
  if(z.hasTrap)    knownItems.push('&#9888;&#65039; Trampa detectada');
  if(z.hasSecret)  knownItems.push('&#128285; Secreto conocido');
  if(z.isSafe)     knownItems.push('&#10003; Zona segura');
  if(z.hasPNJ)     knownItems.push('&#128172; PNJ presente');
  if(z.hasMagic)   knownItems.push('&#10024; Magia detectada');
  const knownHtml = knownItems.length
    ? '<div style="margin-top:10px;padding:8px 10px;background:rgba(0,0,0,.3);border-radius:4px;border-top:1px solid rgba(255,255,255,.06)">'
      + '<div style="font-family:Cinzel,serif;font-size:9px;letter-spacing:1px;color:var(--god);margin-bottom:5px">EL ORÁCULO SABE DE ESTA ZONA:</div>'
      + knownItems.map(i=>'<span style="font-size:11px;color:var(--stl);margin-right:10px">'+i+'</span>').join('')
      + '</div>'
    : '';

  const old = document.getElementById('dg-oracle-popup');
  if(old) old.remove();

  const popup = document.createElement('div');
  popup.id = 'dg-oracle-popup';
  popup.style.cssText = 'position:fixed;inset:0;z-index:3000;background:rgba(0,0,0,.88);display:flex;align-items:center;justify-content:center;padding:20px;animation:fIn .2s ease';

  popup.innerHTML =
    '<div style="background:linear-gradient(160deg,#1e1810,#100c06);border:2px solid '+col+';border-radius:10px;width:100%;max-width:400px;max-height:88vh;overflow-y:auto;box-shadow:0 0 50px rgba(0,0,0,.95)">'

    + '<div style="background:rgba(0,0,0,.5);padding:13px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid '+col+'44">'
    + '<div style="display:flex;align-items:center;gap:8px">'
    + '<span style="font-size:20px">'+q.ico+'</span>'
    + '<span style="font-family:Cinzel,serif;font-size:12px;color:var(--god);letter-spacing:1px">'+q.lbl+'</span>'
    + '</div>'
    + '<button onclick="document.getElementById(\'dg-oracle-popup\').remove()" style="background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:30px;height:30px;color:var(--stl);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;touch-action:manipulation">&#10005;</button>'
    + '</div>'

    + '<div style="padding:16px 18px 8px;text-align:center">'
    + '<div style="font-family:Cinzel,serif;font-size:20px;font-weight:700;color:'+col+';line-height:1.3;margin-bottom:8px">'+result.res+'</div>'
    + '</div>'

    + '<div style="padding:0 18px 14px">'
    + '<div style="font-size:14px;color:var(--pad);line-height:1.75;font-style:italic;border-top:1px solid rgba(255,255,255,.07);padding-top:12px">'+result.det+'</div>'
    + casillasHtml
    + fxHtml
    + knownHtml
    + '</div>'

    + '<div style="padding:12px 16px 16px;display:grid;grid-template-columns:1fr;gap:10px;border-top:1px solid rgba(255,255,255,.07)">'
    + '<button onclick="document.getElementById(\'dg-oracle-popup\').remove()" style="background:linear-gradient(135deg,var(--grd),#1a3010);border:1px solid var(--grd);border-radius:4px;color:var(--gr);font-family:Cinzel,serif;font-size:12px;letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">&#10003; Anotado — continuar</button>'
    + '</div>'
    + '</div>';

  popup.addEventListener('click', e=>{ if(e.target===popup) popup.remove(); });
  document.documentElement.appendChild(popup);

  // Log
  const logEntry = q.ico+' <strong style="color:'+col+'">'+result.res+'</strong> — '+q.lbl+' ['+key+']';
  oracleLog.unshift(logEntry);
  if(oracleLog.length>20) oracleLog.pop();
  if(sk) sk.oracleLog = oracleLog;

  // Track used queries
  if(dg && !oracleLog.slice(1).some(l=>l.includes('['+key+']'))){
    const pos2 = dg.currentPos;
    const zone2 = dg.currentZone;
    if(zone2==='corridor'){
      const ci = pos2 < 0 ? 0 : pos2;
      const rm = dg.rooms[Math.min(ci,9)];
      if(rm && rm.corridorContent) rm.corridorContent.usedQueries=(rm.corridorContent.usedQueries||0)+1;
    } else {
      const rm = pos2>=0 ? dg.rooms[pos2] : null;
      if(rm) rm.usedRoomQueries=(rm.usedRoomQueries||0)+1;
    }
    if(sk) sk.dg = dg;
  }
  saveS();
  renderSk();
  document.documentElement.appendChild(popup);
}




function renderRoomView(room,dg){
  const content=room.content;
  const size=content.size;
  const isBoss=content.isBoss;
  const rt=room.roomType||{type:'combat',label:'Sala de Combate',ico:'&#9876;&#65039;'};
  const gridHtml=renderRoomGrid(content,size,room.idx);
  const maxQ=room.maxRoomQueries||3;
  const usedQ=Math.min(room.usedRoomQueries||0,maxQ);
  const remaining=Math.max(0,maxQ-usedQ);
  const d=DIFFICULTY[dg.difficulty]||DIFFICULTY.medio;
  const enemyCards=renderEnemyCards(content.enemies,'rm'+room.idx);

  // PNJ block
  let pnjHtml='';
  if(content.pnjData){
    const pnj=content.pnjData;
    pnjHtml='<div style="background:rgba(74,128,212,.08);border:1px solid rgba(74,128,212,.3);border-radius:6px;padding:12px 14px;margin-bottom:12px">'
      +'<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">'
      +'<span style="font-size:30px">'+pnj.ico+'</span>'
      +'<div><div style="font-family:Cinzel,serif;font-size:13px;color:var(--mg);font-weight:700">'+pnj.nm+'</div>'
      +'<div style="font-size:11px;color:var(--stl);text-transform:uppercase;letter-spacing:1px">'+pnj.type+'</div>'
      +'</div></div>'
      +'<div style="font-size:13px;color:var(--pad);font-style:italic;line-height:1.6;margin-bottom:8px">'+pnj.desc+'</div>'
      +'<div style="font-size:12px;color:var(--go);background:rgba(0,0,0,.3);border-radius:3px;padding:7px 10px">&#127919; '+pnj.reward+'</div>'
      +(pnj.stock?'<div style="margin-top:10px"><div style="font-family:Cinzel,serif;font-size:9px;letter-spacing:2px;color:var(--god);margin-bottom:6px">INVENTARIO DEL MERCADER</div>'
        +pnj.stock.map(s=>'<div style="display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid rgba(255,255,255,.05)">'
          +'<span style="font-size:16px">'+s.ico+'</span>'
          +'<div style="flex:1"><div style="font-size:12px;color:var(--pa)">'+s.nm+'</div><div style="font-size:11px;color:var(--stl);font-style:italic">'+s.desc+'</div></div>'
          +'<div style="font-family:Cinzel,serif;font-size:13px;color:var(--go)">'+s.price+' oros</div>'
          +'</div>').join('')+'</div>':'')
      +'</div>';
  }

  // Narrative block
  let narrativeHtml='';
  if(content.narrativeEvent){
    const ne=content.narrativeEvent;
    narrativeHtml='<div style="background:rgba(128,74,212,.1);border:2px solid rgba(128,74,212,.4);border-radius:6px;padding:14px;margin-bottom:12px;text-align:center">'
      +'<div style="font-size:36px;margin-bottom:8px">'+ne.ico+'</div>'
      +'<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:2px;color:var(--pul);margin-bottom:8px">MOMENTO DE HISTORIA</div>'
      +'<div style="font-size:14px;color:var(--pad);font-style:italic;line-height:1.7">'+ne.txt+'</div>'
      +'</div>';
  }

  // Oracle questions — coherence-aware
  const zk='rm_'+room.idx;
  const oracleHtml='<div style="display:flex;flex-direction:column;gap:7px">'
    +ROOM_Qs.map((q,qi)=>{
      const key=zk+'_q'+qi;
      const used=(oracleLog||[]).some(l=>l.includes('['+key+']'));
      return '<button onclick="askDgOracle('+qi+',\'room\',\''+key+'\',\''+zk+'\')" style="'
        +'width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(201,150,42,.2);'
        +'border-radius:4px;padding:11px 13px;display:flex;align-items:center;gap:10px;'
        +'cursor:pointer;touch-action:manipulation;text-align:left;opacity:'+(used?.65:1)+'">'
        +'<span style="font-size:20px">'+q.ico+'</span>'
        +'<div style="flex:1">'
        +'<div style="font-family:Cinzel,serif;font-size:13px;color:var(--pa)">'+q.lbl+'</div>'
        +'<div style="font-size:11px;color:var(--stl);font-style:italic;margin-top:2px">'+q.hint+'</div>'
        +'</div>'
        +(used?'<span style="font-size:10px;color:var(--god);font-family:Cinzel,serif;border:1px solid rgba(201,150,42,.2);border-radius:2px;padding:1px 5px">YA CONSULTADO</span>':'<span style="color:var(--god);font-size:18px">&#8250;</span>')
        +'</button>';
    }).join('')+'</div>';

  return '<div style="background:linear-gradient(135deg,#1a1208,#0d0a07);border:1px solid rgba(201,150,42,.3);border-radius:6px;overflow:hidden;margin-bottom:12px">'
    +'<div style="padding:11px 14px;background:rgba(0,0,0,.4);border-bottom:1px solid rgba(201,150,42,.15);display:flex;align-items:center;gap:10px">'
    +'<span style="font-size:22px">'+(isBoss?'&#128128;':rt.ico)+'</span>'
    +'<div style="flex:1">'
    +'<div style="font-family:Cinzel,serif;font-size:13px;color:'+(isBoss?'var(--bl)':'var(--go)')+'">SALA '+(room.idx+1)+' / 10 — '+(isBoss?'JEFE DE MAZMORRA':rt.label)+'</div>'
    +'<div style="font-size:11px;color:var(--stl)">'+size.label+' — '+size.w+'x'+size.h+' casillas</div>'
    +'</div>'
    +'<span style="font-size:13px;color:'+d.col+';font-family:Cinzel,serif;border:1px solid '+d.col+';border-radius:3px;padding:2px 7px">'+d.label+'</span>'
    +'</div>'
    +'<div style="padding:12px 14px">'
    +gridHtml
    +narrativeHtml
    +enemyCards
    +pnjHtml
    +qLimitBar(usedQ,maxQ)
    +(remaining>0
      ?('<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--god);margin-bottom:8px">&#128302; CONSULTAR ORACULO</div>'+oracleHtml)
      :'<div style="font-family:Cinzel,serif;font-size:12px;color:var(--stl);text-align:center;padding:10px;font-style:italic">Sin más consultas en esta sala.</div>'
    )
    +renderInlineD20(room)
    +'</div></div>';
}

function renderRoomGrid(content,size,roomIdx){
  const CELL=34;
  const grid=Array.from({length:size.h},()=>Array(size.w).fill(null));
  (content.enemies||[]).forEach(e=>{ if(e.y<size.h&&e.x<size.w) grid[e.y][e.x]={type:'enemy',data:e}; });
  (content.traps||[]).forEach(t=>{   if(t.y<size.h&&t.x<size.w) grid[t.y][t.x]={type:'trap', data:t}; });
  (content.loots||[]).forEach(l=>{   if(l.y<size.h&&l.x<size.w) grid[l.y][l.x]={type:'loot', data:l}; });
  (content.furniture||[]).forEach(f=>{ if(f.y<size.h&&f.x<size.w&&!grid[f.y][f.x]) grid[f.y][f.x]={type:'furniture',data:f}; });
  const midRow=Math.floor(size.h/2);
  let tbl='<div style="overflow-x:auto;margin-bottom:8px"><table style="border-collapse:collapse;margin:0 auto">';
  for(let r=0;r<size.h;r++){
    tbl+='<tr>';
    for(let c=0;c<size.w;c++){
      const cell=grid[r][c];
      let bg='rgba(18,12,6,.92)',border='1px solid rgba(201,150,42,.1)',inner='',title='';
      if(r===midRow&&c===0)       inner='<span style="font-size:10px;color:rgba(201,150,42,.4)">&#9654;</span>';
      if(r===midRow&&c===size.w-1) inner='<span style="font-size:10px;color:rgba(201,150,42,.4)">&#9654;</span>';
      if(cell){
        if(cell.type==='enemy'){bg=cell.data.id==='boss'?'rgba(100,10,10,.85)':'rgba(70,15,15,.8)';border='1px solid rgba(139,26,26,.6)';inner='<span title="'+cell.data.nm+'" style="font-size:17px;cursor:default">'+cell.data.ico+'</span>';title=cell.data.nm;}
        else if(cell.type==='trap'){bg='rgba(40,30,8,.85)';border='1px solid rgba(201,150,42,.4)';inner='<span style="font-size:13px;cursor:default">&#9888;&#65039;</span>';title=cell.data.nm;}
        else if(cell.type==='loot'){bg='rgba(8,30,8,.85)';border='1px solid rgba(90,176,90,.35)';inner='<span style="font-size:15px;cursor:default">'+cell.data.ico+'</span>';title=cell.data.nm;}
        else if(cell.type==='furniture'){bg='rgba(30,20,10,.7)';border='1px solid rgba(100,80,40,.3)';inner='<span style="font-size:14px;cursor:default;opacity:.85">'+cell.data.ico+'</span>';title=cell.data.nm;}
      }
      tbl+='<td style="width:'+CELL+'px;height:'+CELL+'px;background:'+bg+';border:'+border+';text-align:center;vertical-align:middle" title="'+title+'">'+inner+'</td>';
    }
    tbl+='</tr>';
  }
  tbl+='</table></div>';
  const furnList=(content.furniture||[]);
  const legend='<div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;padding:6px 0;border-top:1px solid rgba(201,150,42,.08);border-bottom:1px solid rgba(201,150,42,.08)">'
    +(content.enemies.length?'<span style="font-size:11px;color:var(--stl);display:flex;align-items:center;gap:3px"><span style="background:rgba(70,15,15,.8);padding:1px 4px;border-radius:2px;font-size:13px">&#128121;</span>Enemigo</span>':'')
    +(content.traps.length?'<span style="font-size:11px;color:var(--stl);display:flex;align-items:center;gap:3px"><span style="background:rgba(40,30,8,.85);padding:1px 4px;border-radius:2px;font-size:12px">&#9888;&#65039;</span>Trampa</span>':'')
    +(content.loots.length?'<span style="font-size:11px;color:var(--stl);display:flex;align-items:center;gap:3px"><span style="background:rgba(8,30,8,.85);padding:1px 4px;border-radius:2px;font-size:13px">'+content.loots[0].ico+'</span>Botín</span>':'')
    +(furnList.length?furnList.map(f=>'<span style="font-size:11px;color:var(--stl);display:flex;align-items:center;gap:3px"><span style="font-size:13px">'+f.ico+'</span>'+f.nm+'</span>').join(''):'')
    +'</div>';
  return tbl+legend;
}

function renderNavButtons(pos, zone, dg){
  const atBoss = pos===9 && zone==='room';
  let html = '<div style="display:grid;gap:8px;margin-top:4px">';
  if(zone==='corridor'){
    const nextRoomIdx = pos+1;
    if(nextRoomIdx < 10){
      html += '<button onclick="enterRoom('+(pos+1)+')" style="background:linear-gradient(135deg,#2a1e0a,#1a1208);border:2px solid var(--go);border-radius:5px;color:var(--go);font-family:Cinzel,serif;font-size:13px;font-weight:700;letter-spacing:1px;padding:14px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center;gap:10px"><span style="font-size:20px">&#127968;</span>ENTRAR EN SALA '+(pos+2)+' / 10</button>';
    }
  } else if(zone==='room'){
    if(!atBoss){
      html += '<button onclick="exitRoom('+pos+')" style="background:linear-gradient(135deg,#1a2a1a,#0a180a);border:2px solid var(--gr);border-radius:5px;color:var(--gr);font-family:Cinzel,serif;font-size:13px;font-weight:700;letter-spacing:1px;padding:14px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center;gap:10px"><span style="font-size:20px">&#9135;&#65039;</span>AVANZAR AL SIGUIENTE PASILLO</button>';
    } else {
      html += '<button onclick="victoryScreen()" style="background:linear-gradient(135deg,var(--bl),var(--bld));border:2px solid var(--bl);border-radius:5px;color:var(--pa);font-family:Cinzel,serif;font-size:14px;font-weight:700;letter-spacing:2px;padding:15px;cursor:pointer;touch-action:manipulation;display:flex;align-items:center;justify-content:center;gap:10px"><span style="font-size:22px">&#11088;</span>FINALIZAR MISION</button>';
    }
  }
  html += '</div>';
  return html;
}

function enterRoom(roomIdx){
  if(!dg||roomIdx<0||roomIdx>9) return;
  dg.rooms[roomIdx].state='revealed';
  dg.currentPos=roomIdx; dg.currentZone='room';
  sk.dg=dg; saveS(); renderSk();
  document.getElementById('skcon').scrollTop=0;
}

function exitRoom(roomIdx){
  if(!dg) return;
  dg.rooms[roomIdx].state='cleared';
  dg.currentPos=roomIdx; dg.currentZone='corridor';
  sk.dg=dg; saveS(); renderSk();
  document.getElementById('skcon').scrollTop=0;
}



function renderMazo(){
  const c=document.getElementById('mazocon');
  if(!c) return;

  if(!dg){
    c.innerHTML='<div style="padding:40px 20px;text-align:center">'
      +'<div style="font-size:64px;margin-bottom:16px;opacity:.35">&#127922;</div>'
      +'<div style="font-family:Cinzel,serif;font-size:15px;color:var(--god);letter-spacing:2px;margin-bottom:10px">SIN ESCARAMUZA ACTIVA</div>'
      +'<div style="font-size:14px;color:var(--stl);font-style:italic;line-height:1.8">Inicia una escaramuza para generar<br>las tablas D20 de cada sala.</div>'
      +'</div>';
    return;
  }

  const lore=dg.lore;
  let html2='<div style="padding:14px 14px 80px">'
    +'<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:2px;color:var(--god);text-align:center;padding:10px 0 14px">&#127922; TABLAS D20 — '+lore.tl.toUpperCase()+'</div>';

  dg.rooms.forEach((room,ri2)=>{
    if(room.state==='hidden') return; // only show revealed rooms
    const rt=room.roomType||{type:'combat',label:'Sala de Combate',ico:'&#9876;&#65039;'};
    const table=room.content.d20Table||[];
    const resultId='mazo-res-'+ri2;
    const hlId='mazo-hl-'+ri2;

    html2+='<div class="mazo-card">'
      +'<div class="mazo-card-header">'
      +'<div>'
      +'<div class="mazo-card-title">'+rt.ico+' SALA '+(ri2+1)+' — '+rt.label+'</div>'
      +'<div class="mazo-card-sub">Tabla D20 de eventos interactuables</div>'
      +'</div>'
      +'<div style="display:flex;align-items:center;gap:10px">'
      +'<span class="d20-result" id="'+resultId+'">—</span>'
      +'<button class="d20-roll-btn" onclick="rollMazoD20('+ri2+')">&#127922; D20</button>'
      +'</div>'
      +'</div>'
      +'<div style="overflow-x:auto"><table class="d20-table"><thead><tr><th>&#127922;</th><th>RESULTADO</th></tr></thead>'
      +'<tbody id="'+hlId+'">'
      +table.map(row=>'<tr id="mzr-'+ri2+'-'+row[0]+'"><td>'+row[0]+'</td><td>'+row[1]+'</td></tr>').join('')
      +'</tbody></table></div>'
      +'</div>';
  });

  // If no rooms revealed yet
  if(!dg.rooms.some(r=>r.state!=='hidden')){
    html2+='<div style="text-align:center;padding:20px;font-size:13px;color:var(--stl);font-style:italic">Explora salas para desbloquear sus tablas D20 aqui.</div>';
  }

  html2+='</div>';
  c.innerHTML=html2;
}

function rollMazoD20(roomIdx){
  const roll=Math.floor(Math.random()*20)+1;
  const el=document.getElementById('mazo-res-'+roomIdx);
  if(el){ el.classList.remove('rolling'); void el.offsetWidth; el.textContent=roll; el.classList.add('rolling'); }
  const tbody=document.getElementById('mazo-hl-'+roomIdx);
  if(tbody){
    tbody.querySelectorAll('tr').forEach(r=>{ r.style.background=''; r.style.color=''; });
    const target=document.getElementById('mzr-'+roomIdx+'-'+roll);
    if(target){ target.style.background='rgba(201,150,42,.18)'; target.style.color='var(--go)';
      setTimeout(()=>target.scrollIntoView({behavior:'smooth',block:'nearest'}),150); }
  }
}


function showCondition(tagName){
  const cond = CONDITIONS[tagName];
  if(!cond) return;
  const old = document.getElementById('cond-overlay');
  if(old) old.remove();

  const typeColor = cond.type==='BONIFICACION' ? 'var(--gr)' : 'var(--bl)';
  const typeBg    = cond.type==='BONIFICACION' ? 'rgba(42,90,42,.3)' : 'rgba(139,26,26,.3)';

  const rulesHtml = (cond.rules||[]).map(r=>
    '<div class="cond-rule">'
    + '<span class="cond-rule-ico">'+r.ico+'</span>'
    + '<span class="cond-rule-txt">'+r.txt+'</span>'
    + '</div>'
  ).join('');

  const el = document.createElement('div');
  el.id = 'cond-overlay';
  el.className = 'cond-overlay';
  el.innerHTML =
    '<div class="cond-popup">'
    + '<div class="cond-header" style="border-bottom:2px solid '+cond.col+'">'
    + '<div style="display:flex;align-items:center;gap:12px">'
    + '<span style="font-size:38px">'+cond.ico+'</span>'
    + '<div>'
    + '<div class="cond-name" style="color:'+cond.col+'">'+tagName+'</div>'
    + '<div class="cond-type" style="color:'+typeColor+';background:'+typeBg+';padding:2px 8px;border-radius:3px;display:inline-block;margin-top:3px">'+cond.type+'</div>'
    + '</div>'
    + '</div>'
    + '</div>'
    + '<div class="cond-body">'
    + '<div class="cond-effect">'+cond.effect+'</div>'
    + '<div class="cond-rules">'+rulesHtml+'</div>'
    + '<button class="cond-close" onclick="document.getElementById(\'cond-overlay\').remove()">&#10003; Entendido</button>'
    + '</div>'
    + '</div>';

  el.addEventListener('click', function(e){ if(e.target===el) el.remove(); });
  document.documentElement.appendChild(el);
}


