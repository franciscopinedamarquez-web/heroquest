  },
];

function renderGuaridaUpgrades(){
  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
  const purchased = guaridaMejoras || {};

  let html = '<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:3px;color:var(--god);padding:12px 0 10px">&#127981; MEJORAS DE LA GUARIDA</div>'
    + '<div style="font-size:12px;color:var(--stl);font-style:italic;margin-bottom:12px;line-height:1.6">Mejoras permanentes para toda la campaña. Una vez construidas, sus beneficios son para siempre.</div>';

  GUARIDA_UPGRADES.forEach(upg=>{
    const owned   = !!purchased[upg.id];
    const canGold = totalGold >= upg.costGold;
    const canBuy  = !owned && canGold;

    html += '<div style="background:linear-gradient(135deg,'+(owned?'#0d1a0d':'#1a1208')+','+(owned?'#081008':'#0d0a07')+');border:1px solid rgba('+(owned?'42,90,42':'201,150,42')+','+(owned?.4:.18)+');border-radius:8px;overflow:hidden;margin-bottom:10px">'
      // Header
      + '<div style="display:flex;align-items:center;gap:12px;padding:12px 14px;'+(owned?'border-bottom:1px solid rgba(42,90,42,.2)':'')+';">'
      + '<span style="font-size:28px;flex-shrink:0">'+upg.ico+'</span>'
      + '<div style="flex:1">'
      + '<div style="font-family:Cinzel,serif;font-size:13px;color:'+(owned?'var(--gr)':'var(--pa)')+';font-weight:700;margin-bottom:2px">'+upg.nm+'</div>'
      + '<div style="font-size:11px;color:var(--stl);font-style:italic">'+upg.lore+'</div>'
      + '</div>'
      + (owned
        ? '<span style="font-family:Cinzel,serif;font-size:10px;color:var(--gr);border:1px solid var(--grd);border-radius:3px;padding:2px 8px;flex-shrink:0">CONSTRUIDA</span>'
        : '<div style="text-align:right;flex-shrink:0">'
          + '<div style="font-family:Cinzel,serif;font-size:13px;color:'+(canGold?'var(--go)':'var(--bl)')+';font-weight:700">'+upg.costGold+' &#128176;</div>'
          + '</div>'
      )
      + '</div>'
      // Body
      + (owned
        ? '<div style="padding:8px 14px 12px"><div style="font-size:12px;color:var(--gr)">&#10003; '+upg.effect+'</div></div>'
        : '<div style="padding:8px 14px 12px">'
          + '<div style="font-size:12px;color:var(--pad);font-style:italic;margin-bottom:8px">'+upg.desc+'</div>'
          + '<div style="font-size:11px;color:'+(owned?'var(--gr)':'var(--go)')+';background:rgba(0,0,0,.3);border-radius:3px;padding:6px 9px;margin-bottom:8px">&#127919; '+upg.effect+'</div>'
          + '<button onclick="buyGuaridaUpgrade(\''+upg.id+'\')" '+(canBuy?'':'disabled ')
          + 'style="width:100%;background:'+(canBuy?'linear-gradient(135deg,#1a2a0a,#0d1808)':'rgba(0,0,0,.3)')+';border:1px solid '+(canBuy?'var(--grd)':'rgba(255,255,255,.1)')+';border-radius:4px;color:'+(canBuy?'var(--gr)':'var(--stl)')+';font-family:Cinzel,serif;font-size:11px;letter-spacing:1px;padding:10px;cursor:'+(canBuy?'pointer':'not-allowed')+';touch-action:manipulation;">'
          + (canBuy ? '&#9874;&#65039; CONSTRUIR' : 'Sin oros suficientes')
          + '</button>'
          + '</div>'
      )
      + '</div>';
  });

  return html;
}

function buyGuaridaUpgrade(upgradeId){
  const upg = GUARIDA_UPGRADES.find(u=>u.id===upgradeId);
  if(!upg) return;
  if(guaridaMejoras[upgradeId]){ toast('Ya está construida'); return; }

  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
  if(totalGold < upg.costGold){ toast('Sin oros suficientes'); return; }

  // Deduct gold
  let rem = upg.costGold;
  for(const h of heroes){
    const pay = Math.min(rem, h.gold||0);
    h.gold = (h.gold||0) - pay;
    rem -= pay;
    if(rem<=0) break;
  }

  // Mark as owned
  if(!guaridaMejoras) guaridaMejoras = {};
  guaridaMejoras[upgradeId] = true;

  rH(); saveS(); renderGuarida();
  toast(upg.ico+' '+upg.nm+' — ¡construida en la guarida!');
}


