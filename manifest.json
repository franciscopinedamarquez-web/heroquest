    +'</div>'
    +'</div>';
}

function toggleShop(shopId){
  ciudadOpenCard = ciudadOpenCard===shopId ? null : shopId;
  renderCiudad();
}

function buyItem(shopId, itemIdx){
  const shopMap={armeria:ARMERIA_ITEMS,taberna:TABERNA_ITEMS,templo:TEMPLO_ITEMS,gremio:GREMIO_ITEMS,biblioteca:BIBLIOTECA_ITEMS};
  const items=shopMap[shopId];
  if(!items) return;
  const item=items[itemIdx];
  if(!item) return;

  const totalGold=heroes.reduce((s,h)=>s+(h.gold||0),0);
  if(totalGold<item.price){ toast('Sin oros suficientes'); return; }
  if(!heroes.filter(h=>!h.dead).length){ toast('Sin heroes activos'); return; }

  // Items that require choosing a specific hero → show picker popup
  if(item.heroTarget){
    showHeroPickerForItem(shopId, itemIdx, item);
    return;
  }

  // Pay immediately
  _deductGold(item.price);
  _applyItemEffect(item, null);
  rH(); saveS(); renderCiudad();
}

function _deductGold(amount){
  let rem=amount;
  for(const h of heroes){
    const pay=Math.min(rem,h.gold||0);
    h.gold=(h.gold||0)-pay;
    rem-=pay;
    if(rem<=0) break;
  }
}

function _applyItemEffect(item, targetHero){
  // targetHero = specific hero object, or null = apply to all/group
  const targets = targetHero ? [targetHero] : heroes.filter(h=>!h.dead);

  if(item.effect){
    const {stat,val}=item.effect;
    if(stat==='atk'||stat==='def'||stat==='mov'){
      targets.forEach(h=>{ h[stat]=(h[stat]||0)+val; });
      toast(item.ico+' '+item.nm+' — '+(targetHero?targetHero.name:'todos')+': +'+val+' '+stat.toUpperCase());
    } else if(stat==='maxHp'){
      targets.forEach(h=>{ h.maxHp=(h.maxHp||4)+val; h.hp=Math.min((h.hp||0)+val,h.maxHp); });
      toast(item.ico+' '+item.nm+' — '+(targetHero?targetHero.name:'todos')+': +'+val+' HP máx');
    } else if(stat==='maxMp'){
      targets.forEach(h=>{ h.maxMp=(h.maxMp||2)+val; h.mp=Math.min((h.mp||0)+val,h.maxMp); });
      toast(item.ico+' '+item.nm+' — '+(targetHero?targetHero.name:'todos')+': +'+val+' MP máx');
    } else if(stat==='mp'){
      targets.forEach(h=>{ h.mp=Math.min((h.mp||0)+val,h.maxMp||10); });
      toast(item.ico+' '+item.nm+' — MP restaurado');
    }
    return;
  }

  if(item.type==='upgrade'&&item.stat){
    const {stat,val}=item;
    targets.forEach(h=>{
      if(stat==='maxHp'){h.maxHp=(h.maxHp||4)+val;h.hp=Math.min((h.hp||0)+val,h.maxHp);}
      else if(stat==='maxMp'){h.maxMp=(h.maxMp||2)+val;h.mp=Math.min((h.mp||0)+val,h.maxMp);}
      else if(stat==='mp'){h.mp=Math.min((h.mp||0)+val,h.maxMp||10);}
      else if(stat==='atk'||stat==='def'||stat==='mov'){h[stat]=(h[stat]||0)+val;}
    });
    toast(item.ico+' '+item.nm+' — '+(targetHero?targetHero.name:'todos')+' mejorado');
    return;
  }

  if(item.stat&&item.val&&!item.type){
    const {stat,val}=item;
    targets.forEach(h=>{
      if(stat==='atk'||stat==='def'||stat==='mov'){h[stat]=(h[stat]||0)+val;}
      else if(stat==='maxHp'){h.maxHp=(h.maxHp||4)+val;h.hp=Math.min((h.hp||0)+val,h.maxHp);}
      else if(stat==='maxMp'){h.maxMp=(h.maxMp||2)+val;h.mp=Math.min((h.mp||0)+val,h.maxMp);}
      else if(stat==='level'){
        h.level=(h.level||1)+val;
        const sk2=pickTwoSkills(h);
        if(sk2.length>=2){ const hcopy=h; setTimeout(()=>showSkillChoicePopup(hcopy,sk2,null),600); }
      }
    });
    toast(item.ico+' '+item.nm+' — '+(targetHero?targetHero.name:'todos'));
    return;
  }

  if(item.type==='rest'&&item.heal){
    targets.forEach(h=>{ h.hp=h.maxHp; h.mp=h.maxMp; });
    toast('&#127817; Descanso completo — HP y MP al máximo');
    return;
  }
  if(item.type==='potion'&&item.heal){
    const t=targetHero||(targets.sort((a,b)=>(a.hp/a.maxHp)-(b.hp/b.maxHp))[0]);
    if(t){ const heal=Math.floor(Math.random()*4)+3; t.hp=Math.min(t.maxHp,(t.hp||0)+heal); toast(item.ico+' '+t.name+': +'+heal+' HP'); }
    return;
  }
  if(item.allHeroes&&item.stat){
    const {stat,val}=item;
    targets.forEach(h=>{
      if(stat==='maxHp'){h.maxHp=(h.maxHp||4)+val;h.hp=Math.min((h.hp||0)+val,h.maxHp);}
      else if(stat==='maxMp'){h.maxMp=(h.maxMp||2)+val;h.mp=Math.min((h.mp||0)+val,h.maxMp);}
      else if(stat==='atk'||stat==='def'){h[stat]=(h[stat]||0)+val;}
    });
    toast(item.ico+' '+item.nm+' — todos los héroes mejorados');
    return;
  }

  // Default: add to inventory
  addToInventory({nm:item.nm,ico:item.ico,ds:item.desc,r:'uncommon',qty:1},'Ciudad');
  toast(item.ico+' '+item.nm+' añadido al inventario');
}

// Hero picker popup for single-target upgrades
function showHeroPickerForItem(shopId, itemIdx, item){
  const old=document.getElementById('hero-picker-popup');
  if(old) old.remove();

  const available=heroes.filter(h=>!h.dead);
  if(!available.length){ toast('No hay héroes disponibles'); return; }

  // Build stat change preview
  function statPreview(h){
    if(item.effect||item.stat||item.type==='upgrade'){
      const stat=item.effect?.stat||item.stat;
      const val=item.effect?.val||item.val||1;
      const before=h[stat]||(stat==='maxHp'?h.maxHp:stat==='maxMp'?h.maxMp:0)||0;
      return stat?('<span style="color:var(--gr);font-family:Cinzel,serif;font-size:11px">'+stat.replace('max','').toUpperCase()+' '+before+' → '+(before+val)+'</span>'):'';
    }
    return '';
  }

  const el=document.createElement('div');
  el.id='hero-picker-popup';
  el.style.cssText='position:fixed;inset:0;z-index:4000;background:rgba(0,0,0,.92);display:flex;align-items:center;justify-content:center;padding:20px;animation:fIn .2s ease';

  el.innerHTML='<div style="background:linear-gradient(160deg,#1e1810,#100c06);border:2px solid var(--go);border-radius:10px;width:100%;max-width:400px;max-height:88vh;overflow-y:auto;box-shadow:0 0 50px rgba(201,150,42,.3)">'
    // Header
    +'<div style="position:sticky;top:0;background:#1a1208;padding:14px 16px;border-bottom:1px solid rgba(201,150,42,.2);display:flex;align-items:center;gap:12px;z-index:1">'
    +'<span style="font-size:28px">'+item.ico+'</span>'
    +'<div style="flex:1">'
    +'<div style="font-family:Cinzel,serif;font-size:14px;color:var(--go);font-weight:700">'+item.nm+'</div>'
    +'<div style="font-size:12px;color:var(--stl);margin-top:2px">'+item.desc+'</div>'
    +'</div>'
    +'<button onclick="document.getElementById(\'hero-picker-popup\').remove()" style="background:rgba(0,0,0,.5);border:1px solid rgba(255,255,255,.15);border-radius:50%;width:30px;height:30px;color:var(--stl);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;touch-action:manipulation">&#10005;</button>'
    +'</div>'
    // Body
    +'<div style="padding:16px">'
    +'<div style="font-family:Cinzel,serif;font-size:9px;letter-spacing:2px;color:var(--god);margin-bottom:10px">¿A QUÉ HÉROE APLICAS LA MEJORA?</div>'
    +available.map(h=>{
      const hpPct=Math.max(0,Math.min(100,((h.hp||0)/(h.maxHp||1))*100));
      const hpCol=hpPct>60?'var(--gr)':hpPct>30?'var(--go)':'var(--bl)';
      const status=h.enGuarida?'&#128564; Descansando':'&#9876;&#65039; Activo';
      return '<button onclick="confirmHeroPickerBuy(\''+shopId+'\','+itemIdx+','+h.id+')" style="'
        +'width:100%;background:linear-gradient(135deg,#1e1810,#2a2218);'
        +'border:2px solid rgba(201,150,42,.25);border-radius:6px;padding:12px 14px;'
        +'display:flex;align-items:center;gap:12px;cursor:pointer;touch-action:manipulation;'
        +'text-align:left;margin-bottom:8px">'
        +'<div style="width:40px;height:40px;border-radius:50%;background:radial-gradient(circle,'+h.col+'44,'+h.col+'11);border:2px solid rgba(201,150,42,.3);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">'+h.ico+'</div>'
        +'<div style="flex:1">'
        +'<div style="font-family:Cinzel,serif;font-size:14px;color:var(--pa);font-weight:700;margin-bottom:2px">'+h.name+'</div>'
        +'<div style="font-size:11px;color:var(--stl);margin-bottom:4px">'+h.cls+' &bull; Nv '+(h.level||1)+' &bull; '+status+'</div>'
        +'<div style="height:5px;background:rgba(0,0,0,.4);border-radius:2px;overflow:hidden;margin-bottom:4px">'
        +'<div style="height:100%;width:'+hpPct+'%;background:linear-gradient(90deg,'+hpCol+','+hpCol+'88);border-radius:2px"></div></div>'
