    {n:'Golpe Devastador',c:'1/turno',pasiva:false,d:'ACTIVA: Tira 4 dados de ataque en lugar de 3. Si saca 3+ simbolos de ataque, el enemigo no puede defenderse.'}
  ]},
enano:{ico:'&#9874;&#65039;',col:'#7a5a18',cls:'Enano',cat:'Original',
  hp:7,maxHp:7,mp:3,maxMp:3,atk:2,def:3,mov:2,
  eq:[{sl:'Arma',ico:'&#9874;&#65039;',nm:'Martillo de Guerra',r:'common',a:0,d:0},{sl:'Armadura',ico:'&#128737;&#65039;',nm:'Cota de Malla',r:'uncommon',a:0,d:2},{sl:'Accesorio',ico:'&#128141;',nm:'Amuleto Runico',r:'rare',a:0,d:1}],
  sp:[],inv:[],
  sk:[
    {n:'Buscar Trampas',c:null,pasiva:true, d:'PASIVA: Al entrar en una sala, detecta automaticamente cualquier trampa antes de activarla.'},
    {n:'Rompeminas',c:'1/turno',pasiva:false,d:'ACTIVA: Destruye una trampa o mecanismo magico sin tirada. Ademas otorga +1 monedas de oro al grupo.'}
  ]},
elfo:{ico:'&#127993;',col:'#2a5a2a',cls:'Elfo',cat:'Original',
  hp:6,maxHp:6,mp:4,maxMp:4,atk:2,def:2,mov:4,
  eq:[{sl:'Arma',ico:'&#127993;',nm:'Arco Largo Elfico',r:'rare',a:2,d:0},{sl:'Armadura',ico:'&#129509;',nm:'Capa de Sigiloso',r:'uncommon',a:0,d:1},{sl:'Accesorio',ico:'&#127807;',nm:'Corona de Hojas',r:'uncommon',a:0,d:0}],
  sp:[{nm:'Flecha de Luz',co:'1 MP',ico:'&#10024;',ds:'Disparo que ignora armadura.',r:'uncommon'}],inv:[],
  sk:[
    {n:'Paso Silencioso',c:null,pasiva:true, d:'PASIVA: El Elfo no activa trampas al moverse y siempre actua primero en iniciativa.'},
