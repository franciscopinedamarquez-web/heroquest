const REWARDS=[[{ico:'&#128176;',n:'Oros de la mazmorra',v:'+50 oros/heroe'},{ico:'&#129514;',n:'Pocion de Curacion',v:'+2 unidades'}],[{ico:'&#128176;',n:'Cofre del tesoro',v:'+80 oros/heroe'},{ico:'&#11088;',n:'Experiencia',v:'+150 XP/heroe'}],[{ico:'&#11088;',n:'Experiencia de combate',v:'+200 XP/heroe'},{ico:'&#128505;&#65039;',n:'Espada Corta',v:'Objeto raro'}],[{ico:'&#128176;',n:'Botin de guerra',v:'+120 oros/heroe'},{ico:'&#128220;',n:'Pergamino Arcano',v:'Nuevo hechizo'}],[{ico:'&#128737;&#65039;',n:'Escudo Elfico',v:'Equip raro'},{ico:'&#11088;',n:'Experiencia',v:'+300 XP/heroe'}],[{ico:'&#128142;',n:'Anillo de Poder',v:'Objeto legendario'},{ico:'&#128176;',n:'Monedas antiguas',v:'+200 oros/heroe'}]];
const TDEF=[{k:'gold',i:'&#128176;',n:'Monedas de Oro',u:'oros',s:10},{k:'potions',i:'&#129514;',n:'Pociones de Curacion',u:'uds',s:1},{k:'scrolls',i:'&#128220;',n:'Pergaminos Magicos',u:'uds',s:1},{k:'keys',i:'&#128285;',n:'Llaves y Artefactos',u:'uds',s:1}];
const RN={common:'Comun',uncommon:'Poco comun',rare:'Raro',legendary:'Legendario',magic:'Hechizo'};
const RC={common:'rc',uncommon:'ru',rare:'rr',legendary:'rl',magic:'rm'};
const CF=['&#128128;','&#9876;&#65039;','&#128737;&#65039;','&#9876;&#65039;','&#128128;','&#9876;&#65039;'];
// state
const LSK='hq_v4';
function loadS(){try{const r=localStorage.getItem(LSK);if(r)return JSON.parse(r)}catch(e){}return null}
function dpUpdatePhoto(id,input){
  const file=input.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=e=>{
    const h=heroes.find(x=>x.id===id);
    if(!h)return;
    h.photo=e.target.result;
    // Update visible avatar in detail panel
    const dav=document.querySelector('.dpanel .dav');
    if(dav){
      let img=dav.querySelector('img');
      if(!img){img=document.createElement('img');img.style.cssText='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%';dav.appendChild(img);}
      img.src=h.photo;
      const ico=dav.querySelector('span');if(ico)ico.style.display='none';
    }
    rH();saveS();toast('&#128247; Foto actualizada');
  };
  reader.readAsDataURL(file);
}

function saveS(){try{localStorage.setItem(LSK,JSON.stringify({heroes,gt,gi,cn,dh,sk,guaridaRestLog,esquirlas,esquirlasPozo,guaridaMejoras,esquirlasLog}));fl()}catch(e){}}
let stim;function fl(){const e=document.getElementById('sind');e.classList.add('v');clearTimeout(stim);stim=setTimeout(()=>e.classList.remove('v'),1800)}
// State starts empty — loaded by session screen
let heroes=[],gt={gold:0,potions:0,scrolls:0,keys:0},gi=[],cn='',dh=[],sk=null;
let sT='barbaro',eHid=null,eSidx=-1,ciM='equip',ciR='common',giR='common';
let esquirlas=0;  // shards in hand
let esquirlasLog=[];  // history log
let esquirlasPozo=0;  // shards thrown into the well
let guaridaMejoras={};  // permanent guarida upgrades purchased
function rnd(a){return a[Math.floor(Math.random()*a.length)]}
function ri(a,b){return Math.floor(Math.random()*(b-a+1))+a}
function openM(id){
  const el=document.getElementById(id);
  if(!el)return;
  // Move to document root to escape any stacking context
  if(el.parentElement!==document.documentElement){
    document.documentElement.appendChild(el);
  }
  el.classList.add('open');
}
function closeM(id){document.getElementById(id).classList.remove('open')}
function closeMB(e,id){if(e.target===document.getElementById(id))closeM(id)}
let tT;
function toast(m){const t=document.getElementById('toast');t.innerHTML=m;t.classList.add('show');clearTimeout(tT);tT=setTimeout(()=>t.classList.remove('show'),2600)}
function showTab(tab,btn){
  closeHeroModal();
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));
  document.getElementById('view-'+tab).classList.add('active');
  if(btn)btn.classList.add('active');
  document.getElementById('fab').classList.toggle('hidden',tab!=='heroes');
  if(tab==='notes')renderN();
  if(tab==='skirmish')renderSk();
  if(tab==='inventario')renderInventario();
  if(tab==='ciudad')renderCiudad();
  if(tab==='guarida')renderGuarida();
}
// HEROES
function rH(){
  const c=document.getElementById('hcon');c.querySelectorAll('.hcard').forEach(x=>x.remove());
  document.getElementById('ehero').style.display=heroes.length?'none':'block';
  heroes.filter(h=>!h.enGuarida).forEach(h=>{
    const hpp=(h.hp/h.maxHp)*100,mpp=(h.mp/h.maxMp)*100,dead=h.hp<=0;
    const d=document.createElement('div');d.className='hcard'+(dead?' dead':'');
    const avatarInner=h.photo?`<img src="${h.photo}" style="width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;inset:0">`:`${h.ico}`;
    d.innerHTML=`<div class="hch"><div class="hav" style="background:radial-gradient(circle at 40% 35%,${h.col}44,${h.col}11);position:relative;overflow:hidden">${avatarInner}</div><div style="flex:1"><div class="hnm" style="font-size:17px;${dead?'color:#888':''}">${h.name||'Sin nombre'}${dead?' <small>&#128128;</small>':''}</div><div class="hcl" style="font-size:12px">${h.cls}${h.sp?.length?' &bull; <span style="color:var(--mg);font-size:11px">&#10024;'+h.sp.length+'</span>':''}</div></div><div class="hlv" style="font-size:11px">NV ${h.level}</div></div>
    <div class="hsts"><div class="sb"><span class="slb">VIDA</span><span class="sv hp">${h.hp}</span><span class="smx">/${h.maxHp}</span></div><div class="sb"><span class="slb">MANA</span><span class="sv mp">${h.mp}</span><span class="smx">/${h.maxMp}</span></div><div class="sb"><span class="slb">ATAQUE</span><span class="sv atk">${h.atk}</span><span class="smx">dados</span></div><div class="sb"><span class="slb">DEFENSA</span><span class="sv def">${h.def}</span><span class="smx">dados</span></div></div>
    <div class="hbrs"><div class="brow"><span class="blb">HP</span><div class="btk"><div class="bf hpb" style="width:${hpp}%"></div></div><span class="btx">${h.hp}/${h.maxHp}</span></div><div class="brow"><span class="blb">MP</span><div class="btk"><div class="bf mpb" style="width:${mpp}%"></div></div><span class="btx">${h.mp}/${h.maxMp}</span></div></div>
    <div class="cact" style="grid-template-columns:1fr 1fr 1fr 1fr 1fr"><button class="cab" style="color:var(--bl)" onclick="qs(${h.id},'hp',-1)">&#128148;</button><button class="cab" style="color:var(--gr)" onclick="qs(${h.id},'hp',1)">&#10084;&#65039;</button><button class="cab" style="color:var(--mg)" onclick="qs(${h.id},'mp',-1)">&#128309;</button><button class="cab" onclick="showD(${h.id})">VER &#8250;</button><button class="cab" style="color:rgba(139,26,26,.7);font-size:14px" onclick="if(confirm('Eliminar a ${h.name}?')){ heroes=heroes.filter(x=>x.id!==${h.id});rH();saveS();toast('&#128128; ${h.name} eliminado');}">&#10005;</button></div>`;
    c.appendChild(d);
  });
}
function qs(id,st,d){const h=heroes.find(x=>x.id===id);if(!h)return;if(st==='hp')h.hp=Math.max(0,Math.min(h.maxHp,h.hp+d));if(st==='mp')h.mp=Math.max(0,Math.min(h.maxMp,h.mp+d));rH();saveS();if(st==='hp'&&h.hp===0)toast('&#128128; '+h.name+' ha caido');}
function rEq(h,id){return(h.eq||[]).map((e,i)=>`<div class="esl" onclick="openEQ(${id},${i})"><span style="font-size:22px;width:30px;text-align:center">${e.ico}</span><div style="flex:1"><div style="font-size:9px;letter-spacing:1px;color:var(--stl);font-family:'Cinzel',serif;text-transform:uppercase">${e.sl}</div><div style="font-size:14px;color:var(--pa);font-weight:600">${e.nm}</div>${e.ds?`<div style="font-size:11px;color:var(--stl);font-style:italic">${e.ds}</div>`:''}<div class="${RC[e.r]||'rc'}" style="font-size:11px">${RN[e.r]||''}${e.a>0?' &bull; +'+e.a+' Ataque':''}${e.d>0?' &bull; +'+e.d+' Defensa':''}${e.custom?' &#9998;':''}</div></div><span style="color:var(--stl);font-size:18px">&#8250;</span></div>`).join('')}
function rSp(h,id){if(!h.sp?.length)return`<div style="padding:11px 14px;font-size:13px;color:var(--stl);font-style:italic">Sin hechizos aprendidos.</div>`;return h.sp.map((s,i)=>`<div class="spsl"><span style="font-size:24px;width:32px;text-align:center">${s.ico||'&#10024;'}</span><div style="flex:1"><div style="font-family:'Cinzel',serif;font-size:13px;color:var(--pa)">${s.nm}</div><div style="font-size:12px;color:var(--mg)">${s.co||''}</div><div style="font-size:12px;color:var(--stl);font-style:italic">${s.ds}</div></div><button class="sprm" onclick="remSp(${id},${i})">X</button></div>`).join('')}
function rInv(h,id){if(!h.inv?.length)return`<div style="padding:11px 14px;font-size:13px;color:var(--stl);font-style:italic">Inventario vacio.</div>`;return h.inv.map((it,i)=>`<div class="ivit"><span style="font-size:22px;width:30px;text-align:center">${it.ico||'&#128230;'}</span><div style="flex:1"><div style="font-size:14px;color:var(--pa);font-weight:600">${it.nm}</div><div style="font-size:12px;color:var(--stl);font-style:italic">${it.ds||''}</div></div><div style="font-family:'Cinzel',serif;font-size:14px;color:var(--go);min-width:24px;text-align:center">${it.qty||1}</div><div style="display:flex;gap:3px"><button class="ibt" onclick="adjHI(${id},${i},-1)">-</button><button class="ibt" onclick="adjHI(${id},${i},1)">+</button><button class="ibt del" onclick="remHI(${id},${i})">X</button></div></div>`).join('')}
function showD(id){
  const h=heroes.find(x=>x.id===id);
  if(!h)return;
  if(!h.sp)h.sp=[];
  if(!h.inv)h.inv=[];

  const p=document.createElement('div');
  p.className='dpanel';
  p.id='dpanel';

  // Build avatar
  const avContent = h.photo
    ? '<img src="'+h.photo+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;inset:0">'
    : h.ico;

  // Build bonus name line
  const bonusLine = h.bonusName
    ? '<div style="font-size:10px;color:var(--god);font-style:italic;font-family:\'Cinzel\',serif;letter-spacing:1px;margin-top:2px">'+h.bonusName+'</div>'
    : '';

  // Build skills
  const skillsHtml = h.sk.map(function(s){
    const badge = s.pasiva
      ? '<span style="font-family:\'Cinzel\',serif;font-size:8px;letter-spacing:1px;padding:2px 6px;border-radius:2px;border:1px solid;color:var(--gr);border-color:var(--grd);background:rgba(42,90,42,.2)">PASIVA</span>'
      : '<span style="font-family:\'Cinzel\',serif;font-size:8px;letter-spacing:1px;padding:2px 6px;border-radius:2px;border:1px solid;color:var(--go);border-color:var(--god);background:rgba(201,150,42,.15)">ACTIVA</span>';
    const costLine = s.c ? '<div style="font-size:10px;color:var(--mg);margin-bottom:2px">'+s.c+'</div>' : '';
    return '<div style="padding:10px 13px;border-bottom:1px solid rgba(255,255,255,.04)">'
      + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">'
      + '<span style="font-family:\'Cinzel\',serif;font-size:13px;color:var(--pa)">'+s.n+'</span>'
      + badge
      + '</div>'
      + costLine
      + '<div style="font-size:12px;color:var(--stl);font-style:italic">'+s.d+'</div>'
      + '</div>';
  }).join('');

  p.innerHTML =
    '<div class="dtb">'
      + '<button class="bbtn" onclick="closeD()">&#8249;</button>'
      + '<span class="dttl">FICHA DE HEROE</span>'
    + '</div>'

    + '<div class="dhdr">'
      + '<div style="position:relative;flex-shrink:0">'
        + '<div class="dav" style="background:radial-gradient(circle at 40% 35%,'+h.col+'55,'+h.col+'11);position:relative;overflow:hidden;cursor:pointer" onclick="document.getElementById(\'dp-photo-'+id+'\').click()">'+avContent+'</div>'
        + '<div style="position:absolute;bottom:0;right:0;width:22px;height:22px;background:var(--god);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;border:2px solid #1a1208" onclick="document.getElementById(\'dp-photo-'+id+'\').click()">&#128247;</div>'
        + '<input type="file" id="dp-photo-'+id+'" accept="image/*" style="display:none" onchange="dpUpdatePhoto('+id+',this)">'
      + '</div>'
      + '<div>'
        + '<div class="dname">'+h.name+'</div>'
        + '<div class="dsubt">'+h.cls+' &bull; Nivel <span id="d-lv">'+h.level+'</span></div>'
        + bonusLine
        + '<div class="dgold">&#128176; <span id="d-go">'+h.gold+'</span> oros</div>'
      + '</div>'
    + '</div>'

    + '<div class="scard">'
      + '<div class="sct">ESTADISTICAS</div>'
      + '<div class="sadj"><div class="alb">Vida<small>Max: '+h.maxHp+'</small></div><div class="acls"><button class="abtn" onclick="adjD('+id+',\'hp\',-1)">-</button><span class="aval" id="d-hp">'+h.hp+'</span><button class="abtn" onclick="adjD('+id+',\'hp\',1)">+</button></div></div>'
      + '<div class="sadj"><div class="alb">Mana<small>Max: '+h.maxMp+'</small></div><div class="acls"><button class="abtn" onclick="adjD('+id+',\'mp\',-1)">-</button><span class="aval" id="d-mp">'+h.mp+'</span><button class="abtn" onclick="adjD('+id+',\'mp\',1)">+</button></div></div>'
      + '<div class="sadj"><div class="alb">Oro<small>Propias</small></div><div class="acls"><button class="abtn" onclick="adjD('+id+',\'gold\',-10)">-</button><span class="aval" id="d-go2">'+h.gold+'</span><button class="abtn" onclick="adjD('+id+',\'gold\',10)">+</button></div></div>'
      + '<div class="sadj"><div class="alb">Nivel<small>1-10</small></div><div class="acls"><button class="abtn" onclick="adjD('+id+',\'level\',-1)">-</button><span class="aval" id="d-lv2">'+h.level+'</span><button class="abtn" onclick="adjD('+id+',\'level\',1)">+</button></div></div>'
    + '</div>'

    + '<div class="scard" id="d-eq">'
      + '<div class="sct">EQUIPAMIENTO'
        + '<button class="sctb" onclick="openEQ('+id+',-1)">+ ANADIR</button>'
      + '</div>'
      + rEq(h,id)
    + '</div>'

    + '<div class="scard" id="d-sp">'
      + '<div class="sct">HECHIZOS'
        + '<button class="sctb" onclick="openSP('+id+')">+ HECHIZO</button>'
      + '</div>'
      + rSp(h,id)
    + '</div>'

    + '<div class="scard" id="d-iv">'
      + '<div class="sct">INVENTARIO'
        + '<button class="sctb" onclick="openCI(\'inv-hero\')">+ ANADIR</button>'
      + '</div>'
      + rInv(h,id)
    + '</div>'

    + '<div class="scard">'
      + '<div class="sct">HABILIDADES</div>'
      + skillsHtml
    + '</div>'

    + '<div class="scard">'
      + '<div class="sct">NOTAS DEL HEROE</div>'
      + '<textarea class="nfld" placeholder="Anotaciones personales..." rows="3" onblur="saveHN('+id+',this.value)" onchange="saveHN('+id+',this.value)">'+( h.notes||'' )+'</textarea>'
    + '</div>'

    + '<div style="padding:14px;display:grid;grid-template-columns:1fr 1fr;gap:10px">'
      + '<button onclick="revive('+id+')" style="background:linear-gradient(135deg,var(--grd),#1a3010);border:1px solid var(--grd);border-radius:4px;color:var(--gr);font-family:\'Cinzel\',serif;font-size:11px;letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">&#10024; REVIVIR</button>'
      + '<button onclick="sendToRest('+id+');closeD()" style="background:linear-gradient(135deg,rgba(74,128,212,.2),rgba(50,80,150,.15));border:1px solid rgba(74,128,212,.5);border-radius:4px;color:var(--mg);font-family:\'Cinzel\',serif;font-size:11px;letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">&#128564; GUARIDA</button>'
      + '<button onclick="if(confirm(\'¿Marcar este héroe como caído en combate?\'))markAsDead('+id+',\'Caído en combate.\');closeD()" style="background:linear-gradient(135deg,rgba(139,26,26,.4),rgba(80,10,10,.3));border:1px solid rgba(139,26,26,.5);border-radius:4px;color:rgba(220,120,120,.9);font-family:\'Cinzel\',serif;font-size:11px;letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">&#9760;&#65039; CAÍDO</button>'
      + '<button onclick="delH('+id+')" style="background:linear-gradient(135deg,rgba(80,15,15,.7),rgba(50,10,10,.7));border:1px solid var(--bl);border-radius:4px;color:var(--bl);font-family:\'Cinzel\',serif;font-size:11px;letter-spacing:1px;padding:12px;cursor:pointer;touch-action:manipulation">&#128128; ELIMINAR</button>'
    + '</div>';

  document.documentElement.appendChild(p);
}

function closeD(){const p=document.getElementById('dpanel');if(p){p.style.opacity='0';p.style.transform='translateX(28px)';setTimeout(()=>p.remove(),200)}}
function adjD(id,st,d){const h=heroes.find(x=>x.id===id);if(!h)return;if(st==='hp')h.hp=Math.max(0,Math.min(h.maxHp,h.hp+d));if(st==='mp')h.mp=Math.max(0,Math.min(h.maxMp,h.mp+d));if(st==='gold')h.gold=Math.max(0,h.gold+d);if(st==='level')h.level=Math.max(1,Math.min(10,h.level+d));const m={hp:'d-hp',mp:'d-mp',gold:'d-go',level:'d-lv'};[m[st],m[st]+'2'].forEach(k=>{const e=document.getElementById(k);if(e)e.textContent=h[st];});if(st==='gold'){const e=document.getElementById('d-go');if(e)e.textContent=h.gold;}rH();saveS();if(st==='hp'&&h.hp===0)toast('&#128128; '+h.name+' ha caido');}
function saveHN(id,t){const h=heroes.find(x=>x.id===id);if(h){h.notes=t;saveS()}}
function revive(id){const h=heroes.find(x=>x.id===id);if(!h)return;h.hp=Math.ceil(h.maxHp/2);h.mp=Math.ceil(h.maxMp/2);rH();saveS();toast('&#10024; '+h.name+' revivido');const e=document.getElementById('d-hp');if(e)e.textContent=h.hp;}
function delH(id){if(!confirm('Eliminar este heroe?'))return;heroes=heroes.filter(x=>x.id!==id);closeD();rH();saveS();toast('Heroe eliminado')}
function openEQ(hid,sidx,slotOverride){
  eHid=hid;eSidx=sidx;
  const h=heroes.find(x=>x.id===hid);if(!h)return;
  const sl=sidx>=0?h.eq[sidx]:null;
  const sn=slotOverride||(sl?sl.sl:'Arma');
  document.getElementById('eqtit').textContent=sn;

  const cat=(ICAL[sn]||ICAL['Arma']).filter(it=>!it.nm.startsWith('//'));
  let slotHeader='';
  if(sidx<0){
    // Show slot chooser tabs
    slotHeader=`<div style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap">
      ${['Arma','Armadura','Accesorio'].map(s=>`
        <button onclick="openEQ(${hid},-1,'${s}')"
          style="flex:1;min-width:80px;background:${sn===s?'rgba(201,150,42,.2)':'rgba(0,0,0,.4)'};
            border:1px solid ${sn===s?'var(--go)':'rgba(201,150,42,.25)'};border-radius:4px;
            color:${sn===s?'var(--go)':'var(--stl)'};font-family:'Cinzel',serif;
            font-size:11px;letter-spacing:1px;padding:8px;cursor:pointer;touch-action:manipulation">
          ${s==='Arma'?'&#9876;&#65039;':s==='Armadura'?'&#128737;&#65039;':'&#128141;'} ${s}
        </button>`).join('')}
    </div>`;
  }

  document.getElementById('eqopts').innerHTML=slotHeader+cat.map(it=>{
    const enc=JSON.stringify(it).replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const isCur=sl&&it.nm===sl.nm;
    return`<div class="eopt${isCur?' cur':''}" onclick="selEQ(${enc})">
      <span style="font-size:24px">${it.ico}</span>
      <div style="flex:1">
        <div style="font-size:14px;color:var(--pa);font-weight:600">${it.nm}</div>
        ${it.ds?`<div style="font-size:12px;color:var(--stl);font-style:italic">${it.ds}</div>`:''}
        <div class="${RC[it.r]||'rc'}" style="font-size:12px">${RN[it.r]||''}${it.a>0?' &bull; +'+it.a+' ATK':''}${it.d>0?' &bull; +'+it.d+' DEF':''}</div>
      </div>
      ${isCur?'<span style="color:var(--go);font-size:20px">&#10003;</span>':''}
    </div>`;
  }).join('');
  openM('m-eq');
}
function selEQ(it){const h=heroes.find(x=>x.id===eHid);if(!h)return;if(eSidx>=0)h.eq[eSidx]={...h.eq[eSidx],...it};else h.eq.push({sl:it.sl||'Arma',...it});closeM('m-eq');saveS();toast('Equipamiento actualizado');const c=document.getElementById('d-eq');if(c){c.querySelectorAll('.esl').forEach(x=>x.remove());c.insertAdjacentHTML('beforeend',rEq(h,h.id));}rH();}
function openSP(hid){
  eHid=hid;
  const h=heroes.find(x=>x.id===hid); if(!h) return;
  const kn=(h.sp||[]).map(s=>s.nm);

  const schools=[
    {lbl:'&#128293; Fuego',    nms:['Bola de Fuego','Valentia','Tempestad de Fuego','Muro de Fuego']},
    {lbl:'&#127774; Tierra',   nms:['Piel de Piedra','Pasar por la Roca','Terremoto']},
    {lbl:'&#128167; Agua',     nms:['Curacion Corporal','Dormir','Niebla','Agua Purificadora']},
    {lbl:'&#128168; Aire',     nms:['Genio','Rafaga','Tempestad','Vuelo']},
    {lbl:'&#10024; Arcano',    nms:['Mano Fantasma','Reflejo','Drenaje de Vida','Clarividencia','Torpeza']},
    {lbl:'&#128267; Luz',      nms:['Luz Divina','Bendicion','Exorcismo','Consagrar']},
    {lbl:'&#9760;&#65039; Oscuro', nms:['Invocar Esqueleto','Maldicion','Drenar Vida']},
    {lbl:'&#128065;&#65039; Ilusiones', nms:['Ilusion','Confusion','Sigilo Arcano']},
    {lbl:'&#127744; Gran Poder',nms:['Tormenta Magica','Cataclismo']},
  ];

  let out='';
  schools.forEach(function(sch){
    const items=SCATS.filter(s=>sch.nms.includes(s.nm));
    if(!items.length) return;
    out+='<div style="font-family:\'Cinzel\',serif;font-size:10px;letter-spacing:2px;color:var(--god);'
      +'padding:10px 2px 5px;border-bottom:1px solid rgba(201,150,42,.15);margin-bottom:5px">'+sch.lbl+'</div>';
    out+=items.map(function(s){
      const enc=JSON.stringify(s).replace(/"/g,'&quot;');
      const isKn=kn.includes(s.nm);
      return '<div class="eopt'+(isKn?' cur':'')+'" onclick="addSP('+enc+')">'
        +'<span style="font-size:24px">'+s.ico+'</span>'
        +'<div style="flex:1">'
          +'<div style="font-family:\'Cinzel\',serif;font-size:13px;color:var(--pa);font-weight:600">'+s.nm+'</div>'
          +'<div style="font-size:12px;color:var(--mg);margin-bottom:2px">'+s.co+'</div>'
          +'<div style="font-size:12px;color:var(--stl);font-style:italic">'+s.ds+'</div>'
        +'</div>'
        +(isKn?'<span style="color:var(--mg);font-size:20px">&#10003;</span>':'')
        +'</div>';
    }).join('');
  });
  document.getElementById('spopts').innerHTML=out;
  openM('m-sp');
}

function addSP(sp){const h=heroes.find(x=>x.id===eHid);if(!h)return;if(!h.sp)h.sp=[];if(h.sp.find(s=>s.nm===sp.nm)){toast('Ya conoces ese hechizo');return;}h.sp.push(sp);closeM('m-sp');saveS();toast('&#10024; Hechizo aprendido: '+sp.nm);const c=document.getElementById('d-sp');if(c){c.querySelectorAll('.spsl').forEach(x=>x.remove());const p=c.querySelector('[style*="Sin hechizos"]');if(p)p.remove();c.insertAdjacentHTML('beforeend',rSp(h,h.id));}rH();}
function remSp(id,idx){const h=heroes.find(x=>x.id===id);if(!h)return;h.sp.splice(idx,1);saveS();const c=document.getElementById('d-sp');if(c){c.querySelectorAll('.spsl').forEach(x=>x.remove());const p=c.querySelector('[style*="Sin hechizos"]');if(p)p.remove();c.insertAdjacentHTML('beforeend',rSp(h,h.id));}rH();}
function adjHI(id,idx,d){const h=heroes.find(x=>x.id===id);if(!h||!h.inv[idx])return;h.inv[idx].qty=Math.max(0,(h.inv[idx].qty||1)+d);if(h.inv[idx].qty===0)h.inv.splice(idx,1);saveS();const c=document.getElementById('d-iv');if(c){c.querySelectorAll('.ivit').forEach(x=>x.remove());const p=c.querySelector('[style*="Inventario"]');if(p)p.remove();c.insertAdjacentHTML('beforeend',rInv(h,h.id));}}
function remHI(id,idx){const h=heroes.find(x=>x.id===id);if(!h)return;h.inv.splice(idx,1);saveS();const c=document.getElementById('d-iv');if(c){c.querySelectorAll('.ivit').forEach(x=>x.remove());const p=c.querySelector('[style*="Inventario"]');if(p)p.remove();c.insertAdjacentHTML('beforeend',rInv(h,h.id));}}
function openHeroInvCatalog(hid){
  eHid=hid;
  const h=heroes.find(x=>x.id===hid); if(!h) return;
  if(!h.inv) h.inv=[];

  let out='<div style="font-family:\'Cinzel\',serif;font-size:10px;letter-spacing:2px;color:var(--god);padding:4px 0 8px">OBJETOS DEL JUEGO BASE</div>';
  out+=IINV.map(function(it){
    const alreadyHas=h.inv.find(x=>x.nm===it.nm);
    return '<div class="eopt'+(alreadyHas?' cur':'')+'" onclick="addInvItem(\''+it.nm+'\')">'
      +'<span style="font-size:24px">'+it.ico+'</span>'
      +'<div style="flex:1">'
        +'<div style="font-size:14px;color:var(--pa);font-weight:600">'+it.nm+'</div>'
        +'<div style="font-size:12px;color:var(--stl);font-style:italic">'+it.ds+'</div>'
        +'<div style="font-size:11px;color:var(--god)">'+RN[it.r]+'</div>'
      +'</div>'
      +(alreadyHas?'<span style="color:var(--go);font-size:18px">&#10003;</span>':'<span style="color:var(--stl);font-size:14px">+</span>')
      +'</div>';
  }).join('');

  // Modal: reuse m-ci structure but with catalog content
  document.getElementById('citit').textContent='Inventario';
  document.getElementById('ci-n').style.display='none';
  document.getElementById('ci-xweapon').style.display='none';
  document.getElementById('ci-xspell').style.display='none';
  document.getElementById('ci-xinv').style.display='none';
  // Show catalog
  let catDiv=document.getElementById('ci-catalog');
  if(!catDiv){
    catDiv=document.createElement('div');
    catDiv.id='ci-catalog';
    document.getElementById('ci-n').parentNode.insertBefore(catDiv,document.getElementById('ci-n'));
  }
  catDiv.innerHTML=out;
  document.getElementById('ci-n').style.display='';
  document.getElementById('ci-n').placeholder='O escribe nombre de objeto personalizado...';
  document.getElementById('ci-xinv').style.display='block';
  document.querySelectorAll('#ci-rg .rbt').forEach(b=>{b.classList.remove('sel');if(b.dataset.r==='common')b.classList.add('sel')});
  ciR='common'; ciM='inv-hero';
  openM('m-ci');
}

function addInvItem(nm){
  const h=heroes.find(x=>x.id===eHid); if(!h) return;
  if(!h.inv) h.inv=[];
  const template=IINV.find(x=>x.nm===nm);
  if(!template) return;
  const existing=h.inv.find(x=>x.nm===nm);
  if(existing){ existing.qty=(existing.qty||1)+1; }
  else { h.inv.push({nm:template.nm,ico:template.ico,ds:template.ds,r:template.r,qty:1}); }
  saveS();
  toast(template.ico+' '+nm+' anadido');
  // Refresh inv panel in dpanel
  const c=document.getElementById('d-iv');
  if(c){c.querySelectorAll('.ivit').forEach(x=>x.remove());const ph=c.querySelector('[style*="Inventario"]');if(ph)ph.remove();c.insertAdjacentHTML('beforeend',rInv(h,h.id));}
  // Re-open to show updated state
  openHeroInvCatalog(eHid);
}

function openCI(mode){ciM=mode;document.getElementById('citit').textContent=mode.includes('spell')?'Crear Hechizo':mode.includes('inv')?'Anadir al Inventario':'Crear Objeto de Equipo';document.getElementById('ci-xw').style.display=mode==='equip'?'block':'none';document.getElementById('ci-xs').style.display=mode.includes('spell')?'block':'none';document.getElementById('ci-xv').style.display=(mode==='inv'||mode==='inv-hero')?'block':'none';document.querySelectorAll('#ci-rg .rbt').forEach(b=>{b.classList.remove('sel');if(b.dataset.r==='common')b.classList.add('sel')});ciR='common';['ci-n','ci-d','ci-i'].forEach(id=>{const e=document.getElementById(id);if(e)e.value='';});closeM('m-eq');closeM('m-sp');openM('m-ci');}
function selR(btn,ctx){const g=ctx==='gi'?'#gi-rg .rbt':'#ci-rg .rbt';document.querySelectorAll(g).forEach(b=>b.classList.remove('sel'));btn.classList.add('sel');if(ctx==='gi')giR=btn.dataset.r;else ciR=btn.dataset.r;}
function saveCI(){const nm=document.getElementById('ci-n').value.trim();const ds=document.getElementById('ci-d').value.trim();const ico=document.getElementById('ci-i').value.trim()||'&#128230;';if(!nm){toast('Escribe un nombre');return;}
if(ciM==='equip'){const sl=document.getElementById('ci-sl').value;const a=parseInt(document.getElementById('ci-a').value)||0;const d=parseInt(document.getElementById('ci-df').value)||0;const it={sl,nm,ico,ds,r:ciR,a,d,custom:true};if(!ICAL[sl])ICAL[sl]=[];ICAL[sl].push(it);const h=heroes.find(x=>x.id===eHid);if(h){if(eSidx>=0)selEQ(it);else{h.eq.push(it);const c=document.getElementById('d-eq');if(c){c.querySelectorAll('.esl').forEach(x=>x.remove());c.insertAdjacentHTML('beforeend',rEq(h,h.id));}rH();saveS();}}toast('Objeto creado');}
else if(ciM.includes('spell')){const co=document.getElementById('ci-c').value.trim()||'0 MP';const sp={nm,ico,ds,co,r:ciR};SCATS.push(sp);if(eHid)addSP(sp);else toast('&#10024; Hechizo creado al catalogo');}
else{const qty=parseInt(document.getElementById('ci-q').value)||1;const it={nm,ico,ds,r:ciR,qty};if(ciM==='inv-hero'&&eHid){const h=heroes.find(x=>x.id===eHid);if(h){if(!h.inv)h.inv=[];h.inv.push(it);saveS();toast('Objeto anadido al heroe');const c=document.getElementById('d-iv');if(c){c.querySelectorAll('.ivit').forEach(x=>x.remove());const p=c.querySelector('[style*="Inventario"]');if(p)p.remove();c.insertAdjacentHTML('beforeend',rInv(h,h.id));}}}else{gi.push(it);saveS();toast('Objeto anadido al grupo');renderGI();}}closeM('m-ci');}
function openHeroModal(){
  sT = Object.keys(HT)[0];
  // Reset to step 1
  const s1 = document.getElementById('nh-step1');
  const s2 = document.getElementById('nh-step2');
  if(s1) s1.style.display='flex';
  if(s2) s2.style.display='none';
  renderClassGrid();
  const m = document.getElementById('m-nh');
  if(m){
    if(m.parentElement!==document.documentElement){
      document.documentElement.appendChild(m);
    }
    m.style.display='flex';
  }
}

