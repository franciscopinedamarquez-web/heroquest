    ico:'&#129461;', nm:'Estatua del Héroe Caído',
    desc:'En honor a los aventureros que no regresaron. Su memoria fortalece a los supervivientes.',
    lore:'Tallada en piedra de mazmorra por el Enano del grupo.',
    effect:'Cada héroe caído da +5 de bonificación permanente de ATK a todos los supervivientes.',
    costGold: 250,
    statBonus: {fallBonus: 5},
  },
  {
    id:'portal_rapido',
    ico:'&#128302;', nm:'Portal de Acceso Rápido',
    desc:'Un portal mágico que permite llegar antes a las mazmorras. El grupo actúa con ventaja al inicio.',
    lore:'Fragmento de un portal mayor destruido por los cultistas.',
