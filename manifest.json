    +'<span style="background:rgba(74,128,212,.15);border:1px solid var(--mb);border-radius:12px;padding:3px 10px;font-family:Cinzel,serif;font-size:12px;color:var(--mg)">&#10024; '+cls.mp+'</span>'
    +'<span style="background:rgba(201,150,42,.12);border:1px solid var(--god);border-radius:12px;padding:3px 10px;font-family:Cinzel,serif;font-size:12px;color:var(--go)">&#9876; '+cls.atk+'</span>'
    +'<span style="background:rgba(90,176,90,.12);border:1px solid var(--grd);border-radius:12px;padding:3px 10px;font-family:Cinzel,serif;font-size:12px;color:var(--gr)">&#128737; '+cls.def+'</span>';

