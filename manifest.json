    .guarida-section-title{font-family:'Cinzel',serif;font-size:10px;letter-spacing:3px;color:var(--god);padding:10px 0 8px}
    .guarida-hero-card{background:linear-gradient(135deg,#1a1208,#0d0a07);border:1px solid rgba(201,150,42,.2);border-radius:8px;overflow:hidden;margin-bottom:10px}
    .guarida-hero-hdr{display:flex;align-items:center;gap:12px;padding:12px 14px}
    .guarida-hero-av{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;border:2px solid rgba(201,150,42,.3);position:relative;overflow:hidden}
    .guarida-hero-body{flex:1;min-width:0}
    .guarida-hero-name{font-family:'Cinzel',serif;font-size:14px;color:var(--pa);font-weight:700;margin-bottom:2px}
    .guarida-hero-cls{font-size:11px;color:var(--stl)}
    .guarida-hp-bar{height:5px;background:rgba(0,0,0,.5);border-radius:3px;margin-top:5px;overflow:hidden}
    .guarida-hp-fill{height:100%;border-radius:3px;transition:width .4s ease}
    .guarida-rest-bar{height:5px;background:rgba(0,0,0,.5);border-radius:3px;margin-top:3px;overflow:hidden}
    .guarida-rest-fill{height:100%;background:linear-gradient(90deg,var(--mg),var(--pul));border-radius:3px;transition:width .4s ease}
    .guarida-btn{font-family:'Cinzel',serif;font-size:11px;letter-spacing:1px;padding:8px 12px;border-radius:4px;cursor:pointer;touch-action:manipulation;white-space:nowrap;flex-shrink:0}
    .guarida-btn-rest{background:rgba(74,128,212,.15);border:1px solid rgba(74,128,212,.4);color:var(--mg)}
    .guarida-btn-recall{background:linear-gradient(135deg,#1a2a0a,#0d1808);border:1px solid var(--grd);color:var(--gr)}
    .guarida-btn-rest:active,.guarida-btn-recall:active{opacity:.7}
    .guarida-event-card{background:linear-gradient(135deg,rgba(128,74,212,.12),rgba(74,128,212,.08));border:2px solid rgba(128,74,212,.3);border-radius:8px;padding:14px;margin-bottom:14px}
    .guarida-facility{background:rgba(0,0,0,.3);border:1px solid rgba(201,150,42,.15);border-radius:6px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px}
    .dead-card{background:linear-gradient(135deg,#1a0808,#0d0404);border:1px solid rgba(139,26,26,.25);border-radius:8px;padding:12px 14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;opacity:.7}
    .guarida-empty{text-align:center;padding:28px 16px;color:var(--stl);font-style:italic;font-size:13px}
  `;
  document.head.appendChild(s);
})();

// ── State ─────────────────────────────────────────────────────────────────────
let guaridaEventShown = false;
let guaridaRestLog = []; // log of rest actions

// ── MAIN RENDER ───────────────────────────────────────────────────────────────
function renderGuarida(){
  const c = document.getElementById('guaridacon');
  if(!c) return;

  const active  = heroes.filter(h => !h.enGuarida && !h.dead);
  const resting = heroes.filter(h => h.enGuarida && !h.dead);
  const dead    = heroes.filter(h => h.dead);

  let html = '<div class="guarida-view">'
    + '<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:3px;color:var(--god);text-align:center;padding:8px 0 12px">&#127956;&#65039; GUARIDA DEL GRUPO</div>';

  // ── Random event banner (shown once per visit) ────────────────────────────
  if(resting.length > 0 && !guaridaEventShown){
    guaridaEventShown = true;
    const ev = GUARIDA_EVENTS[Math.floor(Math.random()*GUARIDA_EVENTS.length)];
    // Apply effects
    if(ev.healAll) resting.forEach(h=>{ h.hp=Math.min(h.maxHp,(h.hp||0)+1); });
    if(ev.gold)    heroes.forEach(h=>{ h.gold=(h.gold||0)+Math.floor(ev.gold/Math.max(1,heroes.length)); });
    if(ev.goldPerHero) resting.forEach(h=>{ h.gold=(h.gold||0)+ev.goldPerHero; });
    if(ev.xp)     resting.forEach(h=>{ h.xp=(h.xp||0)+ev.xp; });
    saveS();
    html += '<div class="guarida-event-card">'
      + '<div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">'
      + '<span style="font-size:30px">'+ev.ico+'</span>'
      + '<div>'
      + '<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--pul);margin-bottom:2px">EVENTO DE GUARIDA</div>'
      + '<div style="font-size:13px;color:var(--pad);font-style:italic;line-height:1.6">'+ev.txt+'</div>'
      + '</div></div>'
      + '<div style="font-size:12px;color:'+(ev.type==='good'?'var(--gr)':ev.type==='bad'?'var(--bl)':'var(--stl)')+';background:rgba(0,0,0,.3);border-radius:3px;padding:7px 10px">'+ev.effect+'</div>'
      + '</div>';
  }

  // ── Facilities ────────────────────────────────────────────────────────────
  html += renderFacilities(resting);

  // ── Resting heroes ────────────────────────────────────────────────────────
  html += '<div class="guarida-section-title">&#128564; EN DESCANSO ('+resting.length+')</div>';
  if(resting.length === 0){
    html += '<div class="guarida-empty">Ningún héroe descansando en la guarida.<br>Envía un héroe aquí para que se recupere.</div>';
  } else {
    resting.forEach(h => { html += renderGuaridaHeroCard(h, true); });
  }

  // ── Active heroes ─────────────────────────────────────────────────────────
  html += '<div class="guarida-section-title">&#9876;&#65039; ACTIVOS EN AVENTURA ('+active.length+')</div>';
  if(active.length === 0){
    html += '<div class="guarida-empty">Todos los héroes están descansando.<br>Recuerda llevar al menos uno a la aventura.</div>';
  } else {
    active.forEach(h => { html += renderGuaridaHeroCard(h, false); });
  }

  // ── Fallen heroes ─────────────────────────────────────────────────────────
  if(dead.length > 0){
    html += '<div class="guarida-section-title">&#128128; CAÍDOS EN BATALLA ('+dead.length+')</div>';
    dead.forEach(h => { html += renderDeadHeroEntry(h); });
  }

  // ── Rest log ──────────────────────────────────────────────────────────────
  if(guaridaRestLog.length > 0){
    html += '<div class="guarida-section-title">&#128220; REGISTRO</div>'
      + '<div style="background:rgba(0,0,0,.25);border:1px solid rgba(201,150,42,.1);border-radius:6px;padding:10px 14px">'
      + guaridaRestLog.slice(0,5).map(l=>'<div style="font-size:12px;color:var(--stl);padding:4px 0;border-bottom:1px solid rgba(255,255,255,.04)">'+l+'</div>').join('')
      + '</div>';
  }

  html += renderGuaridaUpgrades();
  html += '</div>';
  c.innerHTML = html;
}

function renderFacilities(resting){
  const hasWounded = resting.some(h=>(h.hp||0) < (h.maxHp||4));
  const anyResting = resting.length > 0;

  const facilities = [
    {ico:'&#127869;&#65039;', nm:'Cocina de la Guarida',   desc:'Una noche de comida caliente. Recupera 1 HP a todos los que descansan.',       action:'facility_meal',    cost:10,  disabled:!anyResting},
    {ico:'&#128167;',         nm:'Herborista',              desc:'Hierbas medicinales. Recupera 1D4 HP a un héroe específico.',                   action:'facility_herb',    cost:25,  disabled:!hasWounded},
    {ico:'&#9874;&#65039;',   nm:'Mantenimiento de Equipo', desc:'Afila y repara el equipo. +1 dado de ataque en la próxima batalla.',            action:'facility_repair',  cost:20,  disabled:!anyResting},
    {ico:'&#128218;',         nm:'Meditación Arcana',       desc:'El Mago o Elfo recuperan todos los MP gastados.',                               action:'facility_arcane',  cost:0,   disabled:!anyResting},
    {ico:'&#127807;',         nm:'Baño y Descanso Profundo',desc:'Descanso completo: recupera todos los HP a un héroe en la guarida.',            action:'facility_fullrest',cost:50,  disabled:!hasWounded},
  ];

  let html = '<div class="guarida-section-title">&#127981; INSTALACIONES</div>'
    + '<div style="margin-bottom:12px">';

  facilities.forEach(f=>{
    const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);
    const canAfford = totalGold >= f.cost;
    const disabled  = f.disabled || (!canAfford && f.cost > 0);
    html += '<div class="guarida-facility">'
      + '<span style="font-size:24px">'+f.ico+'</span>'
      + '<div style="flex:1">'
      + '<div style="font-family:Cinzel,serif;font-size:12px;color:var(--pa);font-weight:700;margin-bottom:2px">'+f.nm+'</div>'
      + '<div style="font-size:11px;color:var(--stl);font-style:italic">'+f.desc+'</div>'
      + '</div>'
      + (f.cost>0?'<span style="font-family:Cinzel,serif;font-size:12px;color:var(--go);margin-right:8px">'+f.cost+'&#128176;</span>':'<span style="font-family:Cinzel,serif;font-size:10px;color:var(--gr);margin-right:8px">GRATIS</span>')
      + '<button class="guarida-btn guarida-btn-recall" style="'+(disabled?'opacity:.35;cursor:not-allowed':'')
      + '" '+(disabled?'disabled':'onclick="useFacility(\''+f.action+'\')"')+'>USAR</button>'
      + '</div>';
  });

  return html + '</div>';
}

function renderGuaridaHeroCard(h, isResting){
  const hpPct   = Math.max(0, Math.min(100, ((h.hp||0)/(h.maxHp||1))*100));
  const hpCol   = hpPct > 60 ? 'var(--gr)' : hpPct > 30 ? 'var(--go)' : 'var(--bl)';
  const restPct = isResting ? Math.min(100, hpPct) : 0;
  const injured = (h.hp||0) < (h.maxHp||4);
  const av      = h.photo
    ? '<img src="'+h.photo+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;position:absolute;inset:0">'
    : '<span style="font-size:22px">'+h.ico+'</span>';

  // Status tags
  let statusTags = '';
  if(h.hp<=0)           statusTags += '<span style="background:rgba(139,26,26,.3);border:1px solid var(--bld);border-radius:3px;font-family:Cinzel,serif;font-size:9px;color:var(--bl);padding:1px 6px;margin-right:4px">CRÍTICO</span>';
  else if(injured)      statusTags += '<span style="background:rgba(201,150,42,.15);border:1px solid var(--god);border-radius:3px;font-family:Cinzel,serif;font-size:9px;color:var(--go);padding:1px 6px;margin-right:4px">HERIDO</span>';
  else                  statusTags += '<span style="background:rgba(42,90,42,.2);border:1px solid var(--grd);border-radius:3px;font-family:Cinzel,serif;font-size:9px;color:var(--gr);padding:1px 6px;margin-right:4px">EN FORMA</span>';
  if(isResting)         statusTags += '<span style="background:rgba(74,128,212,.15);border:1px solid rgba(74,128,212,.4);border-radius:3px;font-family:Cinzel,serif;font-size:9px;color:var(--mg);padding:1px 6px">DESCANSANDO</span>';

  // Skills quick view
  const skillsHtml = (h.sk||[]).slice(0,3).map(s=>
    '<span style="font-size:10px;color:var(--stl);background:rgba(0,0,0,.3);border-radius:2px;padding:1px 5px;margin-right:3px">'
    +(s.pasiva?'P':'A')+' '+s.n+'</span>'
  ).join('');

  const actionBtn = isResting
    ? '<button class="guarida-btn guarida-btn-recall" onclick="recallHero('+h.id+')">&#9876; AL GRUPO</button>'
    : '<button class="guarida-btn guarida-btn-rest" onclick="sendToRest('+h.id+')">&#128564; DESCANSAR</button>';

  return '<div class="guarida-hero-card">'
    + '<div class="guarida-hero-hdr">'
    + '<div class="guarida-hero-av" style="background:radial-gradient(circle at 40% 35%,'+h.col+'44,'+h.col+'11);position:relative">'+av+'</div>'
    + '<div class="guarida-hero-body">'
    + '<div class="guarida-hero-name">'+h.name+'</div>'
    + '<div class="guarida-hero-cls">'+h.cls+' &bull; Nv '+( h.level||1)+' &bull; '+( h.gold||0)+' &#128176;</div>'
    + '<div style="margin:5px 0 3px;display:flex;gap:6px;flex-wrap:wrap">'+statusTags+'</div>'
    + '<div class="guarida-hp-bar"><div class="guarida-hp-fill" style="width:'+hpPct+'%;background:linear-gradient(90deg,'+hpCol+','+hpCol+'88)"></div></div>'
    + '<div style="font-size:10px;color:var(--stl);margin-top:2px">&#10084; '+( h.hp||0)+' / '+(h.maxHp||0)+(isResting&&injured?' — Recuperando...':'')+'</div>'
    + (skillsHtml?'<div style="margin-top:5px">'+skillsHtml+'</div>':'')
    + '</div>'
    + '<div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0;margin-left:8px">'+actionBtn+'</div>'
    + '</div>'
    + '</div>';
}

function renderDeadHeroEntry(h){
  const av = h.photo
    ? '<img src="'+h.photo+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;filter:grayscale(1);opacity:.6">'
    : '<span style="font-size:22px;filter:grayscale(1);opacity:.5">'+h.ico+'</span>';
  return '<div class="dead-card">'
    + '<div style="width:40px;height:40px;border-radius:50%;border:2px solid rgba(139,26,26,.4);display:flex;align-items:center;justify-content:center;flex-shrink:0;position:relative;overflow:hidden;background:rgba(20,6,6,.8)">'+av+'</div>'
    + '<div style="flex:1">'
    + '<div style="font-family:Cinzel,serif;font-size:13px;color:rgba(200,150,150,.7);margin-bottom:2px">'+h.name+'</div>'
    + '<div style="font-size:11px;color:var(--stl)">'+h.cls+' &bull; Nv '+(h.level||1)+'  &bull; Caído en combate</div>'
    + (h.deathNote?'<div style="font-size:11px;color:rgba(200,100,100,.6);font-style:italic;margin-top:3px">'+h.deathNote+'</div>':'')
    + '</div>'
    + '<button onclick="removeDeadHero('+h.id+')" style="background:none;border:1px solid rgba(139,26,26,.3);border-radius:3px;color:rgba(139,26,26,.6);font-size:11px;padding:4px 8px;cursor:pointer;flex-shrink:0">RETIRAR</button>'
    + '</div>';
}

// ── ACTIONS ───────────────────────────────────────────────────────────────────
function sendToRest(heroId){
  const h = heroes.find(x=>x.id===heroId);
  if(!h) return;
  h.enGuarida = true;
  guaridaEventShown = false; // reset so event shows next visit
  guaridaRestLog.unshift('&#128564; '+h.name+' entra en descanso con '+(h.hp||0)+'/'+(h.maxHp||0)+' HP.');
  rH(); saveS(); renderGuarida();
  toast('&#128564; '+h.name+' va a descansar a la guarida');
}

function recallHero(heroId){
  const h = heroes.find(x=>x.id===heroId);
  if(!h) return;

  // Recovery: rest heals based on how injured they were
  const missing = (h.maxHp||4) - (h.hp||0);
  let healed = 0;
  if(missing > 0){
    healed = Math.min(missing, Math.floor(Math.random()*3)+1); // 1-3 HP natural recovery
    h.hp = Math.min(h.maxHp, (h.hp||0) + healed);
  }

  h.enGuarida = false;

  // Random departure encounter
  const enc = GUARIDA_ENCOUNTERS[Math.floor(Math.random()*GUARIDA_ENCOUNTERS.length)];
  let encMsg = '';
  if(enc.gold){ h.gold=(h.gold||0)+enc.gold; encMsg=' +'+enc.gold+' oros.'; }
  if(enc.roll){
    const roll = Math.floor(Math.random()*6)+1;
    if(roll >= 4){ h.gold=(h.gold||0)+30; encMsg=' Tira '+roll+': ¡+30 oros!'; }
    else { h.hp=Math.max(0,(h.hp||0)-1); encMsg=' Tira '+roll+': -1 HP.'; }
  }

  guaridaRestLog.unshift('&#9876;&#65039; '+h.name+' vuelve al grupo'+(healed>0?' (+'+healed+' HP recuperado)':'')+(encMsg||'.')+'.');
  rH(); saveS(); renderGuarida();
  toast('&#9876;&#65039; '+h.name+' vuelve al grupo'+(healed>0?' +'+healed+' HP':''));
}

function markAsDead(heroId, note){
  const h = heroes.find(x=>x.id===heroId);
  if(!h) return;
  h.dead   = true;
  h.enGuarida = false;
  h.hp     = 0;
  h.deathNote = note || 'Caído en combate.';
  guaridaRestLog.unshift('&#128128; '+h.name+' ha caído en combate.');
  rH(); saveS(); renderGuarida();
  toast('&#128128; '+h.name+' ha caído...');
}

function removeDeadHero(heroId){
  if(!confirm('¿Retirar permanentemente este héroe caído? Esta acción no se puede deshacer.')) return;
  heroes = heroes.filter(x=>x.id!==heroId);
  rH(); saveS(); renderGuarida();
  toast('&#128128; Héroe retirado del registro.');
}

function useFacility(action){
  const resting = heroes.filter(h=>h.enGuarida&&!h.dead);
  if(!resting.length && action !== 'facility_arcane') return;

  const totalGold = heroes.reduce((s,h)=>s+(h.gold||0),0);

  if(action==='facility_meal'){
    if(totalGold < 10){ toast('Sin oros suficientes'); return; }
    deductGroupGold(10);
    resting.forEach(h=>{ h.hp=Math.min(h.maxHp,(h.hp||0)+1); });
    guaridaRestLog.unshift('&#127869;&#65039; Cena en la guarida: todos recuperan 1 HP.');
    toast('&#127869;&#65039; Cena caliente: +1 HP a todos');
  }
  else if(action==='facility_herb'){
    if(totalGold < 25){ toast('Sin oros suficientes'); return; }
    const wounded = resting.filter(h=>(h.hp||0)<(h.maxHp||4));
    if(!wounded.length){ toast('Nadie herido'); return; }
    deductGroupGold(25);
    const target = wounded[0]; // heal most injured
    const heal = Math.floor(Math.random()*4)+1;
    target.hp = Math.min(target.maxHp, (target.hp||0)+heal);
    guaridaRestLog.unshift('&#127807; Herborista: '+target.name+' recupera '+heal+' HP.');
    toast('&#127807; '+target.name+' recupera '+heal+' HP');
  }
  else if(action==='facility_repair'){
    if(totalGold < 20){ toast('Sin oros suficientes'); return; }
    deductGroupGold(20);
    resting.forEach(h=>{ h._repairBuff=true; });
    guaridaRestLog.unshift('&#9874;&#65039; Equipo reparado: +1 dado ATK próxima batalla.');
    toast('&#9874;&#65039; Equipo reparado para todos');
  }
  else if(action==='facility_arcane'){
    const casters = resting.filter(h=>{
      const t=(h.type||'').toLowerCase();
      return ['mago','elfo','hechicera','alquimista','elementalista','piromante'].some(k=>t.includes(k));
    });
    if(!casters.length){ toast('Ningún lanzador de hechizos descansando'); return; }
    casters.forEach(h=>{ h.mp=h.maxMp; });
    guaridaRestLog.unshift('&#128302; Meditación arcana: MP restaurados.');
    toast('&#128302; MP restaurados para lanzadores');
  }
  else if(action==='facility_fullrest'){
    if(totalGold < 50){ toast('Sin oros suficientes (necesitas 50)'); return; }
    const wounded = resting.filter(h=>(h.hp||0)<(h.maxHp||4));
    if(!wounded.length){ toast('Nadie herido'); return; }
    deductGroupGold(50);
    // Heal most injured hero fully
    wounded.sort((a,b)=>(a.hp/a.maxHp)-(b.hp/b.maxHp));
    const target = wounded[0];
    const healed = (target.maxHp||4) - (target.hp||0);
    target.hp = target.maxHp;
    guaridaRestLog.unshift('&#127807; Descanso profundo: '+target.name+' totalmente recuperado (+'+healed+' HP).');
    toast('&#127807; '+target.name+' completamente recuperado!');
  }

  rH(); saveS(); renderGuarida();
}

function deductGroupGold(amount){
  let remaining = amount;
  for(const h of heroes){
    const pay = Math.min(remaining, h.gold||0);
    h.gold = (h.gold||0) - pay;
    remaining -= pay;
    if(remaining <= 0) break;
  }
}


