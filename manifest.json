// APPLY REWARDS ON VICTORY
// ══════════════════════════════════════════════════════════════════════════════
function victoryScreen(){
  if(!dg) return;
  const lore = dg.lore;
  const diff = dg.difficulty||'medio';
  const d = DIFFICULTY[diff]||DIFFICULTY.medio;

  // Calculate rewards based on difficulty
  const goldPerHero = diff==='facil'?ri(40,70):diff==='dificil'?ri(80,150):ri(60,120);
  const xpPerHero   = diff==='facil'?100:diff==='dificil'?200:150;
  const bonusItem   = diff==='facil'
    ? {nm:'Poción de Curación',ico:'&#129514;',ds:'Restaura 1D4+2 HP.',r:'common'}
    : diff==='dificil'
    ? {nm:'Objeto Mágico Raro',ico:'&#128302;',ds:'Objeto de gran poder. Identifica con el Mago.',r:'rare'}
    : {nm:'Equipo de Aventura',ico:'&#9876;&#65039;',ds:'Equipo poco común del dungeon.',r:'uncommon'};

  // Collect all loot from cleared rooms
  const dungeonLoot = [];
  (dg.rooms||[]).forEach(room=>{
    if(room.state==='cleared'||room.state==='revealed'){
      (room.content.loots||[]).forEach(l=>{
        dungeonLoot.push({nm:l.nm,ico:l.ico,ds:l.det||l.ds||'',r:'uncommon',src:'Sala '+(room.idx+1)+' — '+lore.tl});
      });
    }
  });

  // Apply gold and XP to active heroes
  const activeHeroes = heroes.filter(h=>!h.enGuarida&&!h.dead);
  activeHeroes.forEach(h=>{
    h.gold=(h.gold||0)+goldPerHero;
    h.xp=(h.xp||0)+xpPerHero;
    // Level up check: every 200 XP
    const newLevel = Math.floor(h.xp/200)+1;
    if(newLevel > (h.level||1)){
      h.level=newLevel;
      const sk2=pickTwoSkills(h);
      if(sk2.length>=2){ const hcopy=h; setTimeout(()=>showSkillChoicePopup(hcopy,sk2,null),800+activeHeroes.indexOf(h)*600); }
    }
  });

  // Add bonus item + dungeon loot to inventory
  addToInventory({...bonusItem, src:'Recompensa — '+lore.tl}, 'Recompensa');
  dungeonLoot.forEach(l=>{ addToInventory(l, l.src); });

  // Award esquirla
  const esquirlasEarned = diff==='dificil' ? 2 : 1;
  esquirlas += esquirlasEarned;
  if(!esquirlasLog) esquirlasLog=[];
  esquirlasLog.unshift('&#128142; +'+esquirlasEarned+' esquirla'+(esquirlasEarned>1?'s':'')+' — '+lore.tl+' ('+new Date().toLocaleDateString('es')+')');

  // Apply guarida bonuses if purchased
  if(guaridaMejoras && guaridaMejoras.sala_entrenamiento){
    activeHeroes.forEach(h=>{ h.xp=(h.xp||0)+25; });
  }

  rH(); saveS();

  const c=document.getElementById('skcon');
  c.innerHTML='<div style="padding:40px 20px;text-align:center">'
    +'<div style="font-size:72px;margin-bottom:16px">&#11088;</div>'
    +'<div style="font-family:Cinzel,serif;font-size:22px;color:var(--go);letter-spacing:2px;margin-bottom:6px">MISIÓN COMPLETADA</div>'
    +'<div style="font-family:Cinzel,serif;font-size:13px;color:var(--god);margin-bottom:18px">'+lore.tl+'</div>'

    // Rewards breakdown
    +'<div style="background:rgba(0,0,0,.4);border:2px solid var(--go);border-radius:8px;padding:18px;margin-bottom:16px;text-align:left">'
    +'<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:3px;color:var(--god);margin-bottom:12px;text-align:center">RECOMPENSAS APLICADAS</div>'
    +'<div style="display:flex;flex-direction:column;gap:8px">'
    +'<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(201,150,42,.08);border-radius:4px">'
    +'<span style="font-size:20px">&#128176;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa);flex:1">Oro</span>'
    +'<span style="font-family:Cinzel,serif;font-size:15px;color:var(--go);font-weight:700">+'+goldPerHero+' por héroe</span>'
    +'</div>'
    +'<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(201,150,42,.08);border-radius:4px">'
    +'<span style="font-size:20px">&#11088;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa);flex:1">Experiencia</span>'
    +'<span style="font-family:Cinzel,serif;font-size:15px;color:var(--go);font-weight:700">+'+xpPerHero+' XP por héroe</span>'
    +'</div>'
    +'<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(128,74,212,.12);border-radius:4px">'
    +'<span style="font-size:20px">&#128142;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa);flex:1">Esquirla de Mazmorra</span>'
    +'<span style="font-family:Cinzel,serif;font-size:15px;color:var(--pul);font-weight:700">+'+esquirlasEarned+' (total: '+esquirlas+')</span>'
    +'</div>'
    +'<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(201,150,42,.08);border-radius:4px">'
    +'<span style="font-size:20px">'+bonusItem.ico+'</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa);flex:1">'+bonusItem.nm+'</span>'
    +'<span style="font-family:Cinzel,serif;font-size:11px;color:var(--god);text-transform:uppercase">&#10003; Inventario</span>'
    +'</div>'
    +(dungeonLoot.length?'<div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(42,90,42,.15);border-radius:4px">'
    +'<span style="font-size:20px">&#127917;</span>'
    +'<span style="font-family:Cinzel,serif;font-size:13px;color:var(--pa);flex:1">Botín del dungeon</span>'
    +'<span style="font-family:Cinzel,serif;font-size:11px;color:var(--gr)">'+dungeonLoot.length+' objetos &#10003;</span>'
    +'</div>':'')
    +'</div></div>'

    // Hero summary
    +(activeHeroes.length?'<div style="display:flex;flex-direction:column;gap:6px;margin-bottom:18px">'
    +activeHeroes.map(h=>'<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(0,0,0,.3);border:1px solid rgba(201,150,42,.15);border-radius:5px">'
      +'<span style="font-size:20px">'+h.ico+'</span>'
      +'<div style="flex:1;text-align:left">'
      +'<div style="font-family:Cinzel,serif;font-size:12px;color:var(--pa)">'+h.name+'</div>'
      +'<div style="font-size:11px;color:var(--stl)">Nv '+(h.level||1)+' &bull; '+( h.xp||0)+' XP &bull; '+(h.gold||0)+' oros</div>'
      +'</div>'
      +'<div style="text-align:right"><div style="font-size:11px;color:var(--go)">&#10084; '+(h.hp||0)+'/'+(h.maxHp||0)+'</div></div>'
      +'</div>'
    ).join('')+'</div>':'')

    +'<button onclick="resetDungeon()" style="background:linear-gradient(135deg,var(--bl),var(--bld));border:2px solid var(--bl);border-radius:5px;color:var(--pa);font-family:Cinzel,serif;font-size:13px;font-weight:700;letter-spacing:2px;padding:14px 28px;cursor:pointer;touch-action:manipulation">&#9876;&#65039; NUEVA ESCARAMUZA</button>'
    +'</div>';
}


// ══════════════════════════════════════════════════════════════════════════════
// CRÓNICA — Notas + gestor de esquirlas
// ══════════════════════════════════════════════════════════════════════════════

const OBJETIVO_ESQUIRLAS = 100;

function renderN(){
  // Keep existing textarea notes functional
  const ta = document.getElementById('cnotes');
  if(ta) ta.value = cn||'';
  // Render esquirlas panel
  renderEsquirlas();
}

function renderEsquirlas(){
  const el = document.getElementById('esquirlas-panel');
  if(!el) return;

  const pct  = Math.min(100, Math.round((esquirlasPozo / OBJETIVO_ESQUIRLAS) * 100));
  const done = esquirlasPozo >= OBJETIVO_ESQUIRLAS;
  const held = esquirlas; // in hand, not yet thrown

  el.innerHTML =
    // Title
    '<div style="font-family:Cinzel,serif;font-size:11px;letter-spacing:3px;color:var(--god);padding:10px 0 12px;text-align:center">&#128142; POZO DE LAS ESQUIRLAS</div>'

    // Lore blurb
    + '<div style="font-size:13px;color:var(--pad);font-style:italic;line-height:1.7;margin-bottom:14px;padding:10px 12px;background:rgba(0,0,0,.25);border:1px solid rgba(201,150,42,.12);border-radius:5px">'
    + 'Una antigua profecía dice que cuando cien almas de mazmorra sean arrojadas al Pozo del Umbral, '
    + 'las puertas de Zargon se abrirán para siempre o serán selladas eternamente. '
    + 'Cada escaramuza completada deja una esquirla de mazmorra en vuestras manos.'
    + '</div>'

    // Progress bar
    + '<div style="margin-bottom:16px">'
    + '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px">'
    + '<span style="font-family:Cinzel,serif;font-size:11px;color:var(--god)">PROGRESO DE CAMPAÑA</span>'
    + '<span style="font-family:Cinzel,serif;font-size:16px;color:'+(done?'var(--go)':'var(--pa)')+';font-weight:700">'+esquirlasPozo+' / '+OBJETIVO_ESQUIRLAS+'</span>'
    + '</div>'
    + '<div style="height:14px;background:rgba(0,0,0,.5);border-radius:7px;overflow:hidden;border:1px solid rgba(201,150,42,.2);position:relative">'
    + '<div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,#4a2080,#8a50d0,var(--go));border-radius:7px;transition:width .6s ease;position:relative">'
    + (pct>8?'<span style="position:absolute;right:8px;top:50%;transform:translateY(-50%);font-family:Cinzel,serif;font-size:9px;color:rgba(255,255,255,.8)">'+pct+'%</span>':'')
    + '</div>'
    + '</div>'
    // Milestone markers
    + '<div style="display:flex;justify-content:space-between;margin-top:4px">'
    + [0,25,50,75,100].map(m=>'<span style="font-size:9px;color:'+(esquirlasPozo>=m?'var(--go)':'rgba(201,150,42,.3)')+';font-family:Cinzel,serif">'+m+'</span>').join('')
    + '</div>'
    + '</div>'

    // In-hand esquirlas
    + '<div style="background:linear-gradient(135deg,rgba(128,74,212,.1),rgba(74,50,130,.08));border:1px solid rgba(128,74,212,.3);border-radius:8px;padding:14px;margin-bottom:12px">'
    + '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">'
    + '<div>'
    + '<div style="font-family:Cinzel,serif;font-size:13px;color:var(--pul);font-weight:700;margin-bottom:2px">&#128142; Esquirlas en mano</div>'
    + '<div style="font-size:11px;color:var(--stl)">Obtenidas al terminar mazmorras</div>'
    + '</div>'
    + '<div style="font-family:Cinzel,serif;font-size:32px;color:var(--pul);font-weight:700">'+held+'</div>'
    + '</div>'
    // Buttons: +/- held, throw into well
    + '<div style="display:flex;gap:8px">'
    + '<button onclick="adjEsquirlas(-1)" style="flex:1;background:rgba(0,0,0,.4);border:1px solid rgba(128,74,212,.3);border-radius:4px;color:var(--pul);font-family:Cinzel,serif;font-size:18px;padding:8px;cursor:pointer;touch-action:manipulation">−</button>'
    + '<button onclick="adjEsquirlas(1)"  style="flex:1;background:rgba(0,0,0,.4);border:1px solid rgba(128,74,212,.3);border-radius:4px;color:var(--pul);font-family:Cinzel,serif;font-size:18px;padding:8px;cursor:pointer;touch-action:manipulation">+</button>'
    + '<button onclick="throwEsquirlas()" '+(held<=0?'disabled style="opacity:.4;cursor:not-allowed;':'style="')+'flex:2;background:linear-gradient(135deg,#2a1a50,#1a0a30);border:2px solid rgba(128,74,212,.5);border-radius:4px;color:var(--pul);font-family:Cinzel,serif;font-size:11px;letter-spacing:1px;padding:8px 10px;cursor:pointer;touch-action:manipulation">&#11835; ECHAR AL POZO</button>'
    + '</div>'
    + '</div>'

    // Done banner
    + (done
      ? '<div style="background:linear-gradient(135deg,rgba(201,150,42,.2),rgba(128,74,212,.15));border:2px solid var(--go);border-radius:8px;padding:16px;text-align:center;margin-bottom:12px">'
        + '<div style="font-size:48px;margin-bottom:8px">&#127942;</div>'
        + '<div style="font-family:Cinzel,serif;font-size:16px;color:var(--go);font-weight:700;margin-bottom:6px">¡CAMPAÑA COMPLETADA!</div>'
        + '<div style="font-size:13px;color:var(--pad);font-style:italic;line-height:1.7">Las 100 esquirlas han sido arrojadas al Pozo del Umbral.<br>La profecía se ha cumplido. Zargon ha caído.</div>'
        + '</div>'
      : '')

    // History log
    + '<div style="font-family:Cinzel,serif;font-size:10px;letter-spacing:2px;color:var(--stl);margin-bottom:6px">REGISTRO DE MAZMORRAS COMPLETADAS</div>'
    + '<div id="esquirlas-log" style="background:rgba(0,0,0,.2);border-radius:4px;padding:8px 10px;min-height:40px">'
    + (esquirlasLog && esquirlasLog.length
        ? esquirlasLog.slice(0,8).map(l=>'<div style="font-size:11px;color:var(--stl);padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04)">'+l+'</div>').join('')
        : '<div style="font-size:11px;color:rgba(201,150,42,.3);font-style:italic">Ninguna mazmorra completada todavía.</div>'
    )
    + '</div>';
}

function adjEsquirlas(delta){
  esquirlas = Math.max(0, esquirlas + delta);
  saveS(); renderEsquirlas();
}

function throwEsquirlas(){
  if(esquirlas <= 0) return;
  const thrown = esquirlas;
  esquirlasPozo += thrown;
  esquirlas = 0;
  const logMsg = '&#128142; ×'+thrown+' esquirlas → Pozo (total: '+esquirlasPozo+')';
  if(!esquirlasLog) esquirlasLog = [];
  esquirlasLog.unshift(logMsg);
  if(esquirlasLog.length > 20) esquirlasLog.pop();
  saveS(); renderEsquirlas();
  if(esquirlasPozo >= OBJETIVO_ESQUIRLAS) toast('&#127942; ¡100 esquirlas! ¡CAMPAÑA COMPLETADA!');
  else toast('&#128142; ×'+thrown+' esquirlas echadas al pozo');
}

