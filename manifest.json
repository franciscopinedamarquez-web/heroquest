const STARTER_ITEM_POOL = [
  {nm:'Pocion de Curacion',    ico:'&#129514;', ds:'Restaura 1D4+2 HP.',                    r:'common'},
  {nm:'Racion de Viaje',       ico:'&#127833;', ds:'+1 HP tras el proximo combate.',          r:'common'},
  {nm:'Antidoto',              ico:'&#129514;', ds:'Cura el veneno inmediatamente.',          r:'common'},
  {nm:'Daga de Emergencia',    ico:'&#128505;&#65039;', ds:'+1 ATK en un combate. Uso único.',r:'common'},
  {nm:'Vendas de Campo',       ico:'&#129657;', ds:'Recupera 1 HP. Solo fuera de combate.',  r:'common'},
  {nm:'Pedernal y Yesca',      ico:'&#128293;', ds:'Enciende antorchas. +1 dado vs criaturas de oscuridad.',r:'common'},
  {nm:'Mapa Borroso',          ico:'&#128205;', ds:'Revela vagamente el tipo de la sala 3 de la proxima mazmorra.',r:'uncommon'},
  {nm:'Amuleto de la Suerte',  ico:'&#128140;', ds:'Una vez por sesion: repite una tirada fallida.',r:'uncommon'},
  {nm:'Cuerda de Seda x10m',   ico:'&#129717;', ds:'Util para bajar pozos o atar enemigos. Rompe con 1-2 en 1D6.',r:'common'},
  {nm:'Pocion de Fuerza',      ico:'&#129514;', ds:'+2 ATK durante 1 batalla.',               r:'uncommon'},
  {nm:'Escudo de Madera',      ico:'&#128737;&#65039;', ds:'+1 DEF. Se rompe con 1 en 1D6 al recibirimpacto.',r:'common'},
  {nm:'Tiza de Mazmorra',      ico:'&#128396;&#65039;', ds:'Marca paredes para no perderse. Evita perderse en laberintos.',r:'common'},
];

function giveStarterItems(hero){
  if(!gi) gi = [];
  const pool = [...STARTER_ITEM_POOL];
  // Pick 2 random distinct items
  const shuffled = pool.sort(()=>Math.random()-.5);
  const items = shuffled.slice(0, 2);
  items.forEach(it=>{
    gi.push({...it, qty:1, src:'Equipo inicial de '+hero.name, added:Date.now()});
  });
  return items;
}

function createH(){
  const nm = document.getElementById('hinp').value.trim();
  if(!nm){toast('Escribe un nombre');return;}
  if(heroes.length>=6){toast('Maximo 6 heroes');return;}
  const t = HT[sT];
  if(!t){toast('Selecciona una clase');return;}
  const t_copy = JSON.parse(JSON.stringify(t));
  const h = {
    id:Date.now(), type:sT, notes:'', gold:100, level:1, xp:0, photo:null,
    ...t_copy,
    name:nm,  // always after spread so template can't overwrite it
  };
  heroes.push(h);
  const starterItems = giveStarterItems(h);
  closeHeroModal();
  rH(); saveS();
  const itemNames = starterItems.map(x=>x.nm).join(' y ');
  toast(t.ico+' '+nm+' se une a la aventura! Equipo inicial: '+itemNames);
}

